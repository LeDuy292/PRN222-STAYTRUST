@inject NavigationManager NavManager

<aside class="w-64 bg-neutral-dark border-r border-neutral-border flex flex-col h-full shrink-0 custom-scrollbar overflow-y-auto">
    <!-- Logo -->
    <div class="p-6 flex items-center gap-3">
        <div class="bg-primary/20 p-2 rounded-lg">
            <span class="material-symbols-outlined text-primary text-2xl">shield_with_heart</span>
        </div>
        <div>
            <h1 class="text-slate-100 font-bold text-lg leading-tight">Staytrust</h1>
            <p class="text-primary text-xs font-medium uppercase tracking-wider">Admin Portal</p>
        </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-4 space-y-1">
        <NavLink href="/" Match="NavLinkMatch.All"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="text-sm font-medium">Dashboard</span>
        </NavLink>

        <NavLink href="/users"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">group</span>
            <span class="text-sm font-medium">User Management</span>
        </NavLink>

        <NavLink href="/listings"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">house</span>
            <span class="text-sm font-medium">Listings</span>
        </NavLink>

        <NavLink href="/packages"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">inventory_2</span>
            <span class="text-sm font-medium">Packages</span>
        </NavLink>

        <NavLink href="/invoices"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">receipt_long</span>
            <span class="text-sm font-medium">Invoices</span>
        </NavLink>

        <NavLink href="/roommate-match"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">group</span>
            <span class="text-sm font-medium">Roommate Match</span>
        </NavLink>

        <NavLink href="/notifications"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-primary/10 hover:text-primary transition-all"
                 ActiveClass="bg-primary/10 text-primary border border-primary/20">
            <span class="material-symbols-outlined">campaign</span>
            <span class="text-sm font-medium">Notifications</span>
        </NavLink>
    </nav>

    <!-- User Profile -->
    <div class="p-4 border-t border-neutral-border">
        <div class="flex items-center gap-3 p-2 rounded-xl bg-accent-dark/30">
            <div class="w-9 h-9 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-sm">person</span>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-slate-100 truncate">Admin User</p>
                <p class="text-xs text-slate-400 truncate">Super Admin</p>
            </div>
            <button class="text-slate-400 hover:text-red-400 transition-colors">
                <span class="material-symbols-outlined text-xl">logout</span>
            </button>
        </div>
    </div>
</aside>
