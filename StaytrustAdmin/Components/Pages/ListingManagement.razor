@page "/listings"
@using StaytrustAdmin.Models
@using StaytrustAdmin.Services
@inject IListingService ListingService
@layout MainLayout

<PageTitle>Staytrust Admin - Listing Management</PageTitle>

<!-- Header -->
<header class="h-16 border-b border-neutral-border flex items-center justify-between px-6 bg-neutral-dark shrink-0">
    <div class="flex items-center gap-3">
        @if (selectedLandlord != null)
        {
            <button class="flex items-center gap-2 text-slate-400 hover:text-primary transition-colors text-sm font-medium"
                    @onclick="BackToLandlords">
                <span class="material-symbols-outlined text-lg">arrow_back</span>
                All Landlords
            </button>
            <span class="text-neutral-border">/</span>
            <span class="font-bold text-slate-200">@selectedLandlord.FullName</span>
        }
        else
        {
            <span class="font-bold text-slate-200">Landlord & Listing Management</span>
        }
    </div>
    <div class="flex items-center gap-3 flex-1 max-w-sm ml-6">
        <div class="relative w-full">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
            <input class="w-full bg-background-dark/50 border-neutral-border border rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary focus:outline-none transition-all"
                   placeholder="@(selectedLandlord == null ? "Search landlords..." : "Search rooms...")"
                   value="@searchText"
                   @oninput="OnSearchChanged" />
        </div>
    </div>
</header>

<div class="flex-1 overflow-y-auto p-6 lg:p-10 custom-scrollbar">

    @if (!string.IsNullOrEmpty(globalError))
    {
        <div class="bg-red-500/10 border border-red-500/30 text-red-400 p-4 rounded-xl flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <p class="text-sm font-medium">@globalError</p>
            </div>
            <button @onclick="() => globalError = null" class="p-1 rounded hover:bg-red-500/20">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
    }

    <!-- ===== VIEW 1: LANDLORD LIST ===== -->
    @if (selectedLandlord == null)
    {
        <div class="mb-8">
            <nav class="flex gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                <span>Main</span><span>/</span><span class="text-primary">Listing Management</span>
            </nav>
            <h1 class="text-3xl font-black tracking-tight">Landlords</h1>
            <p class="text-slate-500 mt-1 text-sm">Select a landlord to view and manage their listings. Spam warnings are highlighted automatically.</p>
        </div>

        @if (isLoading)
        {
            <div class="flex items-center justify-center h-64">
                <span class="material-symbols-outlined text-5xl text-primary animate-spin">progress_activity</span>
            </div>
        }
        else if (loadError != null)
        {
            <div class="flex flex-col items-center justify-center h-64 gap-4">
                <span class="material-symbols-outlined text-5xl text-red-400">error</span>
                <p class="text-red-400 font-bold">@loadError</p>
                <button class="bg-primary/10 text-primary px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-primary/20" @onclick="LoadLandlordsAsync">
                    <span class="material-symbols-outlined text-lg mr-1">refresh</span> Retry
                </button>
            </div>
        }
        else
        {
            @if (SpamLandlords.Any())
            {
                <div class="border border-red-500/40 bg-red-500/10 rounded-2xl p-4 mb-6 flex items-start gap-4">
                    <span class="material-symbols-outlined text-red-400 text-3xl mt-0.5">warning</span>
                    <div>
                        <p class="font-bold text-red-400 mb-1">⚠️ Spam Activity Detected</p>
                        <p class="text-sm text-slate-400">
                            @string.Join(", ", SpamLandlords.Select(l => l.FullName))
                            @(SpamLandlords.Count == 1 ? " has" : " have") posted 3+ listings in the last 24h. Please review their accounts.
                        </p>
                    </div>
                </div>
            }

            @if (!landlords.Any())
            {
                <div class="flex items-center justify-center h-48">
                    <p class="text-slate-500">No landlords found.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
                    @foreach (var landlord in landlords)
                    {
                        <div class="group bg-surface-dark border @(landlord.IsSpamFlagged ? "border-red-500/50" : landlord.IsBlocked ? "border-slate-700" : "border-primary/10") rounded-2xl p-5 hover:shadow-xl transition-all cursor-pointer relative overflow-hidden @(landlord.IsBlocked ? "opacity-60" : "")"
                             @onclick="() => SelectLandlord(landlord)">

                            @if (landlord.IsSpamFlagged)
                            {
                                <div class="absolute top-0 right-0 bg-red-500 text-white text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-bl-xl">
                                    ⚠ Spam Alert
                                </div>
                            }
                            else if (landlord.IsBlocked)
                            {
                                <div class="absolute top-0 right-0 bg-slate-700 text-slate-300 text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-bl-xl">
                                    Blocked
                                </div>
                            }

                            <div class="flex items-center gap-4 mb-4">
                                @if (!string.IsNullOrEmpty(landlord.AvatarUrl))
                                {
                                    <img src="@landlord.AvatarUrl" class="w-12 h-12 rounded-full object-cover ring-2 ring-primary/30" />
                                }
                                else
                                {
                                    <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center ring-2 ring-primary/30">
                                        <span class="material-symbols-outlined text-primary text-xl">person</span>
                                    </div>
                                }
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-bold text-slate-100 group-hover:text-primary transition-colors truncate">@landlord.FullName</h3>
                                    <p class="text-xs text-slate-500 truncate">@landlord.Email</p>
                                </div>
                            </div>

                            <div class="grid grid-cols-3 gap-2 mb-4 text-center">
                                <div class="bg-background-dark/60 rounded-xl p-2">
                                    <div class="text-lg font-black text-slate-200">@landlord.TotalRooms</div>
                                    <div class="text-[10px] text-slate-500 font-bold uppercase">Total</div>
                                </div>
                                <div class="bg-background-dark/60 rounded-xl p-2">
                                    <div class="text-lg font-black text-emerald-400">@landlord.ActiveRooms</div>
                                    <div class="text-[10px] text-slate-500 font-bold uppercase">Active</div>
                                </div>
                                <div class="bg-background-dark/60 rounded-xl p-2">
                                    <div class="text-lg font-black @(landlord.RoomsPostedLast24h >= 3 ? "text-red-400" : "text-amber-400")">@landlord.RoomsPostedLast24h</div>
                                    <div class="text-[10px] text-slate-500 font-bold uppercase">Last 24h</div>
                                </div>
                            </div>

                            <div class="flex gap-2" @onclick:stopPropagation>
                                <button class="flex-1 py-2 text-xs font-bold rounded-xl bg-primary/10 hover:bg-primary/20 text-primary transition-all flex items-center justify-center gap-1"
                                        @onclick="() => SelectLandlord(landlord)">
                                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                                    View Listings (@landlord.TotalRooms)
                                </button>
                                @if (landlord.IsBlocked)
                                {
                                    <button class="py-2 px-3 text-xs font-bold rounded-xl bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border border-emerald-500/20 transition-all"
                                            @onclick='() => ToggleLandlordBlock(landlord, false)' title="Unblock Landlord">
                                        <span class="material-symbols-outlined text-sm">lock_open</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="py-2 px-3 text-xs font-bold rounded-xl bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 transition-all"
                                            @onclick='() => ToggleLandlordBlock(landlord, true)' title="Block Landlord">
                                        <span class="material-symbols-outlined text-sm">block</span>
                                    </button>
                                }
                            </div>

                            @if (landlord.IsSpamFlagged)
                            {
                                <div class="mt-3 text-[11px] text-red-400/80 font-medium flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-sm">info</span>
                                    Consider blocking this account for repeated posting.
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    }

    <!-- ===== VIEW 2: ROOMS BY LANDLORD ===== -->
    @if (selectedLandlord != null)
    {
        <div class="bg-surface-dark border @(selectedLandlord.IsSpamFlagged ? "border-red-500/40" : "border-primary/10") rounded-2xl p-5 mb-8 flex flex-col md:flex-row items-start md:items-center gap-5">
            <div class="flex items-center gap-4 flex-1">
                @if (!string.IsNullOrEmpty(selectedLandlord.AvatarUrl))
                {
                    <img src="@selectedLandlord.AvatarUrl" class="w-14 h-14 rounded-full object-cover ring-2 ring-primary/40" />
                }
                else
                {
                    <div class="w-14 h-14 rounded-full bg-primary/20 flex items-center justify-center ring-2 ring-primary/40">
                        <span class="material-symbols-outlined text-primary text-2xl">person</span>
                    </div>
                }
                <div>
                    <h2 class="text-xl font-black text-slate-100">@selectedLandlord.FullName</h2>
                    <p class="text-slate-500 text-sm">@selectedLandlord.Email &bull; @selectedLandlord.Phone</p>
                    <div class="flex items-center gap-3 mt-1.5 flex-wrap">
                        <span class="text-xs font-bold text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded-lg">@selectedLandlord.ActiveRooms Active</span>
                        <span class="text-xs font-bold text-slate-400 bg-slate-700/40 px-2 py-0.5 rounded-lg">@selectedLandlord.TotalRooms Total</span>
                        @if (selectedLandlord.IsSpamFlagged)
                        {
                            <span class="text-xs font-bold text-red-400 bg-red-500/10 px-2 py-0.5 rounded-lg">
                                ⚠ @selectedLandlord.RoomsPostedLast24h posts in last 24h
                            </span>
                        }
                        @if (selectedLandlord.IsBlocked)
                        {
                            <span class="text-xs font-bold text-slate-300 bg-slate-700 px-2 py-0.5 rounded-lg">Account Blocked</span>
                        }
                    </div>
                </div>
            </div>
            <div class="flex gap-2 flex-shrink-0">
                @if (selectedLandlord.IsBlocked)
                {
                    <button class="py-2 px-4 text-sm font-bold rounded-xl bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border border-emerald-500/20 transition-all flex items-center gap-2"
                            @onclick='() => ToggleLandlordBlock(selectedLandlord, false)'>
                        <span class="material-symbols-outlined text-sm">lock_open</span>
                        Unblock Account
                    </button>
                }
                else
                {
                    <button class="py-2 px-4 text-sm font-bold rounded-xl bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 transition-all flex items-center gap-2"
                            @onclick='() => ToggleLandlordBlock(selectedLandlord, true)'>
                        <span class="material-symbols-outlined text-sm">block</span>
                        Block Account
                    </button>
                }
            </div>
        </div>

        <!-- Room Filter Tabs -->
        <div class="flex gap-6 border-b border-primary/10 pb-3 mb-6">
            <button class="relative pb-3 text-sm font-bold @(roomStatusFilter == "all" ? "text-primary" : "text-slate-500 hover:text-primary") transition-colors"
                    @onclick='() => ChangeRoomFilter("all")'>
                All Rooms
                @if (roomStatusFilter == "all") { <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary rounded-t-full"></span> }
            </button>
            <button class="relative pb-3 text-sm font-bold @(roomStatusFilter == "active" ? "text-primary" : "text-slate-500 hover:text-primary") transition-colors"
                    @onclick='() => ChangeRoomFilter("active")'>
                Active / Rented
                @if (roomStatusFilter == "active") { <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary rounded-t-full"></span> }
            </button>
            <button class="relative pb-3 text-sm font-bold @(roomStatusFilter == "hidden" ? "text-primary" : "text-slate-500 hover:text-primary") transition-colors"
                    @onclick='() => ChangeRoomFilter("hidden")'>
                Hidden / Expired
                @if (roomStatusFilter == "hidden") { <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary rounded-t-full"></span> }
            </button>
        </div>

        @if (isLoading)
        {
            <div class="flex items-center justify-center h-48">
                <span class="material-symbols-outlined text-5xl text-primary animate-spin">progress_activity</span>
            </div>
        }
        else if (!rooms.Any())
        {
            <div class="flex items-center justify-center h-48 text-slate-500">
                <p>No listings found for this landlord.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                @foreach (var room in rooms)
                {
                    <div class="group bg-surface-dark border border-primary/10 rounded-xl overflow-hidden hover:border-primary/40 hover:shadow-xl transition-all flex flex-col">
                        <div class="relative aspect-video bg-accent-dark/50 overflow-hidden">
                            @if (!string.IsNullOrEmpty(room.DefaultImageUrl))
                            {
                                <img src="@room.DefaultImageUrl" class="w-full h-full object-cover group-hover:scale-110 transition-all duration-500 opacity-80 group-hover:opacity-100" />
                            }
                            else if (!string.IsNullOrEmpty(room.Image360Url))
                            {
                                <img src="@room.Image360Url" class="w-full h-full object-cover opacity-60" />
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-4xl text-white drop-shadow-lg">360</span>
                                </div>
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-5xl text-primary/20">apartment</span>
                                </div>
                            }
                            <div class="absolute top-2 right-2">
                                <span class="@GetStatusBadgeCss(room.Status) text-white text-[10px] font-black uppercase px-2 py-0.5 rounded shadow">@room.Status</span>
                            </div>
                            <div class="absolute bottom-2 left-2 bg-background-dark/80 backdrop-blur-sm rounded-lg px-2 py-1 text-[10px] text-emerald-400 font-bold flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">verified</span>
                                Auto-approved
                            </div>
                        </div>
                        <div class="p-4 flex-1 flex flex-col">
                            <h3 class="font-bold text-base leading-snug group-hover:text-primary transition-colors mb-1 line-clamp-2">@room.Title</h3>
                            <div class="text-primary font-black text-base mb-3">@room.Price.ToString("N0")<span class="text-[10px] text-slate-500 font-normal"> VND/mo</span></div>
                            <div class="text-xs text-slate-500 mb-3 flex items-center gap-1.5 mt-auto">
                                <span class="material-symbols-outlined text-sm">location_on</span>
                                <span class="line-clamp-1">@room.Address</span>
                            </div>
                            <div class="flex gap-2">
                                @if (IsRoomVisible(room.Status))
                                {
                                    <button class="flex-1 py-2 rounded-lg text-xs font-bold bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 transition-all"
                                            @onclick='() => ConfirmAction(room, "hide")'>
                                        Hide Listing
                                    </button>
                                }
                                else
                                {
                                    <button class="flex-1 py-2 rounded-lg text-xs font-bold bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 border border-emerald-500/20 transition-all"
                                            @onclick='() => ConfirmAction(room, "active")'>
                                        Restore
                                    </button>
                                }
                                <button class="w-9 flex items-center justify-center bg-background-dark/30 border border-neutral-border hover:bg-red-500 hover:border-red-500 rounded-lg transition-all group"
                                        @onclick='() => ConfirmAction(room, "delete")' title="Delete">
                                    <span class="material-symbols-outlined text-sm text-slate-400 group-hover:text-white">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="mt-8 flex items-center justify-center gap-2 border-t border-primary/10 pt-6">
                    <button class="p-2 rounded-lg border border-neutral-border text-slate-400 disabled:opacity-40"
                            disabled="@(currentPage == 1)" @onclick="PrevPage">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </button>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pg = i;
                        <button class="w-8 h-8 rounded-lg text-sm font-bold transition-all @(pg == currentPage ? "bg-primary text-background-dark" : "text-slate-400 hover:bg-accent-dark/20")"
                                @onclick="() => GoToPage(pg)">@pg</button>
                    }
                    <button class="p-2 rounded-lg border border-neutral-border text-slate-400 disabled:opacity-40"
                            disabled="@(currentPage >= totalPages)" @onclick="NextPage">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </button>
                </div>
            }
        }
    }
</div>

<!-- ================== CONFIRM MODAL ================== -->
@if (showConfirm)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-surface-dark border border-neutral-border rounded-3xl w-full max-w-sm shadow-2xl p-6 text-center" @onclick:stopPropagation>
            @if (confirmAction == "delete")
            {
                <span class="material-symbols-outlined text-5xl text-red-500 mb-3 block">delete_forever</span>
                <h3 class="text-lg font-bold mb-1">Delete Listing?</h3>
                <p class="text-sm text-slate-400 mb-6">Permanently delete "<b>@selectedRoom?.Title</b>"? This will also remove all contracts and invoices.</p>
                <div class="flex gap-3">
                    <button class="flex-1 py-3 rounded-xl border border-neutral-border text-slate-300 font-medium text-sm" @onclick="CloseModals">Cancel</button>
                    <button class="flex-1 py-3 rounded-xl bg-red-600 hover:bg-red-700 text-white font-bold text-sm" @onclick="ExecuteRoomAction">Delete</button>
                </div>
            }
            else if (confirmAction == "hide")
            {
                <span class="material-symbols-outlined text-5xl text-amber-400 mb-3 block">visibility_off</span>
                <h3 class="text-lg font-bold mb-1">Hide Listing?</h3>
                <p class="text-sm text-slate-400 mb-6">This will hide "<b>@selectedRoom?.Title</b>" from tenants.</p>
                <div class="flex gap-3">
                    <button class="flex-1 py-3 rounded-xl border border-neutral-border text-slate-300 font-medium text-sm" @onclick="CloseModals">Cancel</button>
                    <button class="flex-1 py-3 rounded-xl bg-amber-500 hover:bg-amber-600 text-background-dark font-bold text-sm" @onclick="ExecuteRoomAction">Hide</button>
                </div>
            }
            else
            {
                <span class="material-symbols-outlined text-5xl text-emerald-400 mb-3 block">visibility</span>
                <h3 class="text-lg font-bold mb-1">Restore Listing?</h3>
                <p class="text-sm text-slate-400 mb-6">Make "<b>@selectedRoom?.Title</b>" visible to tenants again.</p>
                <div class="flex gap-3">
                    <button class="flex-1 py-3 rounded-xl border border-neutral-border text-slate-300 font-medium text-sm" @onclick="CloseModals">Cancel</button>
                    <button class="flex-1 py-3 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-sm" @onclick="ExecuteRoomAction">Restore</button>
                </div>
            }
        </div>
    </div>
}

@code {
    // ─── State ────────────────────────────────────────────────────────────────
    private List<LandlordSummary> landlords        = new();
    private List<Room>            rooms            = new();
    private LandlordSummary?      selectedLandlord;

    private bool    isLoading = true;
    private string? loadError;
    private string? globalError;

    private string searchText       = "";
    private string roomStatusFilter = "all";

    private int currentPage = 1;
    private int pageSize    = 12;
    private int totalCount;
    private int totalPages  => (int)Math.Ceiling((double)totalCount / pageSize);

    private bool    showConfirm;
    private string  confirmAction = "";
    private Room?   selectedRoom;

    // ─── Computed properties ──────────────────────────────────────────────────
    private List<LandlordSummary> SpamLandlords => landlords.Where(l => l.IsSpamFlagged).ToList();

    private static string GetStatusBadgeCss(string status) => status switch
    {
        "Active" or "Available" => "bg-emerald-500",
        "Rented"                => "bg-blue-500",
        "Pending"               => "bg-amber-500",
        _                       => "bg-red-500"
    };

    private static bool IsRoomVisible(string status) =>
        status is "Active" or "Available" or "Rented";

    // ─── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadLandlordsAsync();

    // ─── Landlord Logic ───────────────────────────────────────────────────────
    private async Task LoadLandlordsAsync()
    {
        isLoading = true; loadError = null;
        try   { landlords = await ListingService.GetLandlordsAsync(searchText); }
        catch (Exception ex) { loadError = ex.Message; landlords = new(); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task SelectLandlord(LandlordSummary landlord)
    {
        selectedLandlord = landlord;
        searchText = "";
        roomStatusFilter = "all";
        currentPage = 1;
        await LoadRoomsAsync();
    }

    private async Task BackToLandlords()
    {
        selectedLandlord = null;
        rooms = new();
        searchText = "";
        await LoadLandlordsAsync();
    }

    private async Task ToggleLandlordBlock(LandlordSummary landlord, bool block)
    {
        globalError = null;
        try
        {
            await ListingService.BlockLandlordAsync(landlord.UserId, block);
            if (selectedLandlord == null) await LoadLandlordsAsync();
            else
            {
                selectedLandlord.IsActive = !block;
                StateHasChanged();
            }
        }
        catch (Exception ex) { globalError = ex.Message; StateHasChanged(); }
    }

    // ─── Room Logic ───────────────────────────────────────────────────────────
    private async Task LoadRoomsAsync()
    {
        isLoading = true;
        try
        {
            var (r, t) = await ListingService.GetRoomsByLandlordAsync(
                selectedLandlord!.UserId, roomStatusFilter, currentPage, pageSize);
            rooms = r; totalCount = t;
        }
        catch (Exception ex) { globalError = ex.Message; rooms = new(); totalCount = 0; }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task ChangeRoomFilter(string key)
    {
        roomStatusFilter = key;
        currentPage = 1;
        await LoadRoomsAsync();
    }

    private async Task PrevPage() { currentPage--; await LoadRoomsAsync(); }
    private async Task NextPage() { currentPage++; await LoadRoomsAsync(); }
    private async Task GoToPage(int p) { currentPage = p; await LoadRoomsAsync(); }

    // ─── Debounced Search ─────────────────────────────────────────────────────
    private System.Timers.Timer? _timer;
    private void OnSearchChanged(ChangeEventArgs _)
    {
        _timer?.Stop();
        _timer = new System.Timers.Timer(380);
        _timer.Elapsed += async (_, _) =>
        {
            _timer?.Stop();
            await InvokeAsync(async () =>
            {
                currentPage = 1;
                if (selectedLandlord == null) await LoadLandlordsAsync();
                else await LoadRoomsAsync();
            });
        };
        _timer.Start();
    }

    // ─── Modals ───────────────────────────────────────────────────────────────
    private void ConfirmAction(Room room, string action)
    {
        selectedRoom = room;
        confirmAction = action;
        showConfirm = true;
    }

    private void CloseModals() { showConfirm = false; selectedRoom = null; }

    private async Task ExecuteRoomAction()
    {
        if (selectedRoom == null) return;
        globalError = null;
        try
        {
            if (confirmAction == "delete")
                await ListingService.DeleteListingAsync(selectedRoom.RoomId);
            else
                await ListingService.UpdateListingStatusAsync(selectedRoom.RoomId, confirmAction);
            await LoadRoomsAsync();
        }
        catch (Exception ex) { globalError = $"Action failed: {ex.Message}"; }
        finally { CloseModals(); StateHasChanged(); }
    }
}
