@page "/roommate-match"
@layout MainLayout

<PageTitle>Staytrust Admin - Roommate Match Management</PageTitle>

<!-- Top Nav Bar -->
<header class="flex items-center justify-between border-b border-neutral-border bg-neutral-dark px-6 py-3 shrink-0">
    <div class="flex items-center gap-8">
        <div class="flex items-center gap-4 text-primary">
            <div class="size-8 flex items-center justify-center bg-primary/20 rounded-lg">
                <span class="material-symbols-outlined">diamond</span>
            </div>
            <h2 class="text-slate-100 text-lg font-bold leading-tight tracking-tight">Staytrust Admin</h2>
        </div>
        <div class="flex h-10 min-w-64">
            <div class="flex w-full flex-1 items-stretch rounded-lg bg-surface-dark border border-neutral-border overflow-hidden">
                <div class="text-primary/60 flex items-center justify-center pl-4">
                    <span class="material-symbols-outlined">search</span>
                </div>
                <input class="w-full border-none bg-transparent focus:ring-0 text-slate-100 placeholder:text-primary/40 text-sm px-3 outline-none" placeholder="Search requests or users..." />
            </div>
        </div>
    </div>
    <div class="flex items-center gap-4">
        <button class="flex items-center justify-center rounded-lg size-10 bg-surface-dark text-slate-100 hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined">notifications</span>
        </button>
        <button class="flex items-center justify-center rounded-lg size-10 bg-surface-dark text-slate-100 hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined">settings</span>
        </button>
        <div class="bg-primary/20 rounded-full size-10 flex items-center justify-center border border-primary/40">
            <span class="material-symbols-outlined text-primary">person</span>
        </div>
    </div>
</header>

<div class="flex-1 overflow-y-auto custom-scrollbar">
    <main class="flex-1 flex flex-col p-6 gap-8 max-w-7xl mx-auto w-full">
        <!-- Header Section -->
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div class="flex flex-col gap-2">
                <h1 class="text-slate-100 text-3xl font-black tracking-tight">Roommate Match Management</h1>
                <p class="text-primary/70 text-base max-w-xl leading-relaxed">Oversee all active search requests and manage AI matching performance across the platform.</p>
            </div>
            <button class="bg-primary hover:bg-primary/90 text-background-dark font-bold py-2.5 px-6 rounded-lg transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">add</span>
                New Request
            </button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            @foreach (var stat in stats)
            {
                <div class="bg-surface-dark p-6 rounded-xl border border-neutral-border flex flex-col gap-2">
                    <div class="flex justify-between items-start">
                        <p class="text-slate-400 text-sm font-medium">@stat.Label</p>
                        <span class="@stat.IconCss material-symbols-outlined">@stat.Icon</span>
                    </div>
                    <p class="text-slate-100 text-3xl font-bold">@stat.Value</p>
                    <div class="flex items-center gap-1.5 mt-2">
                        <span class="@stat.BadgeCss text-xs font-bold px-1.5 py-0.5 rounded">@stat.Change</span>
                        <span class="text-slate-500 text-[10px] uppercase font-bold tracking-wider">@stat.SubLabel</span>
                    </div>
                </div>
            }
        </div>

        <!-- Dashboard Grid -->
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <!-- AI Success Chart -->
            <div class="xl:col-span-1 bg-surface-dark rounded-xl border border-neutral-border p-6 flex flex-col">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">AI Match Success Rate</p>
                        <h3 class="text-slate-100 text-4xl font-black">94%</h3>
                    </div>
                    <div class="flex flex-col items-end">
                        <span class="text-primary text-sm font-bold">+3.5%</span>
                        <span class="text-slate-500 text-xs">Past 30 Days</span>
                    </div>
                </div>
                <div class="flex-1 min-h-[220px] flex flex-col">
                    <div class="flex-1 relative">
                        <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 400 150">
                            <path d="M0 120 Q50 80, 100 100 T200 60 T300 40 T400 20" fill="none" stroke="#00d1b2" stroke-linecap="round" stroke-width="4"></path>
                            <path d="M0 120 Q50 80, 100 100 T200 60 T300 40 T400 20 V150 H0 Z" fill="url(#successGradient)" fill-opacity="0.2"></path>
                            <defs>
                                <linearGradient id="successGradient" x1="0%" x2="0%" y1="0%" y2="100%">
                                    <stop offset="0%" stop-color="#00d1b2"></stop>
                                    <stop offset="100%" stop-color="transparent"></stop>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <div class="flex justify-between mt-4">
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Week 1</span>
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Week 2</span>
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Week 3</span>
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Week 4</span>
                    </div>
                </div>
                <div class="mt-6 pt-6 border-t border-neutral-border/50">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary">auto_awesome</span>
                        <p class="text-xs text-slate-400">AI model "Harmony-V2" currently processing 45 matches/min.</p>
                    </div>
                </div>
            </div>

            <!-- Match Requests Table -->
            <div class="xl:col-span-2 bg-surface-dark rounded-xl border border-neutral-border overflow-hidden flex flex-col">
                <div class="p-6 border-b border-neutral-border/50 flex justify-between items-center">
                    <h3 class="text-slate-100 font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">person_search</span>
                        Recent Match Requests
                    </h3>
                    <div class="flex gap-2">
                        <button class="text-xs font-bold text-slate-400 bg-background-dark px-3 py-1.5 rounded border border-neutral-border hover:text-primary transition-colors">All Requests</button>
                        <button class="text-xs font-bold text-slate-400 bg-background-dark px-3 py-1.5 rounded border border-neutral-border hover:text-rose-400 transition-colors">High Risk</button>
                    </div>
                </div>
                <div class="flex-1 overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-background-dark/30 text-[10px] font-black uppercase text-slate-500 tracking-widest border-b border-neutral-border/30">
                                <th class="px-6 py-4">User</th>
                                <th class="px-6 py-4">Preferences</th>
                                <th class="px-6 py-4">Comp. Score</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-neutral-border/30">
                            @foreach (var req in matchRequests)
                            {
                                <tr class="hover:bg-primary/5 transition-colors group">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="size-9 rounded-full @req.AvatarCss flex items-center justify-center border border-neutral-border">
                                                <span class="material-symbols-outlined text-sm @req.AvatarIconCss">@req.AvatarIcon</span>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold @req.NameCss leading-none mb-1">@req.Name</p>
                                                <p class="text-[11px] text-slate-500">@req.Location</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var pref in req.Preferences)
                                            {
                                                <span class="text-[10px] px-2 py-0.5 rounded-full bg-surface-dark border border-neutral-border text-slate-400">@pref</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <div class="w-12 bg-background-dark rounded-full h-1.5 overflow-hidden">
                                                <div class="@req.ScoreBarCss h-full" style="@($"width:{req.Score}%")"></div>
                                            </div>
                                            <span class="text-xs font-bold @req.ScoreTextCss">@req.Score%</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @req.StatusCss uppercase">@req.Status</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2 @(req.Status == "Flagged" ? "opacity-100" : "opacity-0 group-hover:opacity-100") transition-opacity">
                                            @if (req.Status == "Flagged")
                                            {
                                                <button class="px-3 py-1.5 bg-rose-500 text-white text-[10px] font-bold rounded hover:bg-rose-600 transition-colors uppercase">Review</button>
                                            }
                                            else
                                            {
                                                <button class="p-1.5 hover:bg-rose-500/10 text-slate-500 hover:text-rose-400 rounded-lg transition-colors">
                                                    <span class="material-symbols-outlined text-[18px]">flag</span>
                                                </button>
                                            }
                                            <button class="p-1.5 hover:bg-primary/10 text-slate-500 hover:text-primary rounded-lg transition-colors">
                                                <span class="material-symbols-outlined text-[18px]">more_vert</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td class="px-6 py-4 text-center" colspan="5">
                                    <button class="text-xs font-bold text-primary hover:underline py-2">View 1,281 more active requests</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Bottom Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pb-8">
            <!-- Map Placeholder -->
            <div class="bg-surface-dark rounded-xl border border-neutral-border p-6 flex flex-col gap-4">
                <div class="flex justify-between items-center">
                    <h4 class="text-slate-100 font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">map</span>
                        Request Distribution
                    </h4>
                    <span class="text-[10px] font-bold text-slate-500 bg-background-dark border border-neutral-border px-2 py-1 rounded">Global</span>
                </div>
                <div class="flex-1 min-h-[250px] bg-background-dark rounded-lg flex items-center justify-center border border-neutral-border/30 relative overflow-hidden">
                    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, #2e6b62 1px, transparent 0); background-size: 24px 24px;"></div>
                    <div class="z-10 flex flex-col items-center gap-2">
                        <span class="material-symbols-outlined text-5xl text-primary/40">explore</span>
                        <p class="text-slate-500 text-sm italic">Map Data Visualization for Roommate Demand</p>
                        <div class="flex gap-4 mt-4">
                            <div class="flex flex-col items-center"><span class="text-lg font-bold text-slate-100">412</span><span class="text-[10px] text-slate-500 uppercase">Europe</span></div>
                            <div class="w-px h-8 bg-neutral-border/50"></div>
                            <div class="flex flex-col items-center"><span class="text-lg font-bold text-slate-100">308</span><span class="text-[10px] text-slate-500 uppercase">N. America</span></div>
                            <div class="w-px h-8 bg-neutral-border/50"></div>
                            <div class="flex flex-col items-center"><span class="text-lg font-bold text-slate-100">564</span><span class="text-[10px] text-slate-500 uppercase">Other</span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Real-time Activity -->
            <div class="bg-surface-dark rounded-xl border border-neutral-border p-6 flex flex-col gap-4">
                <div class="flex justify-between items-center">
                    <h4 class="text-slate-100 font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">history</span>
                        Real-time Activity
                    </h4>
                    <button class="text-[10px] font-bold text-primary hover:underline">View All Logs</button>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="flex gap-4 p-3 rounded-lg bg-background-dark/50 border border-neutral-border/20">
                        <div class="size-8 rounded-full bg-primary/20 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-[18px] text-primary">link</span>
                        </div>
                        <div>
                            <p class="text-xs text-slate-300 font-medium"><span class="font-bold text-white">New Match:</span> Sarah Jenkins and Mia Wong found high compatibility (94%).</p>
                            <p class="text-[10px] text-slate-500 mt-1">2 minutes ago</p>
                        </div>
                    </div>
                    <div class="flex gap-4 p-3 rounded-lg bg-rose-500/5 border border-rose-500/20">
                        <div class="size-8 rounded-full bg-rose-500/20 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-[18px] text-rose-500">warning</span>
                        </div>
                        <div>
                            <p class="text-xs text-slate-300 font-medium"><span class="font-bold text-rose-400">Content Flagged:</span> Bio of user Elena S. reported for policy violation.</p>
                            <p class="text-[10px] text-slate-500 mt-1">15 minutes ago</p>
                        </div>
                    </div>
                    <div class="flex gap-4 p-3 rounded-lg bg-background-dark/50 border border-neutral-border/20">
                        <div class="size-8 rounded-full bg-blue-500/20 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-[18px] text-blue-400">verified_user</span>
                        </div>
                        <div>
                            <p class="text-xs text-slate-300 font-medium"><span class="font-bold text-white">Account Verified:</span> Marcus Thorne completed ID verification check.</p>
                            <p class="text-[10px] text-slate-500 mt-1">1 hour ago</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

@code {
    private record Stat(string Label, string Value, string Change, string SubLabel, string Icon, string IconCss, string BadgeCss);
    private record MatchRequest(string Name, string Location, List<string> Preferences, int Score, string Status,
        string AvatarCss, string AvatarIcon, string AvatarIconCss, string NameCss,
        string ScoreBarCss, string ScoreTextCss, string StatusCss);

    private List<Stat> stats = new()
    {
        new("Active Requests","1,284","+12%","Since last month","trending_up","text-primary","text-primary bg-primary/10"),
        new("Total Matches","856","+5%","Weekly target met","handshake","text-primary","text-primary bg-primary/10"),
        new("Avg. Compatibility","82%","-2%","Algorithm refresh pending","analytics","text-rose-400","text-rose-400 bg-rose-400/10"),
        new("Flagged Profiles","14","+1%","Pending review","report","text-primary","text-primary bg-primary/10"),
    };

    private List<MatchRequest> matchRequests = new()
    {
        new("Sarah Jenkins","London, UK • Student",new(){"Non-Smoker","Quiet"},92,"Active",
            "bg-slate-700","person","text-slate-400","text-slate-200","bg-primary","text-primary","bg-primary/20 text-primary border border-primary/20"),
        new("Marcus Thorne","Berlin, DE • Developer",new(){"Pet Friendly","Late Owl"},78,"Pending",
            "bg-slate-700","person","text-slate-400","text-slate-200","bg-primary","text-primary","bg-amber-500/20 text-amber-500 border border-amber-500/20"),
        new("Elena Sokolov","Madrid, ES • Designer",new(){"Artistic"},45,"Flagged",
            "bg-rose-500/10","report","text-rose-500","text-rose-400","bg-rose-500","text-rose-400","bg-rose-500/20 text-rose-500 border border-rose-500/20"),
    };
}
