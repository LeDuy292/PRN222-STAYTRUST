<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <div class="min-h-screen flex flex-col items-center justify-center text-white" style="background-color:#0a0a0a">
                        <h1 class="text-6xl font-black text-red-500 mb-4">403</h1>
                        <h2 class="text-2xl font-bold mb-8 text-gray-400">Access Denied</h2>
                        <p class="text-gray-500 mb-12">You don't have permission to access this page.</p>
                        <a href="/" class="px-8 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl font-semibold hover:scale-105 transition-all">
                            Return Home
                        </a>
                    </div>
                </NotAuthorized>
                <Authorizing>
                    <div class="min-h-screen flex items-center justify-center text-white" style="background-color:#0a0a0a">
                        <div class="animate-pulse flex flex-col items-center">
                            <div class="w-16 h-16 border-4 border-cyan-500/20 border-t-cyan-500 rounded-full animate-spin mb-4"></div>
                            <span>Verifying Access...</span>
                        </div>
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
               <div class="min-h-screen flex flex-col items-center justify-center text-white" style="background-color:#0a0a0a">
                    <h1 class="text-6xl font-black text-cyan-500 mb-4">404</h1>
                    <h2 class="text-2xl font-bold mb-8 text-gray-400">Page Not Found</h2>
                    <a href="/" class="px-8 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl font-semibold hover:scale-105 transition-all">
                        Return Home
                    </a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
