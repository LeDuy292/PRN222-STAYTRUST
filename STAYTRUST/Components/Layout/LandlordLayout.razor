@inherits LayoutComponentBase

<head>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        window.tailwind = window.tailwind || {};
        window.tailwind.config = {
            important: ".dark",
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13ec92",
                        "background-light": "#f6f8f7",
                        "background-dark": "#10221a",
                        "surface-dark": "#162b21",
                        "navy-muted": "#1a352b",
                        "emerald-deep": "#0d1a14",
                        "navy-deep": "#0a1611",
                        "border-dark": "#326751",
                        "forest-light": "#193328",
                        "forest-accent": "#234839",
                    },
                    fontFamily: {
                        "display": ["Inter"]
                    },
                    borderRadius: {"DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px"},
                },
            },
        }
    </script>
    <style>
        .dark h1, .dark h2, .dark h3, .dark h4, .dark p, .dark span, .dark div { font-family: 'Inter', sans-serif !important; }
        .dark .material-symbols-outlined { font-family: 'Material Symbols Outlined' !important; }
        .dark a { text-decoration: none !important; }
        .fill-1 { font-variation-settings: 'FILL' 1; }
        .active-nav { background-color: rgba(19, 236, 146, 0.1); border-left: 4px solid #13ec92; }
        .glass-card {
            background: rgba(35, 72, 57, 0.2);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(19, 236, 146, 0.1);
        }
    </style>
</head>

<div class="dark">
<div class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased h-screen overflow-hidden">
<div class="flex h-full w-full">
<!-- Sidebar Navigation -->
<STAYTRUST.Components.Layout.LandlordSidebar />
<!-- Main Content Area -->
<main class="flex-1 flex flex-col overflow-hidden relative w-full h-full">
@Body
</main>
</div>
</div>
</div>
