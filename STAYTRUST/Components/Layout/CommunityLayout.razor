@inherits LayoutComponentBase

<head>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        window.tailwind = window.tailwind || {};
        window.tailwind.config = {
            important: ".community-root",
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#00d1b2",
                        "background-light": "#f5f8f8",
                        "forum-dark": "#0a2540",
                        "profile-dark": "#0f2320",
                        "glass": "rgba(255, 255, 255, 0.03)",
                        "glass-border": "rgba(255, 255, 255, 0.1)",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            overflow-x: hidden !important;
            width: 100% !important;
            background-color: #0a2540;
        }
        body {
            font-family: 'Manrope', sans-serif;
        }
        .dark .material-symbols-outlined { font-family: 'Material Symbols Outlined' !important; }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .custom-scrollbar::-webkit-scrollbar {
            height: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #00d1b2;
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .fill-1 { font-variation-settings: 'FILL' 1; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        @@keyframes spin-slow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .animate-spin-slow {
            animation: spin-slow 3s linear infinite;
        }
    </style>
</head>

<div class="community-root dark min-h-screen w-full overflow-x-hidden text-slate-100">
    <!-- Top Navigation -->
    <header class="sticky top-0 z-50 glass-card border-b-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center gap-8">
                    <div class="flex items-center gap-2 text-primary">
                        <span class="material-symbols-outlined text-3xl font-bold">verified_user</span>
                        <h1 class="text-xl font-[800] tracking-tight text-slate-100 uppercase">Staytrust</h1>
                    </div>
                    <nav class="hidden md:flex items-center gap-6">
                        <a class="text-sm font-semibold text-primary" href="/community">Community</a>
                        <a class="text-sm font-medium text-slate-400 hover:text-white transition-colors" href="#">Rentals</a>
                        <a class="text-sm font-medium text-slate-400 hover:text-white transition-colors" href="#">Trust Network</a>
                        <a class="text-sm font-medium text-slate-400 hover:text-white transition-colors" href="#">Support</a>
                    </nav>
                </div>
                <div class="flex items-center gap-4">
                    <div class="relative hidden sm:block">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                        <input class="bg-white/5 border border-white/10 rounded-full pl-10 pr-4 py-1.5 text-sm w-64 focus:ring-1 focus:ring-primary text-slate-100 placeholder:text-slate-500" placeholder="Search community..." type="text"/>
                    </div>
                    <button class="material-symbols-outlined text-slate-400 hover:text-white">notifications</button>
                    <a href="/user-profile" class="h-8 w-8 rounded-full bg-primary/20 border border-primary/40 overflow-hidden">
                        <img class="w-full h-full object-cover" data-alt="User profile avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAZ8nhY-KIqDog-vxNUyni_OLZG9yRMDUi8KbL7NM6nM9rqTPh4LhLjkbkjzhnvrD7S61qFxZdZT1BdIflaAOSFt0ZZMfQvAVN1B10vcGuK2o3CKHGJ9b5JTZRln3ur-84vGq-PZMLKCM0fTVuiBPljAxcMQqQVuFYLZwTYg9QEe0Y3iS6RxEcyx2IyCA0F5QebR8ZmkEJ4sdbcHDMWIIIHYTEkn8I0ox-_pnrccLCi5ghca1fGVbtxYiKLUbdC15PZ9vpERtcDK4Y"/>
                    </a>
                </div>
            </div>
        </div>
    </header>

    @Body
</div>
