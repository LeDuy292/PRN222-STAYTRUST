@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS

<style>
    .chatbox-container {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .chatbox-button {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #2563eb);
        border: 3px solid white;
        color: white;
        font-size: 28px;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.5), 0 8px 24px rgba(0, 0, 0, 0.2);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        position: relative;
        z-index: 9999;
    }

    .chatbox-button:hover {
        transform: scale(1.15);
        box-shadow: 0 6px 20px rgba(6, 182, 212, 0.7), 0 12px 32px rgba(0, 0, 0, 0.3);
    }

    .chatbox-button:active {
        transform: scale(0.95);
    }

    .chatbox-button.active {
        transform: rotate(45deg) scale(1.15);
    }

    .chatbox-window {
        position: absolute;
        bottom: 90px;
        right: 0;
        width: 420px;
        height: 650px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 5px 40px rgba(0, 0, 0, 0.16), 0 0 0 1px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        z-index: 9998;
    }

    .chatbox-header {
        background: linear-gradient(135deg, #06b6d4 0%, #2563eb 100%);
        color: white;
        padding: 20px;
        border-bottom: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .chatbox-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.5px;
    }

    .chatbox-close {
        background: none;
        border: none;
        color: white;
        font-size: 28px;
        cursor: pointer;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
    }

    .chatbox-close:hover {
        transform: rotate(90deg);
    }

    .chatbox-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background: #f9fafb;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .chatbox-messages::-webkit-scrollbar {
        width: 6px;
    }

    .chatbox-messages::-webkit-scrollbar-track {
        background: transparent;
    }

    .chatbox-messages::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 3px;
    }

    .chatbox-messages::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }

    .message {
        display: flex;
        margin-bottom: 8px;
        animation: messageSlide 0.3s ease;
    }

    @@keyframes messageSlide {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .message.user {
        justify-content: flex-end;
    }

    .message-content {
        max-width: 75%;
        padding: 12px 16px;
        border-radius: 12px;
        word-wrap: break-word;
        font-size: 14px;
        line-height: 1.5;
    }

    .message.user .message-content {
        background: linear-gradient(135deg, #06b6d4, #2563eb);
        color: white;
        border-bottom-right-radius: 4px;
        box-shadow: 0 2px 8px rgba(6, 182, 212, 0.2);
    }

    .message.bot .message-content {
        background: #e5e7eb;
        color: #1f2937;
        border-bottom-left-radius: 4px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 12px 16px;
        background: #e5e7eb;
        border-radius: 12px;
        width: fit-content;
    }

    .typing-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #9ca3af;
        animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% { 
            transform: translateY(0);
            opacity: 1;
        }
        30% { 
            transform: translateY(-10px);
            opacity: 0.7;
        }
    }

    .chatbox-input-area {
        padding: 16px;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: 8px;
        background: white;
        flex-shrink: 0;
    }

    .chatbox-input {
        flex: 1;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 14px;
        font-family: inherit;
        transition: all 0.2s ease;
    }

    .chatbox-input:focus {
        outline: none;
        border-color: #06b6d4;
        box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.1);
    }

    .chatbox-input::placeholder {
        color: #9ca3af;
    }

    .chatbox-send-btn {
        background: linear-gradient(135deg, #06b6d4, #2563eb);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 16px;
        cursor: pointer;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
    }

    .chatbox-send-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.4);
    }

    .chatbox-send-btn:active:not(:disabled) {
        transform: translateY(0);
    }

    .chatbox-send-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #9ca3af;
        padding: 20px;
        text-align: center;
    }

    .empty-state-icon {
        font-size: 56px;
        margin-bottom: 16px;
    }

    .empty-state p {
        margin: 4px 0;
        font-size: 14px;
    }

    .empty-state p:first-of-type {
        color: #1f2937;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .chatbox-window {
            width: 100vw;
            height: 100vh;
            bottom: 0;
            right: 0;
            border-radius: 0;
            max-height: 100vh;
        }

        .message-content {
            max-width: 85%;
        }
    }
</style>

<div class="chatbox-container">
    <!-- Chatbox Button -->
    <button class="chatbox-button @(isOpen ? "active" : "")" 
            @onclick="ToggleChatbox"
            title="M? tr? lý STAYTRUST">
        @if (isOpen)
        {
            <span>?</span>
        }
        else
        {
            <span>??</span>
        }
    </button>

    <!-- Chatbox Window -->
    @if (isOpen)
    {
        <div class="chatbox-window">
            <!-- Header -->
            <div class="chatbox-header">
                <div>
                    <h3>?? Tr? lý STAYTRUST</h3>
                </div>
                <button class="chatbox-close" @onclick="ToggleChatbox" title="?óng">?</button>
            </div>

            <!-- Messages -->
            <div class="chatbox-messages" @ref="messagesContainer">
                @if (messages.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">??</div>
                        <p>Xin chŕo! Tôi lŕ tr? lý STAYTRUST.</p>
                        <p>H?i tôi b?t c? ?i?u gě v? b?t ??ng s?n!</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in messages)
                    {
                        <div class="message @(msg.IsUser ? "user" : "bot")">
                            <div class="message-content">
                                @msg.Content
                            </div>
                        </div>
                    }

                    @if (isLoading)
                    {
                        <div class="typing-indicator">
                            <div class="typing-dot"></div>
                            <div class="typing-dot"></div>
                            <div class="typing-dot"></div>
                        </div>
                    }
                }
            </div>

            <!-- Input Area -->
            <div class="chatbox-input-area">
                <input type="text" 
                       class="chatbox-input" 
                       placeholder="Nh?p câu h?i..." 
                       @bind="userInput"
                       @keydown="HandleKeyDown"
                       disabled="@isLoading" />
                <button class="chatbox-send-btn" 
                        @onclick="SendMessage"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(userInput))"
                        title="G?i">
                    @if (isLoading)
                    {
                        <span>?</span>
                    }
                    else
                    {
                        <span>?</span>
                    }
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool isOpen = false;
    private string userInput = "";
    private bool isLoading = false;
    private List<ChatMessage> messages = new();
    private ElementReference messagesContainer;

    private class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
    }

    private void ToggleChatbox()
    {
        isOpen = !isOpen;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isLoading && !string.IsNullOrWhiteSpace(userInput))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading)
            return;

        // Add user message
        messages.Add(new ChatMessage { Content = userInput, IsUser = true });
        var question = userInput;
        userInput = "";

        isLoading = true;
        await ScrollToBottom();

        try
        {
            var request = new { message = question };
            var response = await Http.PostAsJsonAsync("api/chatbot/message", request);

            if (response.IsSuccessStatusCode)
            {
                var jsonContent = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(jsonContent);
                var root = doc.RootElement;

                if (root.TryGetProperty("response", out var responseElement))
                {
                    var botResponse = responseElement.GetString() ?? "Xin l?i, tôi không th? tr? l?i câu h?i nŕy.";
                    messages.Add(new ChatMessage { Content = botResponse, IsUser = false });
                }
            }
            else
            {
                messages.Add(new ChatMessage 
                { 
                    Content = "Xin l?i, ?ă x?y ra l?i. Vui lňng th? l?i sau.", 
                    IsUser = false 
                });
            }
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage 
            { 
                Content = $"L?i: {ex.Message}", 
                IsUser = false 
            });
        }
        finally
        {
            isLoading = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
    }
}
