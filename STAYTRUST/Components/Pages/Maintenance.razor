@page "/maintenance"
@layout STAYTRUST.Components.Layout.PropertyLayout
@rendermode InteractiveServer

<HeadContent>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="/css/roommates.css" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13ec92",
                        "background-light": "#f6f8f7",
                        "background-dark": "#182e25",
                        "card-dark": "#213c31",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .filled-icon {
            font-variation-settings: 'FILL' 1;
        }
    </style>
</HeadContent>

            <!-- Main Content Area -->
            <div class="flex-1 bg-gradient-to-br from-background-dark via-[#0d1a15] to-background-dark rounded-2xl border border-primary/10 overflow-hidden shadow-xl">
                <!-- Top Header -->
                <header class="sticky top-0 z-30 flex items-center justify-between px-8 py-4 glass-panel border-b border-primary/10 backdrop-blur-md">
                    <div class="flex items-center gap-4">
                        <h1 class="text-xl font-bold text-white">Maintenance Hub</h1>
                        <span class="px-3 py-1 text-xs font-bold rounded-full bg-primary/20 text-primary border border-primary/30 uppercase tracking-wider">Active Status</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <button class="p-2 rounded-full hover:bg-primary/10 text-slate-400 transition-colors relative">
                            <span class="material-symbols-outlined">notifications</span>
                            <span class="absolute top-2 right-2 size-2 bg-primary rounded-full ring-2 ring-background-dark"></span>
                        </button>
                        <button @onclick="StartNewReport" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-primary text-background-dark font-bold text-sm glow-button transition-transform hover:-translate-y-0.5 shadow-lg shadow-primary/20">
                            <span class="material-symbols-outlined text-sm">add</span>
                            New Report
                        </button>
                    </div>
                </header>
                
                <div class="max-w-6xl mx-auto p-8 space-y-8">
                    <!-- Stats Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="p-6 rounded-2xl bg-card-dark border border-primary/10 shadow-md hover:shadow-lg hover:shadow-primary/5 relative overflow-hidden group hover:border-primary/20 transition-all cursor-pointer hover:-translate-y-1">
                            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                <span class="material-symbols-outlined text-6xl text-primary">pending_actions</span>
                            </div>
                            <p class="text-slate-400 text-sm font-medium">Pending Repairs</p>
                            <p class="text-3xl font-bold text-white mt-2">@pendingRepairs.ToString("D2")</p>
                            <div class="mt-4 flex items-center gap-2 text-xs text-primary">
                                <span class="material-symbols-outlined text-xs">trending_up</span>
                                <span>Average response: 14 mins</span>
                            </div>
                        </div>
                        <div class="p-6 rounded-2xl bg-card-dark border border-primary/10 shadow-md hover:shadow-lg hover:shadow-primary/5 relative overflow-hidden group hover:border-primary/20 transition-all cursor-pointer hover:-translate-y-1">
                            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                <span class="material-symbols-outlined text-6xl text-primary">check_circle</span>
                            </div>
                            <p class="text-slate-400 text-sm font-medium">Completed This Month</p>
                            <p class="text-3xl font-bold text-white mt-2">@completedRepairs</p>
                            <div class="mt-4 flex items-center gap-2 text-xs text-primary">
                                <span class="material-symbols-outlined text-xs">stars</span>
                                <span>98% Resident satisfaction</span>
                            </div>
                        </div>
                        <div class="p-6 rounded-2xl bg-card-dark border border-primary/10 shadow-md hover:shadow-lg hover:shadow-primary/5 relative overflow-hidden group hover:border-primary/20 transition-all cursor-pointer hover:-translate-y-1">
                            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                <span class="material-symbols-outlined text-6xl text-primary">bolt</span>
                            </div>
                            <p class="text-slate-400 text-sm font-medium">Emergency Credits</p>
                            <p class="text-3xl font-bold text-white mt-2">@emergencyCredits</p>
                            <div class="mt-4 flex items-center gap-2 text-xs text-primary">
                                <span class="material-symbols-outlined text-xs">info</span>
                                <span>Valid for priority scheduling</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
                        <!-- Left: AI Diagnostic & Report Form -->
                        <div class="xl:col-span-2 space-y-8">
                            <section class="p-8 rounded-3xl bg-card-dark shadow-lg border border-primary/10">
                                <div class="flex items-center gap-3 mb-6">
                                    <div class="size-10 rounded-xl bg-primary/20 flex items-center justify-center text-primary">
                                        <span class="material-symbols-outlined animate-pulse">smart_toy</span>
                                    </div>
                                    <div>
                                        <h3 class="text-lg font-bold text-white">AI Diagnostic Chat</h3>
                                        <p class="text-sm text-slate-400">Describe your issue for instant triage</p>
                                    </div>
                                </div>
                                <div class="space-y-4 mb-6 max-h-60 overflow-y-auto pr-2 custom-scrollbar flex flex-col justify-end">
                                    @foreach (var message in chatMessages)
                                    {
                                        if (message.IsAI)
                                        {
                                            <div class="flex gap-3">
                                                <div class="size-8 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
                                                    <span class="material-symbols-outlined text-sm text-primary">smart_toy</span>
                                                </div>
                                                <div class="p-4 rounded-2xl rounded-tl-none bg-background-dark border border-primary/5 text-sm text-slate-200 max-w-[80%] shadow-sm">
                                                    @((MarkupString)message.Text)
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex gap-3 justify-end">
                                                <div class="p-4 rounded-2xl rounded-tr-none bg-primary/90 text-background-dark font-medium text-sm max-w-[80%] shadow-md">
                                                    @message.Text
                                                </div>
                                                <div class="size-8 rounded-lg bg-primary border border-primary flex items-center justify-center shrink-0 text-background-dark cursor-pointer shadow-[0_0_10px_rgba(19,236,146,0.2)]">
                                                    <img class="w-full h-full object-cover rounded-lg" alt="User profile picture" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC4PFJyro12zt13_ruWP10fhm9y3pUBNFY8OQbmWJj_3PGcHRsy1X2yP0DK2InJnsvfwXI1CDT-h6dQumsstOraJseB6gh32nH-6OibJuzhkcjjci_uLrvzrIkAZWcRAWY007edLOmNfQ86-8e2uDjJ7nLuIf3d0xQkctnbUav988KNrziiiCjXT6LJCvM-umb6zeNo1gmbigiITLGzZr5dbYvJcUAsoYmIX22IVHg4MS6xL2gaz53ZPARlEZUrMcRrvGPVrk53UfIY"/>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                                
                                <form @onsubmit="SendMessage" class="flex gap-2 mb-6">
                                    <input type="text" @bind="chatInput" placeholder="Type your issue here..." class="flex-1 bg-background-dark border border-primary/10 rounded-xl text-white py-3 px-4 focus:ring-primary focus:border-primary placeholder-slate-500 shadow-inner" />
                                    <button type="submit" class="bg-primary text-background-dark font-bold px-6 py-3 rounded-xl glow-button hover:brightness-110 flex items-center gap-2 transition-transform">
                                        Send <span class="material-symbols-outlined text-sm">send</span>
                                    </button>
                                </form>

                                <div class="space-y-6">
                                    <!-- Photo Upload Area -->
                                    <label for="damage-photo" class="@(photoUploaded ? "border-primary bg-primary/10 shadow-[0_0_15px_rgba(19,236,146,0.15)]" : "border-primary/20 bg-background-dark") border-2 border-dashed rounded-2xl p-8 text-center hover:border-primary/40 transition-colors group cursor-pointer relative overflow-hidden block w-full max-w-full m-0">
                                        <InputFile id="damage-photo" OnChange="HandlePhotoUpload" class="hidden" accept="image/*" />
                                        @if(photoUploaded)
                                        {
                                            <div class="absolute inset-0 bg-cover bg-center opacity-40 mix-blend-overlay" style="background-image: url('https://images.unsplash.com/photo-1585704032915-c3400ca199e7?q=80&w=600&auto=format&fit=crop');"></div>
                                            <div class="relative z-10 flex flex-col items-center justify-center">
                                                <div class="size-16 mx-auto bg-primary rounded-full flex items-center justify-center mb-4 text-background-dark glow-button animate-bounce shadow-lg shadow-primary/40">
                                                    <span class="material-symbols-outlined text-3xl">check_circle</span>
                                                </div>
                                                <p class="text-white font-semibold">Photo Uploaded Successfully</p>
                                                <p class="text-xs text-primary mt-1 font-bold tracking-wide">AI Damage Verification Complete</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="relative z-10">
                                                <div class="size-16 mx-auto bg-card-dark border border-primary/10 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-md group-hover:shadow-primary/20 group-hover:border-primary/30">
                                                    <span class="material-symbols-outlined text-primary text-3xl">add_a_photo</span>
                                                </div>
                                                <p class="text-white font-semibold group-hover:text-primary transition-colors">Upload Photo</p>
                                                <p class="text-xs text-slate-400 mt-1">AI will verify damage level automatically</p>
                                            </div>
                                        }
                                    </label>
                                    
                                    <div class="flex gap-4">
                                        <div class="flex-1">
                                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Category</label>
                                            <select @bind="selectedCategory" class="w-full bg-background-dark border-primary/10 rounded-xl text-white py-3 focus:ring-primary focus:border-primary">
                                                <option value="Plumbing">Plumbing</option>
                                                <option value="Electrical">Electrical</option>
                                                <option value="HVAC">HVAC</option>
                                                <option value="Appliances">Appliances</option>
                                                <option value="General">General Maintenance</option>
                                            </select>
                                        </div>
                                        <div class="flex-1">
                                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Severity</label>
                                            <select @bind="selectedSeverity" class="w-full bg-background-dark border-primary/10 rounded-xl text-white py-3 focus:ring-primary focus:border-primary">
                                                <option value="Low">Low - Maintenance</option>
                                                <option value="Medium">Medium - Urgent</option>
                                                <option value="High">High - Emergency</option>
                                            </select>
                                        </div>
                                    </div>
                                    
                                    <button @onclick="SubmitReport" class="w-full py-4 bg-primary text-background-dark font-black rounded-xl glow-button uppercase tracking-widest hover:brightness-110 flex items-center justify-center gap-2 transition-transform hover:-translate-y-1">
                                        @if(isSubmitting)
                                        {
                                            <span class="material-symbols-outlined animate-spin shadow-none">progress_activity</span>
                                            <span>Processing...</span>
                                        }
                                        else
                                        {
                                            <span>Submit Verified Report</span>
                                        }
                                    </button>
                                </div>
                            </section>
                            
                            <!-- Recent History -->
                            <section class="space-y-4">
                                <div class="flex items-center justify-between px-2">
                                    <h3 class="text-lg font-bold text-white">Active Reports</h3>
                                    <button @onclick="ToggleViewAll" class="text-primary text-xs tracking-widest uppercase font-bold hover:underline transition-colors focus:outline-none">
                                        @(showAllReports ? "View Less" : "View All")
                                    </button>
                                </div>
                                
                                <div class="space-y-3">
                                    @foreach (var report in (showAllReports ? activeReports : activeReports.Take(2)))
                                    {
                                        <div class="p-5 rounded-2xl bg-card-dark border border-primary/10 shadow-md hover:shadow-lg hover:shadow-primary/5 flex flex-col md:flex-row items-start md:items-center justify-between group cursor-pointer hover:border-primary/30 transition-all gap-4">
                                            <div class="flex items-center gap-4">
                                                <div class="size-12 rounded-xl @report.ColorClass flex items-center justify-center text-white shrink-0 shadow-lg shadow-black/20 group-hover:scale-105 transition-transform">
                                                    <span class="material-symbols-outlined">@report.Icon</span>
                                                </div>
                                                <div>
                                                    <p class="text-white font-bold group-hover:text-primary transition-colors">@report.Title</p>
                                                    <p class="text-xs text-slate-400">Reported @report.TimeAgo • #@report.Id</p>
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-6 self-end md:self-auto w-full md:w-auto justify-between md:justify-end">
                                                <div class="text-left md:text-right">
                                                    <p class="text-xs font-bold @report.TextColorClass uppercase flex items-center gap-1.5 align-middle">
                                                        @if(report.Status == "In Progress") { <span class="size-2 rounded-full @report.BgColorClass animate-pulse shadow-[0_0_8px_currentColor]"></span> }
                                                        @report.Status
                                                    </p>
                                                    <p class="text-xs text-slate-400">@report.StatusDetail</p>
                                                </div>
                                                <span class="material-symbols-outlined text-slate-500 group-hover:text-primary transition-colors hidden md:block group-hover:translate-x-1">chevron_right</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>
                        </div>
                        
                        <!-- Right: Real-time Tracking Timeline -->
                        <div class="space-y-6">
                            <section class="p-6 rounded-3xl bg-card-dark shadow-lg border border-primary/10 sticky top-28">
                                <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">route</span>
                                    Repair Timeline
                                </h3>
                                
                                <div class="relative space-y-8 before:absolute before:inset-0 before:ml-5 before:-translate-x-px before:h-full before:w-0.5 before:bg-gradient-to-b before:from-primary before:via-primary/20 before:to-transparent">
                                    @foreach (var ev in timelineEvents)
                                    {
                                        <div class="relative flex items-center justify-between md:justify-start group cursor-default">
                                            <div class="flex items-center justify-center w-10 h-10 rounded-full @ev.IconContainerClass z-10 shrink-0 group-hover:scale-110 transition-transform shadow-md">
                                                <span class="material-symbols-outlined text-sm">@ev.Icon</span>
                                            </div>
                                            <div class="ml-6">
                                                <time class="text-[10px] font-bold @ev.TimeClass uppercase tracking-wide">@ev.Time</time>
                                                <p class="text-sm font-bold @ev.TitleClass group-hover:text-primary transition-colors">@ev.Title</p>
                                                <p class="text-xs text-slate-400">@ev.Detail</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                                
                                <div class="mt-10 p-4 rounded-2xl bg-background-dark border border-primary/10 shadow-inner">
                                    <div class="flex items-center justify-between mb-3">
                                        <p class="text-xs font-bold text-primary uppercase tracking-widest">Live Map Tracking</p>
                                        <span class="px-2 py-0.5 rounded text-[9px] font-bold bg-primary text-background-dark shadow-sm">ETA: 12 MINS</span>
                                    </div>
                                    <div class="aspect-video rounded-xl overflow-hidden bg-card-dark relative border border-primary/10 shadow-md">
                                        <div class="absolute inset-0 bg-cover bg-center grayscale opacity-50 mix-blend-screen" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuArPn9iqySYZPOFMktyHDBYaLRaMvZGsmVevh7q--KNdqbsaTI2IwuIVwQbKjo-s3VPlOCEenrjBUN5PeQvo3-pdufeS8kHeIwIqQTpDgjLRYH0LnOsiz_NbMO9jMmhFgQZxrw86-6_uRRD_SeO5f2_WGLyptBH_cVf6F_jQs-7r9zSpqloOU3rPStDtTHp3Gkoy1Kf_o-KQoGV6AFKB6Qku4REFRoJeYtN4UGDqIQspbk881X002QHubCBd6tLMtXn8o8nyg4qXFy0')"></div>
                                        
                                        <!-- User Location -->
                                        <div class="absolute top-1/2 left-1/3 flex flex-col items-center">
                                            <div class="size-4 rounded-full bg-white flex items-center justify-center text-background-dark shadow-[0_0_10px_rgba(255,255,255,0.5)]"></div>
                                            <div class="font-bold text-[8px] mt-1 bg-black/80 px-1.5 py-0.5 rounded text-white backdrop-blur-sm border border-white/10 uppercase tracking-wider">Home</div>
                                        </div>
                                        
                                        <!-- Tech Location -->
                                        <div class="absolute top-1/3 right-1/4 flex flex-col items-center animate-pulse">
                                            <div class="size-8 rounded-full bg-primary flex items-center justify-center text-background-dark ring-4 ring-primary/20 animate-bounce shadow-[0_0_15px_rgba(19,236,146,0.5)]">
                                                <span class="material-symbols-outlined text-sm">home_repair_service</span>
                                            </div>
                                            <div class="font-bold text-[8px] mt-1 bg-primary text-black px-1.5 py-0.5 rounded shadow-lg uppercase tracking-wider">Tech Marcus</div>
                                        </div>
                                    </div>
                                    <div class="mt-4 flex items-center gap-3 p-3 bg-card-dark rounded-xl border border-primary/5 hover:border-primary/20 transition-colors shadow-sm cursor-pointer group">
                                        <div class="size-10 rounded-full bg-background-dark border border-primary/20 flex items-center justify-center overflow-hidden group-hover:border-primary transition-colors">
                                            <img class="w-full h-full object-cover" alt="Technician Marcus" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA-NvF4lj9YETj7rENmtxk29bVPkqle5ECKm-jg9D_0QMhUFCNlRB09F6eufb8rwf3IGKJ_psoDQpvbUlAX7yTSFm576vNicJUYx9DSxyi884UZPvnR6K2MEZmvGo8tHH106EFxpv1fP6NdLNPDXyt7o3Yz0aEYpkCWmGgKoCp61otyKo1ZuQx-uB2eeBQLU_Qze_gps19j4OmMpUc5LeO0g8cTa0MhGagWsYXpKJhnnNIwI3oZ5CGSLj1g8gqqwdITc6wgt26wopFk"/>
                                        </div>
                                        <div>
                                            <p class="text-sm font-bold text-white group-hover:text-primary transition-colors">Marcus Johnson</p>
                                            <div class="flex items-center text-[10px] text-amber-400 font-bold">
                                                <span class="material-symbols-outlined text-[10px]">star</span>
                                                <span class="material-symbols-outlined text-[10px]">star</span>
                                                <span class="material-symbols-outlined text-[10px]">star</span>
                                                <span class="material-symbols-outlined text-[10px]">star</span>
                                                <span class="material-symbols-outlined text-[10px]">star_half</span>
                                                <span class="text-slate-400 ml-1 font-medium">(4.8/5)</span>
                                            </div>
                                        </div>
                                        <button class="ml-auto size-8 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary transition-colors hover:text-black">
                                            <span class="material-symbols-outlined text-sm">call</span>
                                        </button>
                                    </div>
                                </div>
                            </section>
                            
                            <!-- Support Contacts -->
                            <section class="p-6 rounded-3xl glass-panel relative overflow-hidden">
                                <!-- Background accent -->
                                <div class="absolute -right-10 -bottom-10 size-40 bg-red-500/10 blur-3xl rounded-full"></div>
                                
                                <h3 class="text-sm font-bold text-white mb-4 uppercase tracking-widest relative z-10">Emergency Concierge</h3>
                                <div class="space-y-4 relative z-10">
                                    <button class="w-full flex items-center gap-3 p-3 rounded-xl bg-red-500/5 hover:bg-red-500/10 border border-red-500/20 transition-colors group">
                                        <div class="size-10 rounded-lg bg-red-500/20 flex items-center justify-center text-red-500 group-hover:scale-110 transition-transform">
                                            <span class="material-symbols-outlined">call</span>
                                        </div>
                                        <div class="text-left">
                                            <p class="text-sm font-bold text-white group-hover:text-red-400 transition-colors">Immediate Hotline</p>
                                            <p class="text-xs text-slate-400">Response under 2 mins</p>
                                        </div>
                                    </button>
                                    <button class="w-full flex items-center gap-3 p-3 rounded-xl bg-primary/5 hover:bg-primary/10 border border-primary/20 transition-colors group">
                                        <div class="size-10 rounded-lg bg-primary/20 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                                            <span class="material-symbols-outlined">support_agent</span>
                                        </div>
                                        <div class="text-left">
                                            <p class="text-sm font-bold text-white group-hover:text-primary transition-colors">Speak to Manager</p>
                                            <p class="text-xs text-slate-400">Escalate current issue</p>
                                        </div>
                                    </button>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
@code {
    private int pendingRepairs = 2;
    private int completedRepairs = 18;
    private int emergencyCredits = 450;
    
    private string selectedCategory = "Plumbing";
    private string selectedSeverity = "Medium";
    private string chatInput = "";
    private bool photoUploaded = false;
    private bool isSubmitting = false;
    private bool showAllReports = false;

    private void StartNewReport()
    {
        chatMessages = new()
        {
            new ChatMessage { Text = "Hello Alex! I'm your Staytrust AI assistant. What seems to be the problem today?", IsAI = true }
        };
        chatInput = "";
        photoUploaded = false;
        selectedCategory = "Plumbing";
        selectedSeverity = "Medium";
    }

    private async Task HandlePhotoUpload(InputFileChangeEventArgs e)
    {
        // Simulate reading the file and running AI analysis
        var file = e.File;
        if (file != null)
        {
            await Task.Delay(1000); // Wait 1 sec for UX feedback
            photoUploaded = true;
        }
    }

    private void ToggleViewAll()
    {
        showAllReports = !showAllReports;
    }

    private async Task SubmitReport()
    {
        if(isSubmitting) return;
        
        isSubmitting = true;
        // Simulate network delay
        await Task.Delay(1500);
        
        activeReports.Insert(0, new MaintenanceReport 
        {
            Id = $"INC-{new Random().Next(1000, 9999)}",
            Title = selectedCategory + " Issue Reported",
            TimeAgo = "Just now",
            Status = "Pending Review",
            StatusDetail = "Awaiting AI triage",
            Icon = "pending_actions",
            ColorClass = "bg-primary text-background-dark",
            TextColorClass = "text-primary",
            BgColorClass = "bg-primary"
        });
        
        pendingRepairs++;
        isSubmitting = false;
        
        // Reset form
        chatInput = "";
        photoUploaded = false;
    }

    private void SendMessage()
    {
        if (string.IsNullOrWhiteSpace(chatInput)) return;
        
        chatMessages.Add(new ChatMessage { Text = chatInput, IsAI = false });
        
        // Simulate AI response based on keywords
        var userText = chatInput.ToLower();
        var aiResponse = "I've noted that down. Can you provide more details?";
        
        if (userText.Contains("leak") || userText.Contains("water"))
        {
            aiResponse = "I have flagged this as <span class='text-primary font-bold'>Priority: High</span>. Please upload a photo of the water leak if it is safe to do so.";
            selectedCategory = "Plumbing";
            selectedSeverity = "High";
        }
        else if (userText.Contains("electric") || userText.Contains("light") || userText.Contains("power"))
        {
            aiResponse = "Electrical issues are handled with caution. I've classified this as <span class='text-orange-500 font-bold'>Priority: Medium</span>. Please ensure you are safe.";
            selectedCategory = "Electrical";
        }
        
        chatMessages.Add(new ChatMessage { Text = aiResponse, IsAI = true });
        chatInput = "";
    }

