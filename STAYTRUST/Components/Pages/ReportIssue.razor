@page "/report-issue"
@using STAYTRUST.Models
@using STAYTRUST.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IReportService ReportService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<div class="min-h-screen bg-[#0d141b] py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="mb-8 flex items-center gap-4">
            <button @onclick="GoBack" class="size-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-slate-400">
                <span class="material-symbols-outlined">arrow_back</span>
            </button>
            <div>
                <h1 class="text-2xl font-bold text-white">Report an Issue</h1>
                <p class="text-slate-400 text-sm">Let us know if something is wrong with your rental.</p>
            </div>
        </div>

        @if (isSuccess)
        {
            <div class="bg-emerald-500/10 border border-emerald-500/20 rounded-2xl p-6 text-center animate-in fade-in zoom-in duration-300">
                <div class="size-16 rounded-full bg-emerald-500/20 flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-emerald-500 text-3xl">check_circle</span>
                </div>
                <h2 class="text-xl font-bold text-white mb-2">Report Submitted!</h2>
                <p class="text-slate-400 mb-6">We've received your report and will look into it shortly.</p>
                <button @onclick="NavigateToMyReports" class="px-6 py-2.5 bg-primary hover:bg-primary/90 text-[#0d141b] font-bold rounded-xl transition-all shadow-lg shadow-primary/20">
                    View My Reports
                </button>
            </div>
        }
        else
        {
            <div class="bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-md shadow-2xl">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-500 rounded-xl text-sm font-medium flex items-center gap-2">
                        <span class="material-symbols-outlined">error</span>
                        @errorMessage
                    </div>
                }
                <EditForm Model="@report" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="space-y-6">
                        <!-- Issue Type -->
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-300 block">Issue Category</label>
                            <InputSelect @bind-Value="report.ReportType" class="w-full bg-[#1a232e] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all">
                                <option value="">Select a category</option>
                                <option value="Maintenance">Maintenance / Repair</option>
                                <option value="Billing">Billing / Payment</option>
                                <option value="Noise">Noise Complaint</option>
                                <option value="Security">Security Issue</option>
                                <option value="Other">Other</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => report.ReportType)" class="text-red-400 text-xs mt-1" />
                        </div>

                        <!-- Description -->
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-300 block">Detailed Description</label>
                            <InputTextArea @bind-Value="report.Description" placeholder="Tell us more about the issue..." 
                                           class="w-full bg-[#1a232e] border border-white/10 rounded-xl px-4 py-3 text-white h-40 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all resize-none" />
                            <ValidationMessage For="@(() => report.Description)" class="text-red-400 text-xs mt-1" />
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" disabled="@isSubmitting" 
                                class="w-full h-14 bg-primary hover:bg-primary/90 disabled:opacity-50 text-[#0d141b] font-bold rounded-2xl transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-2 group">
                            @if (isSubmitting)
                            {
                                <div class="size-5 border-2 border-[#0d141b]/30 border-t-[#0d141b] rounded-full animate-spin"></div>
                                <span>Submitting...</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">send</span>
                                <span>Submit Report</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        }
    </div>
</div>

@code {
    private Report report = new Report();
    private bool isSubmitting = false;
    private bool isSuccess = false;
    private string errorMessage = "";

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(report.ReportType) || string.IsNullOrEmpty(report.Description))
        {
            return;
        }

        isSubmitting = true;
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null)
            {
                report.CreatedBy = user.UserId;
                report.Status = "Pending";
                await ReportService.CreateReportAsync(report);
                isSuccess = true;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi khi kết nối đến máy chủ. Vui lòng thử lại sau.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/my-rentals");
    }

    private void NavigateToMyReports()
    {
        NavigationManager.NavigateTo("/my-reports");
    }
}
