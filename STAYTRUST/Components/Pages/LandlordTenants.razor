@page "/landlord-tenants"
@layout STAYTRUST.Components.Layout.LandlordLayout

<div class="flex-1 overflow-y-auto bg-background-light dark:bg-background-dark">
<!-- Header -->
<header class="sticky top-0 z-10 flex items-center justify-between px-8 py-4 bg-background-dark/80 backdrop-blur-md border-b border-navy-muted">
<div class="flex flex-col">
<h2 class="text-2xl font-bold text-slate-100">Residents Overview</h2>
<p class="text-slate-400 text-sm">Manage and track your active residents</p>
</div>
<div class="flex flex-1 max-w-xl justify-center ml-8">
<div class="relative w-full">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
<input class="w-full bg-forest-accent border-none rounded-xl pl-12 pr-4 py-2.5 text-slate-100 focus:ring-2 focus:ring-primary/50 placeholder:text-slate-400 text-sm" placeholder="Search by tenant, property, or unit..." type="text"/>
</div>
</div>
<div class="flex items-center gap-4">
<button class="bg-primary hover:bg-primary/90 text-background-dark font-bold py-2.5 px-6 rounded-xl flex items-center gap-2 transition-all">
<span class="material-symbols-outlined text-[20px]">person_add</span>
<span>Add New Tenant</span>
</button>
</div>
</header>
<div class="p-8 max-w-7xl mx-auto space-y-8">
<!-- Top Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="glass-card rounded-xl p-6 relative overflow-hidden group">
<div class="absolute -right-4 -bottom-4 opacity-10 text-primary transition-transform group-hover:scale-110">
<span class="material-symbols-outlined text-8xl">group</span>
</div>
<p class="text-slate-400 text-sm font-medium mb-1">Total Tenants</p>
<div class="flex items-end gap-3">
<h3 class="text-3xl font-bold text-slate-100">1,284</h3>
<span class="text-primary text-sm font-semibold mb-1 flex items-center">
<span class="material-symbols-outlined text-[16px]">trending_up</span>
                                +5.2%
                            </span>
</div>
</div>
<div class="glass-card rounded-xl p-6 relative overflow-hidden group">
<div class="absolute -right-4 -bottom-4 opacity-10 text-primary transition-transform group-hover:scale-110">
<span class="material-symbols-outlined text-8xl">logout</span>
</div>
<p class="text-slate-400 text-sm font-medium mb-1">Upcoming Move-outs</p>
<h3 class="text-3xl font-bold text-slate-100">24</h3>
</div>
<div class="glass-card rounded-xl p-6 relative overflow-hidden group">
<div class="absolute -right-4 -bottom-4 opacity-10 text-primary transition-transform group-hover:scale-110">
<span class="material-symbols-outlined text-8xl">history_edu</span>
</div>
<p class="text-slate-400 text-sm font-medium mb-1">Pending Renewals</p>
<h3 class="text-3xl font-bold text-slate-100">12</h3>
</div>
</div>
<!-- Main Content Table -->
