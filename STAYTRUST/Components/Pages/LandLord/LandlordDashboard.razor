@page "/landlord/dashboard"
@rendermode InteractiveServer
@inject NavigationManager Nav
@using STAYTRUST.Models
@using STAYTRUST.Data
@using System.Linq
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Dashboard - STAYTRUST</PageTitle>

<div class="min-h-screen text-white" style="background-color:#0a0a0a">

    <!-- Mesh Gradient Background -->
    <div class="fixed inset-0 -z-10">
        <div class="absolute inset-0" style="background: radial-gradient(at 0% 0%, rgba(19,91,236,0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(19,91,236,0.1) 0px, transparent 50%), radial-gradient(at 50% 50%, rgba(10,10,10,1) 0px, transparent 100%)"></div>
    </div>

    <!-- ========== HEADER ========== -->
    <HeaderLandlord />

    <!-- ========== MAIN CONTENT ========== -->
    <main class="pt-24 px-6 pb-10 max-w-7xl mx-auto flex flex-col gap-6">

        <!-- Search Header -->
        <header class="w-full h-16 backdrop-blur-xl border border-white/10 rounded-xl px-6 flex items-center justify-between"
                style="background:rgba(255,255,255,0.03); box-shadow:0 8px 32px 0 rgba(0,0,0,0.37)">
            <div class="flex items-center gap-4 flex-1">
                <i class="fas fa-search text-slate-400 text-lg"></i>
                <input class="bg-transparent border-none text-sm text-slate-300 w-full max-w-md outline-none"
                       placeholder="Search portfolio, residents, or payments..."
                       style="color:#cbd5e1"
                       @bind="searchTerm"
                       @bind:event="oninput" />
            </div>
            <div class="flex items-center gap-4">
                <button class="w-10 h-10 rounded-lg flex items-center justify-center hover:scale-110 transition-all relative"
                        style="background:rgba(255,255,255,0.05)">
                    <i class="fas fa-bell text-slate-300"></i>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-cyan-500 rounded-full border border-[#0a0a0a]"></span>
                </button>
                <button class="w-10 h-10 rounded-lg flex items-center justify-center hover:scale-110 transition-all"
                        style="background:rgba(255,255,255,0.05)">
                    <i class="fas fa-calendar-alt text-slate-300"></i>
                </button>
                <div class="h-6 w-px mx-2" style="background:rgba(255,255,255,0.1)"></div>
                <p class="text-xs font-medium text-slate-400">@DateTime.Now.ToString("dddd, MMM d")</p>
            </div>
        </header>

        <!-- ========== KPI CARDS ========== -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

            <!-- Total Rooms -->
            <div class="backdrop-blur-xl border border-white/10 p-6 rounded-xl flex flex-col gap-1 relative overflow-hidden group hover:-translate-y-2 transition-all duration-300 cursor-pointer"
                 style="background:rgba(255,255,255,0.05)">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-cyan-500/10 rounded-full blur-2xl group-hover:bg-cyan-500/20 transition-all"></div>
                <p class="text-slate-400 text-xs font-medium uppercase tracking-wider">Total Rooms</p>
                <div class="flex items-end justify-between mt-2">
                    <h3 class="text-3xl font-bold text-white">@stats.TotalRooms</h3>
                    <span class="text-emerald-400 text-xs font-semibold px-2 py-0.5 rounded flex items-center gap-1"
                          style="background:rgba(52,211,153,0.1)">
                        <i class="fas fa-arrow-up text-xs"></i> 2%
                    </span>
                </div>
            </div>

            <!-- Occupied Rooms -->
            <div class="backdrop-blur-xl border border-white/10 p-6 rounded-xl flex flex-col gap-1 relative overflow-hidden group hover:-translate-y-2 transition-all duration-300 cursor-pointer"
                 style="background:rgba(255,255,255,0.05)">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-cyan-500/10 rounded-full blur-2xl group-hover:bg-cyan-500/20 transition-all"></div>
                <p class="text-slate-400 text-xs font-medium uppercase tracking-wider">Occupied Rooms</p>
                <div class="flex items-end justify-between mt-2">
                    <h3 class="text-3xl font-bold text-white">@stats.OccupiedRooms</h3>
                    <span class="text-emerald-400 text-xs font-semibold px-2 py-0.5 rounded flex items-center gap-1"
                          style="background:rgba(52,211,153,0.1)">
                        <i class="fas fa-arrow-up text-xs"></i> 1%
                    </span>
                </div>
            </div>

            <!-- Monthly Revenue -->
            <div class="backdrop-blur-xl border border-white/10 p-6 rounded-xl flex flex-col gap-1 relative overflow-hidden group hover:-translate-y-2 transition-all duration-300 cursor-pointer"
                 style="background:rgba(255,255,255,0.05)">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-cyan-500/10 rounded-full blur-2xl group-hover:bg-cyan-500/20 transition-all"></div>
                <p class="text-slate-400 text-xs font-medium uppercase tracking-wider">Monthly Revenue</p>
                <div class="flex items-end justify-between mt-2">
                    <h3 class="text-3xl font-bold text-white">₫@stats.MonthlyRevenue.ToString("N0")</h3>
                    <span class="text-emerald-400 text-xs font-semibold px-2 py-0.5 rounded flex items-center gap-1"
                          style="background:rgba(52,211,153,0.1)">
                        <i class="fas fa-arrow-up text-xs"></i> 8%
                    </span>
                </div>
            </div>

            <!-- Occupancy Rate -->
            <div class="backdrop-blur-xl border border-white/10 p-6 rounded-xl flex flex-col gap-1 relative overflow-hidden group hover:-translate-y-2 transition-all duration-300 cursor-pointer"
                 style="background:rgba(255,255,255,0.05)">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-cyan-500/10 rounded-full blur-2xl group-hover:bg-cyan-500/20 transition-all"></div>
                <p class="text-slate-400 text-xs font-medium uppercase tracking-wider">Occupancy Rate</p>
                <div class="flex items-end justify-between mt-2">
                    <h3 class="text-3xl font-bold text-white">@(stats.OccupancyRate)%</h3>
                    <span class="text-orange-400 text-xs font-semibold px-2 py-0.5 rounded flex items-center gap-1"
                          style="background:rgba(251,146,60,0.1)">
                        <i class="fas fa-arrow-down text-xs"></i> 0.5%
                    </span>
                </div>
            </div>

        </section>

        <!-- ========== CHARTS ROW ========== -->
        <div class="flex flex-col lg:flex-row gap-6" style="min-height:400px">

            <!-- Revenue Line Chart -->
            <div class="flex-[2] backdrop-blur-xl border border-white/10 rounded-xl p-8 relative flex flex-col"
                 style="background:rgba(255,255,255,0.03); box-shadow:0 8px 32px 0 rgba(0,0,0,0.37)">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-xl font-bold text-white">Revenue Trends</h2>
                        <p class="text-sm text-slate-400">Yearly performance overview</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="px-3 py-1.5 rounded-lg text-xs font-medium text-slate-300 hover:bg-white/10 transition-colors"
                                style="background:rgba(255,255,255,0.05)">1M</button>
                        <button class="px-3 py-1.5 rounded-lg text-xs font-medium text-white"
                                style="background:#135bec; box-shadow:0 0 10px rgba(19,91,236,0.2)">6M</button>
                        <button class="px-3 py-1.5 rounded-lg text-xs font-medium text-slate-300 hover:bg-white/10 transition-colors"
                                style="background:rgba(255,255,255,0.05)">1Y</button>
                    </div>
                </div>

                <!-- SVG Chart -->
                <div class="flex-1 relative flex items-end w-full pb-4 px-2">
                    @if (chartData.Count > 0)
                    {
                        var maxVal = Math.Max((double)chartData.Max(x => x.Amount), 1);
                        var points = string.Join(" ", chartData.Select((d, i) => $"{(i * 800 / Math.Max(1, chartData.Count - 1))},{180 - ((double)d.Amount / maxVal * 130)}"));
                        var areaPath = $"M0,200 L{points} L800,200 Z";
                        var linePath = $"M{points}";

                        <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 800 200"
                             style="filter: drop-shadow(0 0 15px rgba(19,91,236,0.2))">
                            <defs>
                                <linearGradient id="chartGradient" x1="0" x2="0" y1="0" y2="1">
                                    <stop offset="0%" stop-color="#135bec" stop-opacity="0.3"></stop>
                                    <stop offset="100%" stop-color="#135bec" stop-opacity="0"></stop>
                                </linearGradient>
                            </defs>
                            <path d="@areaPath" fill="url(#chartGradient)"></path>
                            <path d="@linePath" fill="none" stroke="#135bec" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"></path>
                            
                            @for (int i = 0; i < chartData.Count; i++)
                            {
                                var d = chartData[i];
                                var x = i * 800 / Math.Max(1, chartData.Count - 1);
                                var y = 180 - ((double)d.Amount / maxVal * 130);
                                <circle cx="@x" cy="@y" fill="#135bec" r="4" stroke="white" stroke-width="2"></circle>
                                
                                @if (i == chartData.Count - 1)
                                {
                                    <!-- Dynamic Tooltip -->
                                    <foreignObject x="@(x - 60)" y="@(y - 55)" width="120" height="50">
                                        <div class="backdrop-blur-xl border rounded-lg px-2 py-1 flex flex-col items-center shadow-2xl"
                                             style="background:rgba(255,255,255,0.03); border-color:rgba(19,91,236,0.5)">
                                            <span class="text-slate-400 font-bold uppercase" style="font-size:10px">@d.MonthName</span>
                                            <span class="text-xs font-bold text-white">₫@d.Amount.ToString("N0")</span>
                                        </div>
                                    </foreignObject>
                                }
                            }
                        </svg>
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center text-slate-500 italic text-sm">
                            Insufficient data for trends
                        </div>
                    }

                    <!-- X Axis Labels -->
                    <div class="absolute bottom-0 w-full flex justify-between px-2" style="font-size:10px; color:#64748b; font-weight:700">
                        @foreach (var d in chartData)
                        {
                            <span>@d.MonthName.Substring(0, 3).ToUpper()</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Donut Chart -->
            <div class="flex-1 backdrop-blur-xl border border-white/10 rounded-xl p-8 flex flex-col"
                 style="background:rgba(255,255,255,0.03); box-shadow:0 8px 32px 0 rgba(0,0,0,0.37)">
                <h2 class="text-xl font-bold text-white mb-1">Room Status</h2>
                <p class="text-sm text-slate-400 mb-8">Current inventory health</p>
                <div class="flex-1 flex items-center justify-center relative">
                    <div class="w-48 h-48 rounded-full flex items-center justify-center relative"
                         style="border: 18px solid rgba(30,41,59,0.5); filter: drop-shadow(0 10px 10px rgba(0,0,0,0.5))">
                        <svg class="absolute" style="inset:-18px; width:calc(100% + 36px); height:calc(100% + 36px); transform:rotate(-90deg)">
                            <circle cx="50%" cy="50%" fill="none" r="96"
                                    stroke="#135bec" stroke-dasharray="450 600"
                                    stroke-linecap="round" stroke-width="18"></circle>
                            <circle cx="50%" cy="50%" fill="none" opacity="0.6" r="96"
                                    stroke="#3b82f6" stroke-dasharray="100 600"
                                    stroke-dashoffset="-460" stroke-linecap="round" stroke-width="18"></circle>
                        </svg>
                        <div class="text-center">
                            <p class="text-3xl font-bold text-white leading-none">@stats.TotalRooms</p>
                            <p class="text-slate-500 font-bold uppercase mt-1 tracking-widest" style="font-size:10px">Total</p>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-8">
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full" style="background:#135bec; box-shadow:0 0 8px rgba(19,91,236,0.6)"></div>
                        <span class="text-xs text-slate-300 font-medium">Occupied (@stats.OccupiedRooms)</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-slate-700"></div>
                        <span class="text-xs text-slate-300 font-medium">Vacant (@(stats.TotalRooms - stats.OccupiedRooms))</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ========== PAYMENT STATUS TRACKING (PROPERTY-FIRST) ========== -->
        <section id="payment-tracking" 
                 class="backdrop-blur-3xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl bg-white/5 transition-all duration-500 @(isFullExpanded ? "fixed inset-8 z-[200] !m-0 bg-black/95" : "")">
            
            <div class="px-8 py-6 border-b border-white/10 flex items-center justify-between bg-white/5">
                <div>
                    <h3 class="text-xl font-bold text-white flex items-center gap-3">
                        <i class="fas fa-file-invoice-dollar text-cyan-400"></i>
                        Payment Status Tracking
                    </h3>
                    @if (selectedBuilding == null)
                    {
                        <p class="text-xs text-slate-400 mt-1 uppercase tracking-widest font-bold">Select a property to view room details</p>
                    }
                    else
                    {
                        <div class="flex items-center gap-2 mt-1">
                            <button @onclick="() => selectedBuilding = null" class="text-xs text-cyan-500 hover:underline font-bold uppercase tracking-widest">Properties</button>
                            <i class="fas fa-chevron-right text-[10px] text-slate-600"></i>
                            <span class="text-xs text-slate-300 font-bold uppercase tracking-widest">@selectedBuilding</span>
                        </div>
                    }
                </div>
                <div class="flex gap-3">
                    <button class="px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 text-xs font-bold border border-white/10">Export CSV</button>
                    <button class="px-4 py-2 rounded-xl bg-cyan-600 hover:bg-cyan-500 text-white text-xs font-bold shadow-lg shadow-cyan-500/20">Generate Bills</button>
                </div>
            </div>

            <div class="overflow-y-auto @(isFullExpanded ? "h-[calc(100vh-280px)]" : "max-h-[600px]") px-8 py-8 transition-all">
                @if (selectedBuilding == null)
                {
                    <!-- PROPERTY GRID -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in">
                        @foreach (var buildingName in buildingInvoices.Keys)
                        {
                            var bInvoices = buildingInvoices[buildingName];
                            var unpaid = bInvoices.Count(i => i.Status != "Paid");
                            <div @onclick="() => SelectBuilding(buildingName)" 
                                 class="p-6 rounded-2xl border border-white/5 bg-white/5 hover:bg-white/10 hover:border-cyan-500/30 transition-all cursor-pointer group relative overflow-hidden active:scale-95">
                                <div class="absolute -right-4 -top-4 w-24 h-24 bg-cyan-500/5 rounded-full blur-2xl group-hover:bg-cyan-500/10 transition-all"></div>
                                <h4 class="text-lg font-black text-white group-hover:text-cyan-400 uppercase tracking-tight">@buildingName</h4>
                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-[0.2em] mt-1 truncate">@bInvoices.FirstOrDefault()?.Contract?.Room?.Address</p>
                                
                                <div class="mt-8 flex items-center justify-between">
                                    <div>
                                        <p class="text-[9px] text-slate-600 font-black uppercase tracking-[0.2em]">Invoices</p>
                                        <p class="text-xs font-bold text-slate-400 mt-1">@unpaid Unpaid</p>
                                    </div>
                                    <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-slate-600 group-hover:text-cyan-400 transition-all border border-transparent group-hover:border-white/10">
                                        <i class="fas fa-chevron-right"></i>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- FLOOR-WISE ROOM LIST -->
                    <div class="flex flex-col gap-10 animate-fade-in-up">
                        @foreach (var floorGroup in filteredAndGroupedInvoices)
                        {
                            <div class="space-y-4">
                                <div class="flex items-center gap-4 mb-2">
                                    <div class="px-3 py-1 bg-cyan-500 text-black text-[10px] font-black uppercase tracking-widest rounded-md shadow-lg shadow-cyan-500/20">Floor @floorGroup.Key</div>
                                    <div class="flex-1 h-[1px] bg-gradient-to-r from-cyan-500/30 to-transparent"></div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    @foreach (var inv in floorGroup.OrderBy(i => i.Contract?.Room?.Title))
                                    {
                                        <div class="flex items-center justify-between px-6 py-5 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/5 transition-all group hover:border-white/10">
                                            <div class="flex items-center gap-5">
                                                <div class="w-12 h-12 rounded-2xl border border-white/10 bg-slate-900/50 flex items-center justify-center text-cyan-400 font-black text-lg group-hover:scale-110 transition-all shadow-inner">
                                                    @(inv.Contract?.Tenant?.FullName?.FirstOrDefault() ?? 'U')
                                                </div>
                                                <div>
                                                    <p class="text-sm font-black text-white uppercase tracking-tight">Room <span class="text-cyan-400">@inv.Contract?.Room?.Title</span></p>
                                                    <p class="text-[11px] text-slate-500 font-bold uppercase tracking-widest mt-0.5">@inv.Contract?.Tenant?.FullName</p>
                                                </div>
                                            </div>
                                            <div class="flex flex-col items-end gap-3 text-right">
                                                <div class="text-right">
                                                    <p class="text-[9px] text-slate-600 font-black tracking-widest uppercase">Amount</p>
                                                    <p class="text-sm font-black text-white">₫@inv.TotalAmount?.ToString("N0")</p>
                                                </div>
                                                @if (inv.Status == "Paid") {
                                                    <span class="px-3 py-1 rounded-lg border border-emerald-500/20 bg-emerald-500/5 text-emerald-400 text-[9px] font-black uppercase tracking-widest">PAID</span>
                                                } else {
                                                    <span class="px-3 py-1 rounded-lg border border-rose-500/20 bg-rose-500/5 text-rose-400 text-[9px] font-black uppercase tracking-widest">UNPAID</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            
            <div class="p-6 bg-white/5 border-t border-white/10">
                <button @onclick="ToggleFullHistory" class="w-full py-4 rounded-xl border border-white/5 bg-white/5 hover:bg-white/10 text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 hover:text-white transition-all shadow-inner">
                    @(isFullExpanded ? "Back to Dashboard" : "View Full Transaction History")
                </button>
            </div>
        </section>

        <!-- ========== PRIORITY ISSUES ========== -->
        <section class="backdrop-blur-xl border border-white/10 rounded-xl p-6 mb-4"
                 style="background:rgba(255,255,255,0.03); box-shadow:0 8px 32px 0 rgba(0,0,0,0.37)">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-white">Priority Issues</h3>
                <button class="text-xs font-bold hover:underline flex items-center gap-2" style="color:#135bec">
                    View All Tickets <i class="fas fa-chevron-right text-xs"></i>
                </button>
            </div>
            <div class="flex flex-col gap-3">
                @foreach (var issue in priorityIssues)
                {
                    <div class="flex items-center justify-between p-4 rounded-xl border border-white/5 hover:bg-white/[0.08] transition-all cursor-pointer group"
                         style="background:rgba(255,255,255,0.05)">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                                 style="background: @(issue.BgStyle); color: @(issue.TextStyle)">
                                <i class="fas fa-@(issue.IconClass) text-xl"></i>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-white">@issue.Title</p>
                                <p class="text-xs text-slate-500">Reported by @issue.Reporter • @issue.Time</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-6">
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border"
                                  style="background: @(issue.BadgeBg); color: @(issue.TextStyle); border-color: @(issue.BorderStyle)">
                                @issue.Priority
                            </span>
                            <i class="fas fa-chevron-right text-slate-500 group-hover:text-white transition-colors"></i>
                        </div>
                    </div>
                }
            </div>
        </section>

    </main>

    <!-- Floating Action Button -->
    <button class="fixed bottom-10 right-10 w-16 h-16 rounded-full flex items-center justify-center text-white z-20 group hover:scale-110 transition-transform"
            style="background:#135bec; box-shadow:0 20px 40px rgba(19,91,236,0.4)">
        <i class="fas fa-plus text-3xl group-hover:rotate-90 transition-transform duration-300"></i>
    </button>

</div>

@code {
    private string searchTerm = "";
    private int landlordId;
    private DashboardStats stats = new(0, 0, 0, 0);
    private List<Invoice> recentInvoices = new();
    private List<MonthlyRevenueData> chartData = new();
    private List<Invoice> allInvoices = new();
    private Dictionary<string, List<Invoice>> buildingInvoices = new();
    private string? selectedBuilding = null;
    private bool isFullExpanded = false;

    private IEnumerable<IGrouping<int, Invoice>> filteredAndGroupedInvoices {
        get {
            var filtered = allInvoices;
            if (selectedBuilding != null)
                filtered = allInvoices.Where(i => GetBuildingName(i.Contract?.Room?.Address) == selectedBuilding).ToList();
            
            return filtered.GroupBy(i => i.Contract?.Room?.Floor ?? 0).OrderByDescending(g => g.Key);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user != null && user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value 
                         ?? user.FindFirst("sub")?.Value 
                         ?? user.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;

            if (!string.IsNullOrEmpty(userIdStr) && int.TryParse(userIdStr, out landlordId))
            {
                await LoadDashboardData();
            }
        }
    }

    private async Task LoadDashboardData()
    {
        try 
        {
            using var dbContext = DbFactory.CreateDbContext();

            // Get Current User info to check if they are a manager
            var currentUser = await dbContext.Users.AsNoTracking().FirstOrDefaultAsync(u => u.UserId == landlordId);
            bool isManager = currentUser?.LandlordId != null;

            // Fetch Rooms (Owner sees all, Manager sees assigned only)
            IQueryable<Room> roomsQuery = dbContext.Rooms.AsNoTracking();
            
            if (isManager)
                roomsQuery = roomsQuery.Where(r => r.ManagedByUserId == landlordId);
            else
                roomsQuery = roomsQuery.Where(r => r.LandlordId == landlordId);

            var rooms = await roomsQuery.ToListAsync();

            int totalRooms = rooms.Count;
            var roomIds = rooms.Select(r => r.RoomId).ToList();

            if (roomIds.Count > 0)
            {
                // Fetch Active Contracts to count occupied rooms
                var activeContractsCount = await dbContext.RentalContracts
                    .AsNoTracking()
                    .Where(c => roomIds.Contains(c.RoomId) && c.Status == "Active")
                    .Select(c => c.RoomId)
                    .Distinct()
                    .CountAsync();
                    
                int occupiedRooms = activeContractsCount;
                double occupancyRate = totalRooms > 0 ? (double)occupiedRooms / totalRooms * 100 : 0;

                // Fetch Recent Invoices across all landlord's rooms
                recentInvoices = await dbContext.Invoices
                    .AsNoTracking()
                    .Include(i => i.Contract)
                        .ThenInclude(c => c.Room)
                    .Include(i => i.Contract)
                        .ThenInclude(c => c.Tenant)
                    .Where(i => roomIds.Contains(i.Contract.RoomId))
                    .OrderByDescending(i => i.CreatedAt)
                    .Take(7)
                    .ToListAsync();

                decimal monthlyRev = await dbContext.Invoices
                    .AsNoTracking()
                    .Where(i => roomIds.Contains(i.Contract.RoomId) && i.Status == "Paid" && i.CreatedAt.Month == DateTime.Now.Month && i.CreatedAt.Year == DateTime.Now.Year)
                    .SumAsync(i => i.TotalAmount ?? 0);

                stats = new DashboardStats(totalRooms, occupiedRooms, (double)monthlyRev, Math.Round(occupancyRate, 1));

                // Populate Chart Data for Last 6 Months
                chartData.Clear();
                var now = DateTime.Now;
                for (int i = 5; i >= 0; i--)
                {
                    var date = now.AddMonths(-i);
                    var monthStart = new DateTime(date.Year, date.Month, 1);
                    var monthEnd = monthStart.AddMonths(1).AddDays(-1);

                    var rev = await dbContext.Invoices
                        .AsNoTracking()
                        .Where(inv => roomIds.Contains(inv.Contract.RoomId) && inv.Status == "Paid" && inv.CreatedAt >= monthStart && inv.CreatedAt <= monthEnd)
                        .SumAsync(inv => inv.TotalAmount ?? 0);

                    chartData.Add(new MonthlyRevenueData(date.ToString("MMMM"), rev));
                }

                // Invoices for Property-First View
                allInvoices = await dbContext.Invoices.AsNoTracking()
                    .Include(i => i.Contract).ThenInclude(c => c.Room)
                    .Include(i => i.Contract).ThenInclude(c => c.Tenant)
                    .Where(i => roomIds.Contains(i.Contract.RoomId))
                    .OrderByDescending(i => i.CreatedAt).ToListAsync();

                buildingInvoices = allInvoices.GroupBy(i => GetBuildingName(i.Contract?.Room?.Address)).ToDictionary(g => g.Key, g => g.ToList());
                recentInvoices = allInvoices.Take(7).ToList();
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
    }

    private string GetBuildingName(string? address) => !string.IsNullOrEmpty(address) ? address.Split(',').First().Trim() : "Standalone Property";

    private void ToggleFullHistory() => isFullExpanded = !isFullExpanded;

    private void SelectBuilding(string b) { selectedBuilding = b; StateHasChanged(); }

