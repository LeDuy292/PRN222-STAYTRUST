    // ── Data Models ───────────────────────────────────────────────────────────
    private record TabDef(string Id, string Label, string Icon);
    private record HistoryItem(string Action, string User, DateTime Date);

    private class PropertyDetail
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
