                       </span>,
        "occupied" => @<span class="flex items-center gap-2 px-4 py-2 rounded-full border font-semibold"
                             style="background:rgba(59,130,246,.2);color:#60a5fa;border-color:rgba(59,130,246,.3)">
                          <i class="fas fa-users"></i> Occupied
                      </span>,
        "maintenance" => @<span class="flex items-center gap-2 px-4 py-2 rounded-full border font-semibold"
                                style="background:rgba(249,115,22,.2);color:#fb923c;border-color:rgba(249,115,22,.3)">
                             <i class="fas fa-tools"></i> Maintenance
