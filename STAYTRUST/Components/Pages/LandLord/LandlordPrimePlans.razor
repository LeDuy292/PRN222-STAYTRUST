@page "/landlord/prime"
@rendermode InteractiveServer
@inject NavigationManager Nav

<PageTitle>Prime Plans - STAYTRUST</PageTitle>

<HeadContent>
    <style>
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeInUp 0.6s ease-out both; }
        @@keyframes pulse2 {
            0%, 100% { opacity: 1; }
            50%       { opacity: .5; }
        }
        .pulse2 { animation: pulse2 3s ease-in-out infinite; }
        .pulse2-delay { animation: pulse2 3s ease-in-out 2s infinite; }
    </style>
</HeadContent>

<div class="min-h-screen text-white" style="background-color:#0a0a0a">

    <!-- Mesh Gradient Background -->
    <div class="fixed inset-0 -z-10">
        <div class="absolute inset-0"
             style="background:radial-gradient(at 0% 0%,rgba(19,91,236,.15) 0,transparent 50%),radial-gradient(at 100% 100%,rgba(19,91,236,.1) 0,transparent 50%),radial-gradient(at 50% 50%,rgba(10,10,10,1) 0,transparent 100%)">
        </div>
    </div>

    <!-- ========== HEADER ========== -->
    <HeaderLandlord />

    <!-- ========== MAIN CONTENT ========== -->
    <div class="pt-24 pb-12">

        <!-- ===== HERO ===== -->
        <div class="relative px-6 py-20 overflow-hidden">
            <div class="absolute inset-0 overflow-hidden">
                <div class="absolute top-20 left-10 w-64 h-64 rounded-full blur-3xl pulse2"  style="background:rgba(6,182,212,.1)"></div>
                <div class="absolute bottom-20 right-10 w-96 h-96 rounded-full blur-3xl pulse2-delay" style="background:rgba(168,85,247,.1)"></div>
            </div>

            <div class="max-w-7xl mx-auto text-center relative z-10">
                <div class="inline-flex items-center gap-2 px-4 py-2 border border-cyan-500/30 rounded-full mb-6 fade-up" style="background:rgba(6,182,212,.1)">
                    <i class="fas fa-crown text-cyan-400"></i>
                    <span class="text-sm font-semibold text-cyan-400">UPGRADE TO PRIME</span>
                </div>

                <h1 class="text-5xl md:text-7xl font-bold mb-6 fade-up" style="animation-delay:.1s">
                    Supercharge Your&nbsp;
                    <span class="bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">Property Business</span>
                </h1>

                <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto fade-up" style="animation-delay:.2s">
                    Get unlimited listings, AI-powered features, and priority placement. Join 10,000+ successful landlords.
                </p>

                <!-- Billing Toggle -->
                <div class="flex items-center justify-center gap-4 mb-12 fade-up" style="animation-delay:.3s">
                    <span class="font-semibold @(billingCycle == "monthly" ? "text-white" : "text-gray-500")">Monthly</span>
                    <button @onclick="ToggleBilling"
                            class="relative w-16 h-8 rounded-full transition-colors"
                            style="@(billingCycle == "yearly" ? "background:linear-gradient(to right,#06b6d4,#2563eb)" : "background:#374151")">
                        <div class="absolute top-1 left-1 w-6 h-6 bg-white rounded-full transition-transform @(billingCycle == "yearly" ? "translate-x-8" : "")"></div>
                    </button>
                    <span class="font-semibold @(billingCycle == "yearly" ? "text-white" : "text-gray-500")">
                        Yearly
                        <span class="ml-2 px-2 py-1 text-purple-400 text-xs rounded-full" style="background:rgba(168,85,247,.2)">Save 17%</span>
                    </span>
                </div>

                <!-- Stats -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto fade-up" style="animation-delay:.4s">
                    @foreach (var s in heroStats)
                    {
                        <div class="backdrop-blur-xl border border-white/10 rounded-xl p-4 hover:bg-white/[0.05] transition-all text-center" style="background:rgba(255,255,255,.03)">
                            <i class="fas fa-@(s.Icon) text-3xl text-cyan-400 mb-2"></i>
                            <div class="text-2xl font-bold mb-1">@s.Value</div>
                            <div class="text-sm text-gray-400">@s.Label</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ===== PRICING CARDS ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-20">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
                @foreach (var (plan, idx) in pricingPlans.Select((p, i) => (p, i)))
                {
                    <div class="relative backdrop-blur-xl border-2 rounded-3xl overflow-hidden transition-all duration-500 hover:-translate-y-4 fade-up @(plan.Popular ? "scale-105" : "")"
                         style="background:rgba(255,255,255,.03);border-color:@(plan.Popular ? "rgba(6,182,212,.5)" : "rgba(255,255,255,.1)");animation-delay:@(idx * 0.2)s;@(plan.Popular ? "box-shadow:0 25px 50px rgba(6,182,212,.2)" : "")">

                        @if (plan.Popular)
                        {
                            <div class="absolute top-0 left-0 right-0 bg-gradient-to-r from-cyan-500 to-blue-600 py-2 text-center font-bold text-sm z-10">
                                ⭐ MOST POPULAR
                            </div>
                        }

                        <!-- Image Header -->
                        <div class="relative @(plan.Popular ? "mt-8" : "") h-48 overflow-hidden">
                            <img src="@plan.Image" alt="@plan.Name" class="w-full h-full object-cover transition-transform duration-700 hover:scale-110" />
                            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/50 to-transparent"></div>
                            @if (plan.Badge != null)
                            {
                                <div class="absolute top-4 right-4 px-3 py-1 backdrop-blur-sm rounded-full text-xs font-bold" style="background:@(plan.BadgeBg)">
                                    @plan.Badge
                                </div>
                            }
                        </div>

                        <!-- Content -->
                        <div class="p-8">
                            <h3 class="text-2xl font-bold mb-2">@plan.Name</h3>
                            <p class="text-sm text-gray-400 mb-6">@plan.Subtitle</p>

                            <!-- Price -->
                            <div class="mb-6">
                                @if (plan.OriginalPriceYearly.HasValue && billingCycle == "yearly")
                                {
                                    <div class="text-gray-500 line-through text-lg mb-1">₫@FormatPrice(plan.OriginalPriceYearly.Value)/year</div>
                                }
                                <div class="flex items-baseline gap-2">
                                    <span class="text-4xl font-bold text-cyan-400">
                                        ₫@FormatPrice(billingCycle == "monthly" ? plan.PriceMonthly : plan.PriceYearly)
                                    </span>
                                    <span class="text-gray-400">/@(billingCycle == "monthly" ? "month" : "year")</span>
                                </div>
                                @if (billingCycle == "yearly" && plan.Id == "yearly")
                                {
                                    <div class="text-sm text-green-400 mt-1">≈ ₫@FormatPrice(plan.PriceMonthly)/month</div>
                                }
                            </div>

                            <p class="text-gray-300 mb-6 text-sm">@plan.Description</p>

                            <!-- CTA -->
                            <button class="w-full py-4 rounded-xl font-bold transition-all duration-300 mb-6 @(plan.Popular ? "hover:scale-105" : "")"
                                    style="@(plan.Popular ? "background:linear-gradient(to right,#06b6d4,#2563eb);box-shadow:0 0 20px rgba(6,182,212,.3)" : "background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.2)")">
                                @plan.Cta <i class="fas fa-arrow-right ml-2"></i>
                            </button>

                            <!-- Features -->
                            <div class="space-y-3">
                                @foreach (var feat in plan.Features)
                                {
                                    <div class="flex items-start gap-3 text-sm @(feat.Included ? "text-gray-300" : "text-gray-600") @(feat.Highlight ? "rounded-lg -mx-4 px-4 py-2" : "")"
                                         style="@(feat.Highlight ? "background:rgba(34,197,94,.1)" : "")">
                                        @if (feat.Included)
                                        {
                                            <i class="fas fa-check-circle mt-0.5 flex-shrink-0" style="color:@plan.FeatureCheckColor"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-times mt-0.5 flex-shrink-0 text-gray-600"></i>
                                        }
                                        <span class="@(feat.Highlight ? "font-semibold text-green-400" : "")">@feat.Text</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (plan.Popular)
                        {
                            <div class="absolute -inset-1 blur-xl -z-10" style="background:linear-gradient(to right,rgba(6,182,212,.2),rgba(37,99,235,.2))"></div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ===== PRIME FEATURES GRID ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-20">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    Unlock Powerful <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Prime Features</span>
                </h2>
                <p class="text-xl text-gray-400">Everything you need to dominate the rental market</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var (feat, idx) in primeFeatures.Select((f, i) => (f, i)))
                {
                    <div class="group relative backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden hover:bg-white/[0.05] transition-all duration-500 hover:-translate-y-2 fade-up"
                         style="background:rgba(255,255,255,.03);animation-delay:@(idx * 0.15)s">
                        <div class="relative h-48 overflow-hidden">
                            <img src="@feat.Image" alt="@feat.Title" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/50 to-transparent"></div>
                            <div class="absolute top-4 left-4 w-12 h-12 backdrop-blur-md rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                 style="background:@feat.IconBg;border:1px solid @feat.IconBorder">
                                <i class="fas fa-@(feat.Icon) text-2xl" style="color:@feat.IconColor"></i>
                            </div>
                            <div class="absolute bottom-4 right-4 px-3 py-1 rounded-lg text-sm" style="background:rgba(0,0,0,.6)">
                                <div class="text-xs text-gray-400">@feat.StatsLabel</div>
                                <div class="font-bold" style="color:@feat.IconColor">@feat.StatsValue</div>
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2 group-hover:text-cyan-400 transition-colors">@feat.Title</h3>
                            <p class="text-gray-400 text-sm">@feat.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ===== TESTIMONIALS ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-20">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    Success <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Stories</span>
                </h2>
                <p class="text-xl text-gray-400">See how Prime transformed their businesses</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                @foreach (var (t, idx) in testimonials.Select((x, i) => (x, i)))
                {
                    <div class="group relative backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden hover:bg-white/[0.05] transition-all duration-500 hover:-translate-y-2 fade-up"
                         style="background:rgba(255,255,255,.03);animation-delay:@(idx * 0.2)s">
                        <div class="relative h-40 overflow-hidden">
                            <img src="@t.Image" alt="@t.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>
                        </div>
                        <div class="p-6">
                            <i class="fas fa-quote-left text-3xl mb-4" style="color:rgba(6,182,212,.3)"></i>
                            <div class="flex gap-1 mb-4">
                                @for (int i = 0; i < t.Rating; i++) { <i class="fas fa-star text-yellow-400"></i> }
                            </div>
                            <p class="text-gray-300 mb-6 italic">"@t.Text"</p>
                            <div class="flex items-center gap-4 pt-4 border-t border-white/10">
                                <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-lg" style="background:@t.AvatarBg">@t.Avatar</div>
                                <div class="flex-1">
                                    <div class="font-bold">@t.Name</div>
                                    <div class="text-sm text-gray-400">@t.Role</div>
                                    <div class="text-xs text-cyan-400">@(t.Properties) properties</div>
                                </div>
                            </div>
                            <div class="mt-4 px-4 py-2 border border-green-500/30 rounded-lg text-center" style="background:rgba(34,197,94,.1)">
                                <div class="text-xs text-gray-400">Extra Revenue</div>
                                <div class="text-lg font-bold text-green-400">@t.Savings</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ===== COMPARISON TABLE ===== -->
        <div class="max-w-6xl mx-auto px-6 mb-20">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    Detailed <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Comparison</span>
                </h2>
                <p class="text-xl text-gray-400">Compare all features across plans</p>
            </div>

            <div class="backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden" style="background:rgba(255,255,255,.03)">
                <!-- Header -->
                <div class="grid grid-cols-4 gap-4 p-6 border-b border-white/10" style="background:rgba(255,255,255,.03)">
                    <div class="font-bold">Feature</div>
                    <div class="text-center font-bold">Free</div>
                    <div class="text-center font-bold text-cyan-400">Prime Monthly</div>
                    <div class="text-center font-bold text-purple-400">Prime Yearly</div>
                </div>
                @foreach (var (row, idx) in comparisonRows.Select((r, i) => (r, i)))
                {
                    <div class="grid grid-cols-4 gap-4 p-6 hover:bg-white/[0.03] transition-colors @(idx < comparisonRows.Count - 1 ? "border-b border-white/5" : "")">
                        <div class="text-sm text-gray-300">@row.Feature</div>
                        <div class="text-center text-sm">@((MarkupString)RenderCell(row.Free, "text-green-400"))</div>
                        <div class="text-center text-sm">@((MarkupString)RenderCell(row.Monthly, "text-cyan-400"))</div>
                        <div class="text-center text-sm">@((MarkupString)RenderCell(row.Yearly, "text-purple-400"))</div>
                    </div>
                }
            </div>
        </div>

        <!-- ===== FAQ ===== -->
        <div class="max-w-4xl mx-auto px-6 mb-20">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    Frequently Asked <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Questions</span>
                </h2>
                <p class="text-xl text-gray-400">Everything you need to know about Prime</p>
            </div>

            <div class="space-y-4">
                @foreach (var (faq, idx) in faqs.Select((f, i) => (f, i)))
                {
                    <div class="backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden hover:bg-white/[0.05] transition-all" style="background:rgba(255,255,255,.03)">
                        <button @onclick="() => ToggleFaq(idx)" class="w-full flex items-center justify-between p-6 text-left">
                            <span class="font-semibold text-lg">@faq.Question</span>
                            <i class="fas fa-chevron-down text-cyan-400 transition-transform @(openFaq == idx ? "rotate-180" : "")"></i>
                        </button>
                        @if (openFaq == idx)
                        {
                            <div class="px-6 pb-6 text-gray-400">@faq.Answer</div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ===== FINAL CTA ===== -->
        <div class="max-w-5xl mx-auto px-6">
            <div class="relative border border-cyan-500/30 rounded-3xl p-12 text-center overflow-hidden"
                 style="background:linear-gradient(135deg,rgba(6,182,212,.1),rgba(168,85,247,.1))">
                <div class="absolute inset-0 opacity-10">
                    <div class="absolute top-0 left-0 w-40 h-40 bg-cyan-500 rounded-full blur-3xl"></div>
                    <div class="absolute bottom-0 right-0 w-40 h-40 bg-purple-500 rounded-full blur-3xl"></div>
                </div>
                <div class="relative z-10">
                    <i class="fas fa-crown text-6xl text-cyan-400 mb-6 block animate-pulse"></i>
                    <h2 class="text-4xl md:text-5xl font-bold mb-4">Ready to Go Prime?</h2>
                    <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
                        Join thousands of successful landlords. Start your 15-day free trial today, no credit card required.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                        <button class="px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 rounded-xl font-bold text-lg transition-all hover:scale-105"
                                style="box-shadow:0 0 30px rgba(6,182,212,.3)">
                            Start Free Trial <i class="fas fa-rocket ml-2"></i>
                        </button>
                        <button class="px-8 py-4 hover:bg-white/10 border border-white/20 rounded-xl font-bold text-lg transition-all" style="background:rgba(255,255,255,.05)">
                            Compare Plans
                        </button>
                    </div>
                    <div class="mt-8 flex flex-wrap items-center justify-center gap-8 text-sm text-gray-400">
                        <div class="flex items-center gap-2"><i class="fas fa-check-circle text-green-400"></i><span>No credit card required</span></div>
                        <div class="flex items-center gap-2"><i class="fas fa-check-circle text-green-400"></i><span>Cancel anytime</span></div>
                        <div class="flex items-center gap-2"><i class="fas fa-check-circle text-green-400"></i><span>30-day money back</span></div>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /pt-24 -->
</div><!-- /min-h-screen -->

