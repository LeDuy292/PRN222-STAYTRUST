    private static string RenderCell(string val, string colorClass)
    {
        if (val == "true")  return $"<i class='fas fa-check {colorClass} mx-auto block text-center'></i>";
        if (val == "false") return "<i class='fas fa-times text-gray-600 mx-auto block text-center'></i>";
        return $"<span class='{colorClass} font-semibold'>{val}</span>";
    }

