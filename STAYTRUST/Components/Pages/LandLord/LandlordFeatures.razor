        new(3,"rocket",     "Go Live",             "Your properties go live instantly. Start receiving inquiries immediately.",
            "rgba(168,85,247,.2)","rgba(168,85,247,.5)","#c084fc","#9333ea"),
        new(4,"crown",      "Upgrade to Prime",    "Unlock unlimited features, AI tools, and priority placement.",
            "rgba(234,179,8,.2)","rgba(234,179,8,.5)","#facc15","#ca8a04"),
    };

    // ── Integrations ──────────────────────────────────────────────────────────
    private readonly List<(string Name, string Logo)> integrations = new()
    {
        ("Google Calendar", "📅"),
        ("Momo",            "💰"),
        ("ZaloPay",         "💳"),
        ("VNPay",           "🏦"),
        ("QuickBooks",      "📊"),
        ("Zapier",          "⚡"),
        ("Slack",           "💬"),
        ("Google Maps",     "🗺️"),
    };

    // ── Data Models ───────────────────────────────────────────────────────────
    private record Category(string Id, string Name, string Icon, int Count);

    private record FeatureItem(
        int Id, string Category, string Icon, string Title, string Description, string Image,
        string IconBg, string IconBorder, string IconColor, string GlowBg,
        string StatsLabel, string StatsValue, List<string> Benefits);

    private record DemoScreen(string Title, string Description, string Image);

    private record HowStep(int Step, string Icon, string Title, string Description,
        string CircleBg, string CircleBorder, string IconColor, string BadgeBg);
}