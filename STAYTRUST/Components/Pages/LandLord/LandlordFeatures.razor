            "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=400&fit=crop&q=90",
            "rgba(249,115,22,.2)","rgba(249,115,22,.3)","#fb923c","rgba(249,115,22,.1)",
            "Occupancy rate","95%+",
            new(){"Vacancy tracking","Seasonal trends","Price optimization","Competitor analysis"}),
        new(6,"analytics","chart-pie","Performance Dashboard",
            "Visualize all key metrics in one place. Customizable widgets and real-time updates.",
            "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop&q=90",
            "rgba(6,182,212,.2)","rgba(6,182,212,.3)","#22d3ee","rgba(6,182,212,.1)",
            "Data points","50+",
            new(){"Custom dashboards","Real-time data","Export reports","Mobile access"}),
        new(7,"automation","robot","AI Chatbot",
