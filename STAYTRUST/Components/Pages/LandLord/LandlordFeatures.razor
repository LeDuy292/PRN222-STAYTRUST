@page "/landlord/features"
@rendermode InteractiveServer
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Features - STAYTRUST</PageTitle>

<HeadContent>
    <style>
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeInUp 0.5s ease-out both; }
        .scrollbar-hide { -ms-overflow-style:none; scrollbar-width:none; }
        .scrollbar-hide::-webkit-scrollbar { display:none; }
    </style>
</HeadContent>

<div class="min-h-screen text-white" style="background-color:#0a0a0a">

    <!-- Mesh Gradient Background -->
    <div class="fixed inset-0 -z-10">
        <div class="absolute inset-0"
             style="background:radial-gradient(at 0% 0%,rgba(19,91,236,.15) 0,transparent 50%),radial-gradient(at 100% 100%,rgba(19,91,236,.1) 0,transparent 50%),radial-gradient(at 50% 50%,rgba(10,10,10,1) 0,transparent 100%)">
        </div>
    </div>

    <!-- ========== HEADER ========== -->
    <HeaderLandlord />

    <!-- ========== MAIN CONTENT ========== -->
    <div class="pt-24 pb-12">

        <!-- ===== HERO ===== -->
        <div class="relative px-6 py-20 overflow-hidden">
            <div class="absolute inset-0">
                <div class="absolute top-20 left-10 w-72 h-72 rounded-full blur-3xl animate-pulse"  style="background:rgba(6,182,212,.1)"></div>
                <div class="absolute bottom-20 right-10 w-96 h-96 rounded-full blur-3xl animate-pulse" style="background:rgba(168,85,247,.1);animation-delay:2s"></div>
            </div>

            <div class="max-w-7xl mx-auto text-center relative z-10">
                <div class="inline-flex items-center gap-2 px-4 py-2 border border-cyan-500/30 rounded-full mb-6" style="background:rgba(6,182,212,.1)">
                    <i class="fas fa-bolt text-cyan-400"></i>
                    <span class="text-sm font-semibold text-cyan-400">POWERFUL FEATURES</span>
                </div>

                <h1 class="text-5xl md:text-7xl font-bold mb-6">
                    Everything You Need to&nbsp;
                    <span class="bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">Succeed</span>
                </h1>

                <p class="text-xl md:text-2xl text-gray-300 mb-12 max-w-3xl mx-auto">
                    Discover 24+ powerful features designed to simplify property management and maximize your revenue
                </p>

                <!-- Demo Carousel -->
                <div class="max-w-5xl mx-auto mb-12">
                    <div class="relative backdrop-blur-xl border-2 border-cyan-500/30 rounded-3xl overflow-hidden group" style="background:rgba(255,255,255,.03)">
                        <img src="@demoScreens[activeDemo].Image" alt="@demoScreens[activeDemo].Title"
                             class="w-full object-cover transition-transform duration-700 group-hover:scale-105" style="height:500px" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>

                        <div class="absolute bottom-0 left-0 right-0 p-8">
                            <div class="inline-block px-3 py-1 border rounded-full text-sm font-semibold mb-3"
                                 style="background:rgba(6,182,212,.2);border-color:rgba(6,182,212,.5)">
                                Screenshot @(activeDemo + 1) of @demoScreens.Count
                            </div>
                            <h3 class="text-3xl font-bold mb-2">@demoScreens[activeDemo].Title</h3>
                            <p class="text-gray-300 text-lg">@demoScreens[activeDemo].Description</p>
                        </div>

                        <!-- Dots -->
                        <div class="absolute bottom-6 right-6 flex gap-2">
                            @for (int i = 0; i < demoScreens.Count; i++)
                            {
                                int idx = i;
                                <button @onclick="() => activeDemo = idx"
                                        class="h-3 rounded-full transition-all"
                                        style="width:@(activeDemo == idx ? "2rem" : "0.75rem");background:@(activeDemo == idx ? "#22d3ee" : "rgba(255,255,255,.3)")">
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== CATEGORY FILTER ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-12">
            <div class="flex gap-3 overflow-x-auto pb-4 scrollbar-hide">
                @foreach (var cat in categories)
                {
                    <button @onclick="() => selectedCategory = cat.Id"
                            class="flex items-center gap-2 px-6 py-3 rounded-xl font-semibold whitespace-nowrap transition-all"
                            style="@(selectedCategory == cat.Id
                                ? "background:linear-gradient(to right,#06b6d4,#2563eb);box-shadow:0 0 20px rgba(6,182,212,.3)"
                                : "background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1)")">
                        <i class="fas fa-@(cat.Icon)"></i>
                        <span>@cat.Name</span>
                        <span class="px-2 py-0.5 rounded-full text-xs" style="background:rgba(255,255,255,.1)">@cat.Count</span>
                    </button>
                }
            </div>
        </div>

        <!-- ===== FEATURES GRID ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-20">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var (feat, idx) in FilteredFeatures().Select((f, i) => (f, i)))
                {
                    <div class="group relative backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden hover:bg-white/[0.05] transition-all duration-500 hover:-translate-y-2 fade-up"
                         style="background:rgba(255,255,255,.03);animation-delay:@(idx * 0.05)s"
                         @onmouseenter="() => hoveredFeature = feat.Id"
                         @onmouseleave="() => hoveredFeature = null">

                        <!-- Image -->
                        <div class="relative h-48 overflow-hidden">
                            <img src="@feat.Image" alt="@feat.Title"
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/50 to-transparent"></div>

                            <!-- Icon Badge -->
                            <div class="absolute top-4 left-4 w-12 h-12 backdrop-blur-md rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                 style="background:@feat.IconBg;border:1px solid @feat.IconBorder">
                                <i class="fas fa-@(feat.Icon) text-2xl" style="color:@feat.IconColor"></i>
                            </div>

                            <!-- Stats Badge (show on hover) -->
                            <div class="absolute bottom-4 right-4 px-3 py-1 rounded-lg text-sm transition-opacity @(hoveredFeature == feat.Id ? "" : "opacity-0")"
                                 style="background:rgba(0,0,0,.6)">
                                <div class="text-xs text-gray-400">@feat.StatsLabel</div>
                                <div class="font-bold" style="color:@feat.IconColor">@feat.StatsValue</div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2 group-hover:text-cyan-400 transition-colors">@feat.Title</h3>
                            <p class="text-gray-400 text-sm mb-4">@feat.Description</p>

                            <!-- Benefits (show 2, all 4 on hover) -->
                            <div class="space-y-2">
                                @foreach (var benefit in feat.Benefits.Take(hoveredFeature == feat.Id ? 4 : 2))
                                {
                                    <div class="flex items-center gap-2 text-sm text-gray-300">
                                        <i class="fas fa-check-circle flex-shrink-0" style="color:@feat.IconColor"></i>
                                        <span>@benefit</span>
                                    </div>
                                }
                            </div>

                            @if (hoveredFeature == feat.Id)
                            {
                                <button class="mt-4 w-full py-2 rounded-lg font-semibold transition-all flex items-center justify-center gap-2 text-cyan-400 fade-up"
                                        style="background:rgba(6,182,212,.2)">
                                    Learn More <i class="fas fa-arrow-right"></i>
                                </button>
                            }
                        </div>

                        <!-- Hover Glow -->
                        <div class="absolute -inset-1 blur-xl transition-all duration-500 -z-10 @(hoveredFeature == feat.Id ? "opacity-100" : "opacity-0")"
                             style="background:@feat.GlowBg"></div>
                    </div>
                }
            </div>
        </div>

        <!-- ===== HOW IT WORKS ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-20">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    How It <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Works</span>
                </h2>
                <p class="text-xl text-gray-400">Get started in 4 simple steps</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                @foreach (var (step, idx) in howItWorks.Select((s, i) => (s, i)))
                {
                    <div class="relative text-center fade-up" style="animation-delay:@(idx * 0.2)s">
                        @if (idx < howItWorks.Count - 1)
                        {
                            <div class="hidden md:block absolute top-16 left-1/2 w-full h-0.5"
                                 style="background:linear-gradient(to right,rgba(6,182,212,.5),transparent)"></div>
                        }

                        <div class="relative z-10 w-32 h-32 mx-auto mb-6 rounded-full flex items-center justify-center hover:scale-110 transition-transform"
                             style="background:@step.CircleBg;border:2px solid @step.CircleBorder">
                            <div class="absolute inset-2 rounded-full" style="background:#0a0a0a"></div>
                            <i class="fas fa-@(step.Icon) text-5xl relative z-10" style="color:@step.IconColor"></i>
                            <div class="absolute -top-2 -right-2 w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg"
                                 style="background:@step.BadgeBg">
                                @step.Step
                            </div>
                        </div>

                        <h3 class="text-xl font-bold mb-2">@step.Title</h3>
                        <p class="text-gray-400">@step.Description</p>
                    </div>
                }
            </div>
        </div>

        <!-- ===== INTEGRATIONS ===== -->
        <div class="max-w-7xl mx-auto px-6 mb-20">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    Seamless <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Integrations</span>
                </h2>
                <p class="text-xl text-gray-400">Connect with tools you already use</p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4">
                @foreach (var (intg, idx) in integrations.Select((x, i) => (x, i)))
                {
                    <div class="backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:bg-white/[0.05] transition-all hover:-translate-y-2 group fade-up text-center"
                         style="background:rgba(255,255,255,.03);animation-delay:@(idx * 0.1)s">
                        <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">@intg.Logo</div>
                        <div class="text-sm font-semibold text-gray-400 group-hover:text-white transition-colors">@intg.Name</div>
                    </div>
                }
            </div>
        </div>

        <!-- ===== FINAL CTA ===== -->
        <div class="max-w-5xl mx-auto px-6">
            <div class="relative border border-cyan-500/30 rounded-3xl p-12 text-center overflow-hidden"
                 style="background:linear-gradient(135deg,rgba(6,182,212,.1),rgba(168,85,247,.1))">
                <div class="absolute inset-0 opacity-10">
                    <div class="absolute top-0 left-0 w-40 h-40 bg-cyan-500 rounded-full blur-3xl"></div>
                    <div class="absolute bottom-0 right-0 w-40 h-40 bg-purple-500 rounded-full blur-3xl"></div>
                </div>
                <div class="relative z-10">
                    <i class="fas fa-rocket text-6xl text-cyan-400 mb-6 block animate-pulse"></i>
                    <h2 class="text-4xl md:text-5xl font-bold mb-4">Ready to Transform Your Business?</h2>
                    <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
                        Join 10,000+ successful landlords using STAYTRUST features to grow their property business
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="/landlord/prime"
                           class="px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 rounded-xl font-bold text-lg transition-all hover:scale-105 inline-flex items-center justify-center gap-2"
                           style="box-shadow:0 0 30px rgba(6,182,212,.3)">
                            Get Started Now <i class="fas fa-arrow-right"></i>
                        </a>
                        <button class="px-8 py-4 hover:bg-white/10 border border-white/20 rounded-xl font-bold text-lg transition-all inline-flex items-center justify-center gap-2"
                                style="background:rgba(255,255,255,.05)">
                            <i class="fas fa-play"></i> Watch Demo
                        </button>
                    </div>
                    <div class="mt-8 text-sm text-gray-400">
                        <i class="fas fa-check-circle text-green-400 mr-2"></i>
                        Free 15-day trial • No credit card required • Cancel anytime
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private string selectedCategory = "all";
    private int? hoveredFeature = null;
    private int activeDemo = 0;
    private System.Threading.Timer? _demoTimer;

    protected override void OnInitialized()
    {
        _demoTimer = new System.Threading.Timer(_ =>
        {
            activeDemo = (activeDemo + 1) % demoScreens.Count;
            InvokeAsync(StateHasChanged);
        }, null, 5000, 5000);
    }

    public async ValueTask DisposeAsync()
    {
        if (_demoTimer != null)
            await _demoTimer.DisposeAsync();
    }

    // ── Categories ───────────────────────────────────────────────────────────
    private readonly List<Category> categories = new()
    {
        new("all",        "All Features",         "star",      9),
        new("management", "Property Management",  "building",  3),
        new("analytics",  "Analytics & Reports",  "chart-bar", 3),
        new("automation", "Automation",           "robot",     3),
        new("payment",    "Payments",             "credit-card", 0),
    };

    // ── Features ─────────────────────────────────────────────────────────────
    private readonly List<FeatureItem> allFeatures = new()
    {
        new(1,"management","home","Unlimited Listings",
