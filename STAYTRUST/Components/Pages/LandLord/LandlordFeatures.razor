    private List<FeatureItem> FilteredFeatures() =>
        selectedCategory == "all" ? allFeatures : allFeatures.Where(f => f.Category == selectedCategory).ToList();

    // ── Demo Carousel ─────────────────────────────────────────────────────────
    private readonly List<DemoScreen> demoScreens = new()
    {
        new("Dashboard Overview",   "Get a bird's eye view of all your properties, revenue, and key metrics",
            "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&h=700&fit=crop&q=90"),
