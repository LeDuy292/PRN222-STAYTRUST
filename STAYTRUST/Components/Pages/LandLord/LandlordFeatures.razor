            "Avg. listing time","2 min",
            new(){"Unlimited properties","HD photos & videos","3D virtual tours","Floor plans"}),
        new(2,"management","map-marked-alt","Interactive Maps",
            "Show exact location with nearby amenities. Integrated with Google Maps for easy navigation.",
