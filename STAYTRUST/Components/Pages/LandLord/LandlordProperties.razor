@page "/landlord/properties"
@rendermode InteractiveServer
@* @attribute [Authorize] *@
@using System.Text.Json
@using STAYTRUST.Models.DTOs
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>Properties - STAYTRUST</PageTitle>

<HeadContent>
    <style>
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .prop-card { animation: fadeInUp 0.5s ease-out both; }
        
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            animation: fadeInUp 0.3s ease-out;
        }
        
        .modal-content {
            background: rgba(30, 41, 59, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1.25rem;
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            backdrop-filter: blur(10px);
        }
        
        .modal-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #f1f5f9;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        
        .modal-message {
            color: #cbd5e1;
            margin-bottom: 2rem;
            line-height: 1.6;
        }
        
        .modal-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
        }
        
        .btn-modal {
            padding: 0.875rem 1.75rem;
            border-radius: 0.75rem;
            border: none;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .btn-modal:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .btn-secondary-modal {
            background: rgba(255, 255, 255, 0.08);
            color: #cbd5e1;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }
        
        .btn-secondary-modal:hover:not(:disabled) {
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(255, 255, 255, 0.25);
            color: #f1f5f9;
        }
        
        .btn-danger-modal {
            background: rgba(239, 68, 68, 0.1);
            color: #fecaca;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        
        .btn-danger-modal:hover:not(:disabled) {
            background: rgba(239, 68, 68, 0.2);
            border-color: rgba(239, 68, 68, 0.5);
        }
    </style>
</HeadContent>

<div class="min-h-screen text-white" style="background-color:#0a0a0a">

    <!-- Mesh Gradient Background -->
    <div class="fixed inset-0 -z-10">
        <div class="absolute inset-0"
             style="background:radial-gradient(at 0% 0%,rgba(19,91,236,.15) 0,transparent 50%),radial-gradient(at 100% 100%,rgba(19,91,236,.1) 0,transparent 50%),radial-gradient(at 50% 50%,rgba(10,10,10,1) 0,transparent 100%)">
        </div>
    </div>

    <!-- ========== HEADER ========== -->
    <HeaderLandlord />

    <!-- ========== MAIN CONTENT ========== -->
    <div class="pt-24 px-6 pb-12">
        <div class="max-w-7xl mx-auto">

            <!-- Page Header -->
            <div class="mb-8">
                <h1 class="text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
                    Properties Management
                </h1>
                <p class="text-gray-400 text-lg">Manage and monitor all your rental properties</p>
            </div>

            <!-- ========== STATS CARDS ========== -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                @foreach (var stat in summaryStats)
                {
                    <div class="relative backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:bg-white/[0.05] transition-all duration-300 hover:-translate-y-1 group overflow-hidden"
                         style="background:rgba(255,255,255,.03)">
                        <div class="absolute top-0 right-0 w-20 h-20 rounded-full blur-3xl group-hover:w-32 group-hover:h-32 transition-all duration-500"
                             style="background:@(stat.GlowColor)"></div>
                        <div class="relative z-10">
                            <div class="text-gray-400 text-sm mb-2">@stat.Label</div>
                            <div class="flex items-end justify-between">
                                <div class="text-3xl font-bold" style="color:@(stat.ValueColor)">@stat.Value</div>
                                <div class="text-sm font-semibold @(stat.Change.StartsWith("+") ? "text-green-400" : "text-gray-400")">@stat.Change</div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- ========== SEARCH & FILTER BAR ========== -->
            <div class="backdrop-blur-xl border border-white/10 rounded-2xl p-6 mb-8"
                 style="background:rgba(255,255,255,.03);box-shadow:0 8px 32px 0 rgba(0,0,0,.37)">
                <div class="flex flex-col md:flex-row gap-4 items-center justify-between">

                    <!-- Search -->
                    <div class="relative flex-1 w-full">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
                        <input type="text"
                               placeholder="Search properties by name or location..."
                               @bind="searchTerm" @bind:event="oninput"
                               class="w-full border border-white/10 rounded-xl pl-12 pr-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500/50 transition-colors"
                               style="background:rgba(255,255,255,.05);color:white" />
                    </div>

                    <div class="flex gap-3 items-center">

                        <!-- Status Filter -->
                        <div class="relative">
                            <button @onclick="() => showFilterMenu = !showFilterMenu"
                                    class="flex items-center gap-2 px-4 py-3 border border-white/10 rounded-xl transition-colors hover:bg-white/10"
                                    style="background:rgba(255,255,255,.05)">
                                <i class="fas fa-filter text-cyan-400"></i>
                                <span class="hidden md:inline">Filter</span>
                                <i class="fas fa-chevron-down text-xs"></i>
                            </button>
                            @if (showFilterMenu)
                            {
                                <div class="absolute right-0 mt-2 w-48 bg-gray-900/95 backdrop-blur-xl rounded-xl border border-gray-700/50 shadow-2xl overflow-hidden z-10">
                                    @foreach (var s in new[] { "all", "available", "occupied", "maintenance" })
                                    {
                                        <button @onclick="() => { selectedStatus = s; showFilterMenu = false; }"
                                                class="w-full text-left px-4 py-3 hover:bg-white/5 transition-colors capitalize @(selectedStatus == s ? "text-cyan-400" : "")"
                                                style="@(selectedStatus == s ? "background:rgba(255,255,255,.05)" : "")">
                                            @s
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <!-- View Mode Toggle -->
                        <div class="flex gap-2 rounded-xl p-1 border border-white/10" style="background:rgba(255,255,255,.05)">
                            <button @onclick='() => viewMode = "grid"'
                                    class="p-2 rounded-lg transition-all @(viewMode == "grid" ? "text-cyan-400" : "text-gray-400 hover:text-white")"
                                    style="@(viewMode == "grid" ? "background:rgba(6,182,212,.2)" : "")">
                                <i class="fas fa-th-large"></i>
                            </button>
                            <button @onclick='() => viewMode = "list"'
                                    class="p-2 rounded-lg transition-all @(viewMode == "list" ? "text-cyan-400" : "text-gray-400 hover:text-white")"
                                    style="@(viewMode == "list" ? "background:rgba(6,182,212,.2)" : "")">
                                <i class="fas fa-list"></i>
                            </button>
                        </div>

                        <!-- Add Property -->
                        <button @onclick='() => Nav.NavigateTo("/landlord/post-room")'
                                class="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 rounded-xl font-semibold transition-all hover:scale-105"
                                style="box-shadow:0 0 20px rgba(6,182,212,.3)">
                            <i class="fas fa-plus"></i>
                            <span class="hidden md:inline">Add Property</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- ========== PROPERTIES GRID / LIST ========== -->
            @if (isLoading)
            {
                <!-- Loading State -->
                <div class="flex items-center justify-center py-20">
                    <div class="text-center">
                        <div class="w-16 h-16 mx-auto mb-6 rounded-full flex items-center justify-center animate-spin"
                             style="background:rgba(6,182,212,.2);border:2px solid rgba(6,182,212,.1);border-top-color:rgba(6,182,212,.5)">
                            <i class="fas fa-spinner-third"></i>
                        </div>
                        <p class="text-gray-400 text-lg">Loading properties...</p>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <!-- Error State -->
                <div class="backdrop-blur-xl border border-red-500/30 rounded-2xl p-8 text-center" style="background:rgba(239,68,68,.1)">
                    <div class="w-16 h-16 mx-auto mb-6 rounded-full flex items-center justify-center" style="background:rgba(239,68,68,.2)">
                        <i class="fas fa-exclamation-circle text-3xl text-red-400"></i>
                    </div>
                    <h3 class="text-2xl font-bold mb-2 text-red-400">Error Loading Properties</h3>
                    <p class="text-gray-400 mb-6">@errorMessage</p>
                    <button @onclick="LoadData" class="px-6 py-3 bg-cyan-500 hover:bg-cyan-600 rounded-xl font-semibold transition-all">
                        <i class="fas fa-redo mr-2"></i>Try Again
                    </button>
                </div>
            }
            else
            {
                var filtered = FilteredProperties();
                @if (filtered.Count == 0)
            {
                <!-- Empty State -->
                <div class="text-center py-20">
                    <div class="w-24 h-24 mx-auto mb-6 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,.05)">
                        <i class="fas fa-home text-5xl text-gray-600"></i>
                    </div>
                    <h3 class="text-2xl font-bold mb-2 text-gray-400">No properties found</h3>
                    <p class="text-gray-500 mb-6">Try adjusting your search or filters</p>
                    <button @onclick='() => Nav.NavigateTo("/landlord/post-room")'
                            class="px-6 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl font-semibold hover:scale-105 transition-all">
                        Add Your First Property
                    </button>
                </div>
            }
            else
            {
                <div class="@(viewMode == "grid" ? "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" : "space-y-6")">
                    @foreach (var (prop, idx) in filtered.Select((p, i) => (p, i)))
                    {
                        <div class="prop-card group relative backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden hover:bg-white/[0.05] transition-all duration-500 hover:-translate-y-2 @(viewMode == "list" ? "flex gap-0" : "")"
                             style="background:rgba(255,255,255,.03);animation-delay:@(idx * 0.1)s;box-shadow:0 0 0 0 rgba(6,182,212,0)">

                            <!-- Featured Badge -->
                            @if (prop.Featured)
                            {
                                <div class="absolute top-4 left-4 z-20 flex items-center gap-2 px-3 py-1 bg-gradient-to-r from-yellow-500/90 to-orange-500/90 backdrop-blur-sm rounded-full text-xs font-bold">
                                    <i class="fas fa-star text-white"></i>
                                    <span>FEATURED</span>
                                </div>
                            }

                            <!-- Image -->
                            <div class="relative @(viewMode == "list" ? "w-72 flex-shrink-0" : "h-64") overflow-hidden">
                                <img src="@(prop.Images?.FirstOrDefault() ?? "https://via.placeholder.com/400x300?text=No+Image")" alt="@prop.Title"
                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />

                                <!-- Hover Overlay -->
                                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                    <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-4 group-hover:translate-x-0">
                                        <button class="p-2 backdrop-blur-md hover:bg-white/30 rounded-lg transition-colors" style="background:rgba(255,255,255,.2)">
                                            <i class="fas fa-heart text-white"></i>
                                        </button>
                                        <button class="p-2 backdrop-blur-md hover:bg-white/30 rounded-lg transition-colors" style="background:rgba(255,255,255,.2)">
                                            <i class="fas fa-share text-white"></i>
                                        </button>
                                    </div>
                                    <div class="absolute bottom-4 right-4 flex items-center gap-2 px-3 py-1 rounded-lg text-sm" style="background:rgba(0,0,0,.6)">
                                        <i class="fas fa-camera"></i>
                                        <span>@(prop.Images?.Count ?? 0) photos</span>
                                    </div>
                                </div>

                                <!-- Status Badge -->
                                <div class="absolute top-4 right-4 flex items-center gap-2 px-3 py-1 backdrop-blur-md rounded-full text-xs font-semibold border"
                                     style="@GetStatusStyle(prop.Status)">
                                    <i class="fas fa-@(GetStatusIcon(prop.Status))"></i>
                                    <span class="capitalize">@prop.Status</span>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="p-6 flex-1">
                                <!-- Title & Rating -->
                                <div class="mb-3">
                                    <h3 class="text-xl font-bold mb-2 text-white group-hover:text-cyan-400 transition-colors">@prop.Title</h3>
                                    <div class="flex items-center gap-4 text-sm text-gray-400">
                                        <div class="flex items-center gap-1">
                                            <i class="fas fa-star text-yellow-400"></i>
                                            <span class="font-semibold text-white">@prop.Rating</span>
                                            <span>(@prop.Reviews)</span>
                                        </div>
                                        <div class="flex items-center gap-1">
                                            <i class="fas fa-eye text-cyan-400"></i>
                                            <span>@prop.Views views</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Address -->
                                <div class="flex items-start gap-2 mb-4 text-gray-400 text-sm">
                                    <i class="fas fa-map-marker-alt mt-1 flex-shrink-0 text-cyan-400"></i>
                                    <span>@prop.Address</span>
                                </div>

                                <!-- Property Details -->
                                <div class="flex items-center gap-6 mb-4 text-sm">
                                    <div class="flex items-center gap-2 text-gray-400">
                                        <i class="fas fa-bed text-cyan-400"></i>
                                        <span>@prop.Bedrooms beds</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-gray-400">
                                        <i class="fas fa-bath text-cyan-400"></i>
                                        <span>@prop.Bathrooms baths</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-gray-400">
                                        <i class="fas fa-ruler-combined text-cyan-400"></i>
                                        <span>@(prop.Area)m²</span>
                                    </div>
                                </div>

                                <!-- Price -->
                                <div class="mb-4">
                                    <div class="text-2xl font-bold text-cyan-400">
                                        ₫@((prop.Price / 1_000_000.0).ToString("F1"))M
                                        <span class="text-sm text-gray-400 font-normal">/month</span>
                                    </div>
                                    <div class="text-xs text-gray-500 mt-1">@prop.Inquiries inquiries this month</div>
                                </div>

                                <!-- Action Buttons -->
                                <div class="flex gap-2 pt-4 border-t border-white/10">
                                    <a href="/landlord/properties/@prop.Id"
                                       class="flex-1 flex items-center justify-center gap-2 px-4 py-2 rounded-lg transition-all hover:scale-105 font-semibold text-cyan-400"
                                       style="background:rgba(6,182,212,.2)">
                                        <i class="fas fa-eye"></i><span>View</span>
                                    </a>
                                    <button @onclick="() => EditProperty(prop.Id)"
                                            class="flex-1 flex items-center justify-center gap-2 px-4 py-2 rounded-lg transition-all hover:scale-105 font-semibold text-blue-400"
                                            style="background:rgba(59,130,246,.2)">
                                        <i class="fas fa-edit"></i><span>Edit</span>
                                    </button>
                                    <button @onclick="() => DeleteProperty(prop.Id)"
                                            class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg transition-all hover:scale-105 text-red-400"
                                            style="background:rgba(239,68,68,.2)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Hover Glow -->
                            <div class="absolute -inset-1 blur-xl transition-all duration-500 -z-10 opacity-0 group-hover:opacity-100"
                                 style="background:linear-gradient(to right,rgba(6,182,212,.15),rgba(59,130,246,.15))"></div>
                        </div>
                    }
                </div>
            }
        }
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    @if (showDeleteConfirm)
    {
        <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-title">
                    <i class="fas fa-exclamation-circle" style="color:#f87171"></i>
                    Delete Property
                </div>
                <div class="modal-message">
                    Are you sure you want to delete this property? This action cannot be undone. All associated data will be permanently removed.
                </div>
                <div class="modal-actions">
                    <button @onclick="() => showDeleteConfirm = false" class="btn-modal btn-secondary-modal">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button @onclick="ConfirmDelete" disabled="@isDeleting" class="btn-modal btn-danger-modal">
                        @if (isDeleting)
                        {
                            <span style="width:1rem;height:1rem;border:2px solid rgba(255,255,255,0.2);border-top-color:#fecaca;border-radius:50%;display:inline-block;animation:spin 0.8s linear infinite;margin-right:0.5rem"></span>
                            <span>Deleting...</span>
                        }
                        else
                        {
                            <span><i class="fas fa-trash"></i> Delete Permanently</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Floating Action Button -->
    <button @onclick='() => Nav.NavigateTo("/landlord/post-room")'
            class="fixed bottom-10 right-10 w-16 h-16 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 rounded-full flex items-center justify-center text-2xl hover:scale-110 transition-all duration-300 z-40 group"
            style="box-shadow:0 20px 40px rgba(6,182,212,.3)">
        <i class="fas fa-plus group-hover:rotate-90 transition-transform duration-300"></i>
    </button>

</div>

@code {
    private bool showFilterMenu = false;
    private string viewMode = "grid";
    private string searchTerm = "";
    private string selectedStatus = "all";
    private bool isLoading = true;
    private string? errorMessage = null;
    private bool showDeleteConfirm = false;
    private bool isDeleting = false;
    private int pendingDeleteId = 0;
    private List<PropertyListDto> properties = new();
    private PropertyStatsDto stats = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        
        try
        {
            await LoadProperties();
            await LoadStats();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadProperties()
    {
        try
        {
            var response = await Http.GetAsync("api/properties/my-properties");
            
            if (response.IsSuccessStatusCode)
            {
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var content = await response.Content.ReadAsStringAsync();
                
                using var doc = JsonDocument.Parse(content);
                var root = doc.RootElement;
                
                if (root.TryGetProperty("data", out var dataElement))
                {
                    var jsonString = dataElement.GetRawText();
                    properties = JsonSerializer.Deserialize<List<PropertyListDto>>(jsonString, options) ?? new();
                }
                else
                {
                    errorMessage = "Unable to load property data from server";
                    properties = new();
                }
            }
            else
            {
                errorMessage = $"Server returned status code {response.StatusCode}";
                properties = new();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading properties: {ex.Message}";
            properties = new();
        }
    }

    private async Task LoadStats()
    {
        try
        {
            var response = await Http.GetAsync("api/properties/stats/my-stats");
            
            if (response.IsSuccessStatusCode)
            {
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var content = await response.Content.ReadAsStringAsync();
                
                using var doc = JsonDocument.Parse(content);
                var root = doc.RootElement;
                
                if (root.TryGetProperty("data", out var dataElement))
                {
                    var jsonString = dataElement.GetRawText();
                    stats = JsonSerializer.Deserialize<PropertyStatsDto>(jsonString, options) ?? new();
                }
                else
                {
                    stats = new();
                }
            }
            else
            {
                stats = new();
            }
        }
        catch (Exception ex)
        {
            stats = new();
        }
    }

    private List<PropertyListDto> FilteredProperties() =>
        properties.Where(p =>
            (string.IsNullOrEmpty(searchTerm) ||
             p.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             p.Address.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            && (selectedStatus == "all" || p.Status.ToLower() == selectedStatus.ToLower()))
        .ToList();

    private IEnumerable<SummaryStatItem> summaryStats => new[]
    {
        new SummaryStatItem("Total Properties", stats.TotalProperties.ToString(),         "rgba(6,182,212,.1)",   "#22d3ee", "+2"),
        new SummaryStatItem("Available",        stats.AvailableProperties.ToString(),     "rgba(34,197,94,.1)",   "#4ade80", "+1"),
        new SummaryStatItem("Occupied",         stats.OccupiedProperties.ToString(),      "rgba(59,130,246,.1)",  "#60a5fa", "0"),
        new SummaryStatItem("Total Views",      (stats.TotalViews / 1000).ToString() + "K", "rgba(168,85,247,.1)",  "#c084fc", "+12%"),
    };

    private static string GetStatusStyle(string status) => status.ToLower() switch
    {
        "available"   => "color:#4ade80;background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.3)",
        "active"      => "color:#4ade80;background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.3)",
        "rented"      => "color:#60a5fa;background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.3)",
        "occupied"    => "color:#60a5fa;background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.3)",
        "maintenance" => "color:#fb923c;background:rgba(249,115,22,.1);border-color:rgba(249,115,22,.3)",
        _             => "color:#9ca3af;background:rgba(107,114,128,.1);border-color:rgba(107,114,128,.3)",
    };

    private static string GetStatusIcon(string status) => status.ToLower() switch
    {
        "available"   => "check-circle",
        "active"      => "check-circle",
        "rented"      => "clock",
        "occupied"    => "clock",
        "maintenance" => "ban",
        _             => "clock",
    };

    private async Task DeleteProperty(int id)
    {
        pendingDeleteId = id;
        showDeleteConfirm = true;
    }
    
    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            var response = await Http.DeleteAsync($"api/listings/{pendingDeleteId}");
            if (response.IsSuccessStatusCode)
            {
                showDeleteConfirm = false;
                await LoadData();
            }
            else
            {
                errorMessage = "Failed to delete property. Please try again.";
                showDeleteConfirm = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting property: {ex.Message}";
            showDeleteConfirm = false;
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void EditProperty(int id) => Nav.NavigateTo($"/landlord/edit-listing/{id}");
    private void ViewProperty(int id) => Nav.NavigateTo($"/landlord/properties/{id}");

    // ── Data Models ────────────────────────────────────────────────────────────
    private record SummaryStatItem(string Label, string Value, string GlowColor, string ValueColor, string Change);
}
