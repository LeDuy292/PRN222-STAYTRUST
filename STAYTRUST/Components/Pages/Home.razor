<a class="text-[#0d141b] text-sm font-semibold leading-normal hover:text-primary transition-colors" href="#">Contact</a>
</div>
<div class="hidden lg:flex gap-3">
    <AuthorizeView>
        <Authorized>
            @{
                var user = context.User;
                var fullName = user.FindFirst("FullName")?.Value ?? user.Identity?.Name ?? "User";
                var role = user.FindFirst("Role")?.Value ?? "Node";
                var initial = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
            }
            <div class="flex items-center gap-4 bg-white/50 backdrop-blur-md rounded-full pl-2 pr-5 py-1.5 border border-white/20 shadow-sm hover:shadow-md transition-all cursor-pointer group">
                <div class="size-8 rounded-full bg-gradient-to-tr from-primary to-blue-400 flex items-center justify-center text-white font-bold text-sm shadow-inner group-hover:scale-105 transition-transform">
                    @initial
                </div>
                <div class="flex flex-col text-left">
                    <span class="text-[#0d141b] text-xs font-bold leading-none">@fullName</span>
                    <span class="text-blue-600 text-[10px] font-black uppercase tracking-wider leading-none mt-1">@role</span>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <a href="/login" class="flex cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-6 bg-transparent hover:bg-slate-100 text-[#0d141b] text-sm font-bold leading-normal transition-colors">
                Sign In
