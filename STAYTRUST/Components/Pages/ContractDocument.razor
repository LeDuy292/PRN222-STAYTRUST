@page "/contract-document/{ContractId:int}"
@using STAYTRUST.Models
@using STAYTRUST.Services
@inject IRentalService RentalService
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Lease Agreement #@ContractId.ToString("D4")</PageTitle>

<style>
    /* Document exclusive print styles */
    body { background-color: white !important; font-family: 'Space Grotesk', sans-serif; }
    
    @@media print {
        #print-btn { display: none !important; }
        .document-overlay { position: static !important; }
        @@page { margin: 1.5cm; }
        body { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; margin: 0; padding: 0; }
        /* Hide layout navbars in print */
        nav, footer, .sidebar { display: none !important; }
    }
</style>

@if (contract == null)
{
    <div class="fixed inset-0 z-[999] bg-white text-black flex items-center justify-center font-black text-2xl tracking-widest uppercase">
        Loading Document Data...
    </div>
}
else
{
    <!-- Container that covers everything in the browser -->
    <div class="fixed inset-0 z-[999] bg-slate-100 overflow-y-auto document-overlay flex justify-center py-10">
        
        <!-- Print Floating Action Button -->
        <div class="fixed top-8 right-12 z-50" id="print-btn">
            <div class="flex gap-4">
                <button @onclick="GoBack" class="bg-white hover:bg-slate-100 text-slate-800 border border-slate-200 font-bold px-6 py-3 rounded-full shadow-lg flex items-center gap-2 transition-transform hover:scale-105">
                    <span class="material-symbols-outlined">close</span> CLOSE
                </button>
                <button @onclick="PrintDocument" class="bg-emerald-500 hover:bg-emerald-600 text-black font-black px-6 py-3 rounded-full shadow-lg flex items-center gap-2 transition-transform hover:scale-105">
                    <span class="material-symbols-outlined">print</span> SAVE / PRINT PDF
                </button>
            </div>
        </div>

        <!-- The Document Paper Page -->
        <div class="bg-white w-full max-w-[210mm] min-h-[297mm] p-16 shadow-2xl rounded-2xl relative text-black leading-relaxed" style="color: #000;">
            <div class="text-center mb-10 border-b-2 border-slate-900 pb-8">
                <div class="flex items-center justify-center gap-3 mb-4 text-emerald-600">
                    <span class="material-symbols-outlined text-5xl">real_estate_agent</span>
                    <span class="text-4xl font-black tracking-tighter">STAYTRUST</span>
                </div>
                <h1 class="text-3xl font-black uppercase tracking-widest text-slate-900 mt-6">Residential Lease Agreement</h1>
                <p class="text-slate-500 mt-2 font-bold tracking-widest uppercase">Protocol ID: #@contract.ContractId.ToString("D4")</p>
            </div>

            <p class="mb-10 text-justify text-base font-medium">
                This Residential Lease Agreement ("Agreement") is formally entered into on <strong>@contract.StartDate?.ToString("MMMM dd, yyyy")</strong>, by and between the Landlord and the Tenant described below. The parties agree to the terms and conditions set forth regarding the rental of the specified property.
            </p>

            <h2 class="text-xl font-black uppercase border-b border-slate-200 pb-2 mb-6 text-slate-800">1. The Parties</h2>
            <div class="grid grid-cols-2 gap-8 mb-10">
                <div class="p-6 border border-slate-300 rounded-xl bg-slate-50/50">
                    <p class="text-xs font-black uppercase tracking-widest text-emerald-600 mb-2">Landlord</p>
                    <p class="text-2xl font-black text-slate-900 mb-2">@contract.Room?.Landlord?.FullName</p>
                    <p class="text-sm text-slate-600 mb-1"><span class="font-bold">Email:</span> @contract.Room?.Landlord?.Email</p>
                    <p class="text-sm text-slate-600"><span class="font-bold">Contact:</span> @contract.Room?.Landlord?.Phone</p>
                </div>
                <div class="p-6 border border-slate-300 rounded-xl bg-slate-50/50">
                    <p class="text-xs font-black uppercase tracking-widest text-blue-600 mb-2">Tenant</p>
                    <p class="text-2xl font-black text-slate-900 mb-2">@contract.Tenant?.FullName</p>
                    <p class="text-sm text-slate-600 mb-1"><span class="font-bold">Email:</span> @contract.Tenant?.Email</p>
                    <p class="text-sm text-slate-600"><span class="font-bold">Contact:</span> @contract.Tenant?.Phone</p>
                </div>
            </div>

            <h2 class="text-xl font-black uppercase border-b border-slate-200 pb-2 mb-6 text-slate-800">2. Property Details</h2>
            <div class="p-6 border border-slate-300 rounded-xl bg-slate-50/50 mb-10">
                <p class="text-2xl font-black text-slate-900 mb-2">@contract.Room?.Title</p>
                <p class="text-slate-700 font-medium flex items-center gap-1 mb-6"><span class="material-symbols-outlined text-sm">location_on</span> @contract.Room?.Address</p>
                <div class="grid grid-cols-2 gap-4 border-t border-slate-200 pt-4">
                    <div>
                        <p class="text-xs font-black tracking-widest text-slate-500 uppercase">Room Specifications</p>
                        <p class="text-base font-bold text-slate-800 mt-1">Area: @contract.Room?.Area <span class="text-xs">m²</span></p>
                    </div>
                    <div>
                        <p class="text-xs font-black tracking-widest text-slate-500 uppercase">Status</p>
                        <p class="text-base font-bold text-slate-800 mt-1">@contract.Status</p>
                    </div>
                </div>
            </div>

            <h2 class="text-xl font-black uppercase border-b border-slate-200 pb-2 mb-6 text-slate-800">3. Term & Financials</h2>
            <div class="grid grid-cols-3 gap-6 mb-10">
                <div>
                    <span class="block text-xs font-black tracking-widest text-slate-500 uppercase mb-1">Lease Start</span>
                    <span class="text-lg font-black text-slate-900">@contract.StartDate?.ToString("MMM dd, yyyy")</span>
                </div>
                <div>
                    <span class="block text-xs font-black tracking-widest text-slate-500 uppercase mb-1">Lease End</span>
                    <span class="text-lg font-black text-slate-900">@(contract.EndDate?.ToString("MMM dd, yyyy") ?? "Indefinite")</span>
                </div>
                <div>
                    <span class="block text-xs font-black tracking-widest text-slate-500 uppercase mb-1">Monthly Rent</span>
                    <span class="text-lg font-black text-emerald-600">@contract.Room?.Price.ToString("N0") <span class="text-sm text-slate-500 font-normal">VND</span></span>
                </div>
                <div class="col-span-3 border-t border-slate-200 pt-4 mt-2">
                    <span class="block text-xs font-black tracking-widest text-slate-500 uppercase mb-1">Security Deposit Held</span>
                    <span class="text-xl font-black text-slate-900">@contract.Deposit?.ToString("N0") <span class="text-sm text-slate-500 font-normal">VND</span></span>
                </div>
            </div>

            <h2 class="text-xl font-black uppercase border-b border-slate-200 pb-2 mb-6 text-slate-800">4. General Provisions</h2>
            <ul class="list-disc pl-6 space-y-4 mb-16 text-base text-slate-700 font-medium text-justify">
                <li><strong>Rent Payments:</strong> The Tenant agrees to pay the Monthly Rent on or before the first day of each respective billing cycle.</li>
                <li><strong>Utilities:</strong> Electricity, Water, and Network services are calculated based on monthly meter readings and billed additionally to the base rent.</li>
                <li><strong>Deposit Policy:</strong> The Security Deposit will be held in escrow and returned within 14 days of lease termination, subject to property inspection for applicable damages.</li>
                <li><strong>Maintenance:</strong> The Tenant shall maintain the property in clean and sanitary condition and adhere to all community noise and waste disposal protocols.</li>
                <li><strong>Subletting:</strong> Subletting the property is strictly prohibited without explicit written consent from the Landlord.</li>
            </ul>

            <div class="grid grid-cols-2 gap-12 mt-16 pt-8 border-t-2 border-slate-900">
                <div class="text-center">
                    <p class="font-bold text-slate-800 mb-20 uppercase tracking-widest text-xs">Landlord Signature</p>
                    <div class="border-b border-slate-400 mx-10"></div>
                    <p class="mt-3 font-black text-lg text-slate-900">@contract.Room?.Landlord?.FullName</p>
                    <p class="text-xs text-slate-500 font-bold mt-1">Date: _______________</p>
                </div>
                <div class="text-center">
                    <p class="font-bold text-slate-800 mb-20 uppercase tracking-widest text-xs">Tenant Signature</p>
                    <div class="border-b border-slate-400 mx-10"></div>
                    <p class="mt-3 font-black text-lg text-slate-900">@contract.Tenant?.FullName</p>
                    <p class="text-xs text-slate-500 font-bold mt-1">Date: _______________</p>
                </div>
            </div>
            
            <div class="mt-20 pt-8 border-t border-slate-200 text-center text-xs text-slate-400 font-black tracking-[0.2em] uppercase flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">verified_user</span> Digitally Verified & Secured by StayTrust Protocol
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int ContractId { get; set; }

    private RentalContract? contract;

    protected override async Task OnInitializedAsync()
    {
        contract = await RentalService.GetRentalContractByIdAsync(ContractId);
    }

    private async Task PrintDocument()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void GoBack()
    {
        Nav.NavigateTo("/my-rentals");
    }
}
