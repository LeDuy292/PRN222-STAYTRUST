@page "/my-reports"
@using STAYTRUST.Models
@using STAYTRUST.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IReportService ReportService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<div class="min-h-screen bg-[#0d141b] py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-10 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <button @onclick="GoBack" class="size-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-slate-400">
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
                <div>
                    <h1 class="text-2xl font-bold text-white">My Reports</h1>
                    <p class="text-slate-400 text-sm">Track the status of your reported issues.</p>
                </div>
            </div>
            <button @onclick="NavigateToReportIssue" class="px-5 py-2.5 bg-primary/10 hover:bg-primary/20 border border-primary/20 text-primary font-bold rounded-xl transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">add</span>
                <span>New Report</span>
            </button>
        </div>

        @if (reports == null)
        {
            <div class="flex flex-col items-center justify-center py-20 gap-4">
                <div class="size-12 border-4 border-white/5 border-t-primary rounded-full animate-spin"></div>
                <p class="text-slate-500 font-medium">Loading your reports...</p>
            </div>
        }
        else if (reports.Count == 0)
        {
            <div class="bg-white/5 border border-white/10 rounded-3xl p-12 text-center backdrop-blur-md">
                <div class="size-20 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-6">
                    <span class="material-symbols-outlined text-slate-400 text-4xl">inventory_2</span>
                </div>
                <h2 class="text-xl font-bold text-white mb-2">No Reports Yet</h2>
                <p class="text-slate-400 mb-8 max-w-sm mx-auto">You haven't submitted any reports yet. If you have an issue with your rental, you can report it here.</p>
                <button @onclick="NavigateToReportIssue" class="px-8 py-3 bg-primary hover:bg-primary/90 text-[#0d141b] font-bold rounded-2xl transition-all shadow-lg shadow-primary/20">
                    Report an Issue
                </button>
            </div>
        }
        else
        {
            <div class="grid gap-4">
                @foreach (var r in reports)
                {
                    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all group">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-start gap-4">
                                <div class="size-12 rounded-xl bg-primary/20 flex items-center justify-center text-primary shrink-0">
                                    <span class="material-symbols-outlined">@(GetIcon(r.ReportType))</span>
                                </div>
                                <div class="space-y-1">
                                    <div class="flex items-center gap-3">
                                        <h3 class="text-lg font-bold text-white">@r.ReportType</h3>
                                        <span class="px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase tracking-wider @GetStatusClass(r.Status)">
                                            @r.Status
                                        </span>
                                    </div>
                                    <p class="text-slate-400 text-sm line-clamp-2">@r.Description</p>
                                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest pt-2">Submitted on @r.CreatedAt?.ToString("MMM dd, yyyy HH:mm")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<Report>? reports;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user != null)
        {
            reports = await ReportService.GetUserReportsAsync(user.UserId);
        }
    }

    private string GetIcon(string? type) => type switch
    {
        "Maintenance" => "build",
        "Billing" => "payments",
        "Noise" => "volume_up",
        "Security" => "security",
        _ => "help_outline"
    };

    private string GetStatusClass(string? status) => status switch
    {
        "Pending" => "bg-yellow-500/20 text-yellow-500 border border-yellow-500/20",
        "In Progress" => "bg-blue-500/20 text-blue-500 border border-blue-500/20",
        "Resolved" => "bg-emerald-500/20 text-emerald-500 border border-emerald-500/20",
        "Closed" => "bg-slate-500/20 text-slate-500 border border-slate-500/20",
        _ => "bg-slate-500/20 text-slate-500 border border-slate-500/20"
    };

    private void GoBack()
    {
        NavigationManager.NavigateTo("/my-rentals");
    }

    private void NavigateToReportIssue()
    {
        NavigationManager.NavigateTo("/report-issue");
    }
}
