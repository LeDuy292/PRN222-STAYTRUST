            <div class="flex items-center justify-between mb-10">
                <h3 class="text-2xl font-black tracking-tighter">Settlement Protocol Details</h3>
                <button @onclick="() => showPaymentModal = false" class="size-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-red-500/10 hover:text-red-500 transition-all">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="space-y-8">
                <div class="p-8 rounded-3xl bg-white/[0.02] border border-white/5 space-y-6">
                    <div class="flex justify-between items-center pb-6 border-b border-white/5">
                        <span class="text-slate-500 font-bold uppercase tracking-widest text-[10px]">Temporal Period</span>
                        <span class="font-black">@selectedInvoice.Month</span>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between text-base">
                            <span class="text-slate-400">Core Space Allocation</span>
                            <span class="font-black">@selectedInvoice.RoomPrice.ToString("N0") <span class="text-[10px] text-slate-500">VND</span></span>
                        </div>
                        <div class="flex justify-between text-base">
                            <span class="text-slate-400">Energy Consumption</span>
                            <span class="font-black">@selectedInvoice.ElectricFee.ToString("N0") <span class="text-[10px] text-slate-500">VND</span></span>
                        </div>
                        <div class="flex justify-between text-base">
                            <span class="text-slate-400">Hydration Resources</span>
                            <span class="font-black">@selectedInvoice.WaterFee.ToString("N0") <span class="text-[10px] text-slate-500">VND</span></span>
                        </div>
                    </div>

                    <div class="pt-8 border-t border-white/10 flex justify-between items-end">
                        <p class="text-sm font-black text-emerald-400 uppercase tracking-widest">Aggregate Total</p>
                        <p class="text-4xl font-black">@selectedInvoice.TotalAmount?.ToString("N0") <span class="text-lg font-normal text-slate-500">VND</span></p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <button @onclick="() => HandlePayment(selectedInvoice)" class="flex-1 bg-emerald-500 py-6 rounded-2xl font-black text-black hover:bg-emerald-400 transform hover:scale-[1.02] transition-all shadow-lg shadow-emerald-500/20 flex items-center justify-center gap-3">
                        <span class="material-symbols-outlined font-black">lock_open</span> INITIALIZE SECURE PAYMENT
                    </button>
                </div>
            </div>
        </div>
    </div>
