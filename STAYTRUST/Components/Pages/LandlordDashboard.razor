@page "/landlord"
@layout STAYTRUST.Components.Layout.LandlordLayout
@using STAYTRUST.Components.Layout

<LandlordHeader />
<div class="flex-1 overflow-y-auto p-8 space-y-8">

<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="bg-surface-dark/40 backdrop-blur-xl border border-primary/10 p-6 rounded-xl flex flex-col justify-between">
<div class="flex items-center justify-between mb-4">
<span class="text-slate-400 text-sm font-medium">Total Revenue</span>
<div class="size-8 bg-primary/20 rounded-lg flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-sm">trending_up</span>
</div>
</div>
<div class="space-y-1">
<p class="text-3xl font-black text-slate-100 tracking-tight">$45,280.00</p>
<p class="text-primary text-sm font-medium flex items-center gap-1">
<span class="material-symbols-outlined text-[16px]">expand_less</span>
                                +12.5% from last month
                            </p>
</div>
</div>
<div class="bg-surface-dark/40 backdrop-blur-xl border border-primary/10 p-6 rounded-xl flex flex-col justify-between">
<div class="flex items-center justify-between mb-4">
<span class="text-slate-400 text-sm font-medium">Occupancy Rate</span>
<div class="size-8 bg-primary/20 rounded-lg flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-sm">home</span>
</div>
</div>
<div class="space-y-1">
<p class="text-3xl font-black text-slate-100 tracking-tight">94.2%</p>
<p class="text-primary text-sm font-medium flex items-center gap-1">
<span class="material-symbols-outlined text-[16px]">expand_less</span>
                                +0.8% portfolio growth
                            </p>
</div>
</div>
<div class="bg-surface-dark/40 backdrop-blur-xl border border-primary/10 p-6 rounded-xl flex flex-col justify-between">
<div class="flex items-center justify-between mb-4">
<span class="text-slate-400 text-sm font-medium">Pending Requests</span>
<div class="size-8 bg-red-500/20 rounded-lg flex items-center justify-center text-red-500">
<span class="material-symbols-outlined text-sm">engineering</span>
</div>
</div>
<div class="space-y-1">
<p class="text-3xl font-black text-slate-100 tracking-tight">12</p>
<p class="text-slate-500 text-sm font-medium flex items-center gap-1">
<span class="material-symbols-outlined text-[16px]">schedule</span>
                                4 critical priority
                            </p>
</div>
</div>
</div>
<!-- Activity Feed and Charts -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
<!-- Recent Activity -->
<div class="lg:col-span-2 bg-surface-dark/40 backdrop-blur-xl border border-primary/10 rounded-xl overflow-hidden flex flex-col">
<div class="p-6 border-b border-primary/10 flex items-center justify-between">
<h3 class="text-lg font-bold text-slate-100">Recent Activity</h3>
<button class="text-primary text-sm font-semibold hover:underline">View All History</button>
</div>
<div class="p-0">
<div class="divide-y divide-primary/5">
<div class="px-6 py-4 flex items-center gap-4 hover:bg-primary/5 transition-colors group">
<div class="size-10 rounded-full bg-primary/10 flex items-center justify-center border border-primary/20 shrink-0">
<span class="material-symbols-outlined text-primary text-[20px]">payments</span>
</div>
<div class="flex-1 min-w-0">
<p class="text-sm font-medium text-slate-100">Rent Payment Received</p>
<p class="text-xs text-slate-500">Unit 4B - Oak Ridge Apartments</p>
</div>
<div class="text-right">
<p class="text-sm font-bold text-primary">+$2,450.00</p>
<p class="text-[10px] text-slate-500 uppercase tracking-tighter">2 mins ago</p>
</div>
</div>
<div class="px-6 py-4 flex items-center gap-4 hover:bg-primary/5 transition-colors group">
<div class="size-10 rounded-full bg-orange-500/10 flex items-center justify-center border border-orange-500/20 shrink-0">
<span class="material-symbols-outlined text-orange-500 text-[20px]">warning</span>
</div>
<div class="flex-1 min-w-0">
<p class="text-sm font-medium text-slate-100">Maintenance Request Created</p>
<p class="text-xs text-slate-500">Plumbing issue reported by Tenant #2041</p>
</div>
<div class="text-right">
<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-orange-500/20 text-orange-500 uppercase">Urgent</span>
<p class="text-[10px] text-slate-500 uppercase tracking-tighter mt-1">1 hour ago</p>
</div>
</div>
<div class="px-6 py-4 flex items-center gap-4 hover:bg-primary/5 transition-colors group">
<div class="size-10 rounded-full bg-blue-500/10 flex items-center justify-center border border-blue-500/20 shrink-0">
<span class="material-symbols-outlined text-blue-500 text-[20px]">person_add</span>
</div>
<div class="flex-1 min-w-0">
<p class="text-sm font-medium text-slate-100">New Lease Agreement Signed</p>
<p class="text-xs text-slate-500">Maplewood Estate - Sarah Jennings</p>
</div>
<div class="text-right">
<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-blue-500/20 text-blue-500 uppercase">Pending Review</span>
<p class="text-[10px] text-slate-500 uppercase tracking-tighter mt-1">4 hours ago</p>
</div>
</div>
<div class="px-6 py-4 flex items-center gap-4 hover:bg-primary/5 transition-colors group">
<div class="size-10 rounded-full bg-primary/10 flex items-center justify-center border border-primary/20 shrink-0">
<span class="material-symbols-outlined text-primary text-[20px]">done_all</span>
</div>
<div class="flex-1 min-w-0">
<p class="text-sm font-medium text-slate-100">Property Inspection Completed</p>
<p class="text-xs text-slate-500">The Vista Condos - Q3 Routine Check</p>
</div>
<div class="text-right">
<span class="material-symbols-outlined text-primary text-sm">verified</span>
<p class="text-[10px] text-slate-500 uppercase tracking-tighter">Yesterday</p>
</div>
</div>
</div>
</div>
</div>



<!-- Portfolio Health -->
<div class="bg-surface-dark/40 backdrop-blur-xl border border-primary/10 rounded-xl p-6 flex flex-col">
<h3 class="text-lg font-bold text-slate-100 mb-6">Portfolio Distribution</h3>
<div class="flex-1 flex flex-col justify-center items-center space-y-6">
<!-- Simple Visual Distribution Representation -->
<div class="relative size-48">
<svg class="size-full" viewbox="0 0 36 36">
<path class="stroke-primary/10" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke-width="4"></path>
<path class="stroke-primary" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke-dasharray="75, 100" stroke-linecap="round" stroke-width="4"></path>
</svg>
<div class="absolute inset-0 flex flex-col items-center justify-center">
<p class="text-2xl font-black text-slate-100">75%</p>
<p class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Efficiency</p>
</div>
</div>
<div class="w-full space-y-3">
<div class="flex items-center justify-between">
<div class="flex items-center gap-2">
<span class="size-2 rounded-full bg-primary"></span>
<span class="text-xs text-slate-400">Residential</span>
</div>
<span class="text-xs font-bold text-slate-100">64%</span>
</div>
<div class="flex items-center justify-between">
<div class="flex items-center gap-2">
<span class="size-2 rounded-full bg-blue-400"></span>
<span class="text-xs text-slate-400">Commercial</span>
</div>
<span class="text-xs font-bold text-slate-100">22%</span>
</div>
<div class="flex items-center justify-between">
<div class="flex items-center gap-2">
<span class="size-2 rounded-full bg-orange-400"></span>
<span class="text-xs text-slate-400">Industrial</span>
</div>
<span class="text-xs font-bold text-slate-100">14%</span>
</div>
</div>
<button class="w-full py-3 bg-primary/10 border border-primary/20 rounded-xl text-primary text-sm font-bold hover:bg-primary/20 transition-colors">
                                Generate Insight Report
                            </button>
</div>
</div>
</div>
<!-- Featured Property Card Section -->
<div class="bg-surface-dark/20 border border-primary/10 rounded-xl overflow-hidden group">
<div class="flex flex-col md:flex-row h-full">
<div class="md:w-1/3 relative h-64 md:h-auto overflow-hidden">
<img class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" data-alt="Modern high-end real estate facade" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDPJyp1wKg4jqxk_uOgRgGekOF4uD9GIrUeiZa-2Bqm_AphixNdnz4y-9SfQ86qUEUcmrYmMSJWqIOocPU5Yn5KIusNbkuBg2RTzHiPJ9jgoKgYjjJY3PeWri1P3HUZLExREzVWuoyJifbX21rEZwOyDsDtxiyZTOxYNvvmWfuDOa4LTa-2FOjgY5HM4IYlwgvWac9EW-kK_KE0jePPmRzxrf6pA54f0bCm2M8gbtJDTaRrbAjTWMEjlBgsEnUFDkISMAbHHULOZ5g"/>
<div class="absolute top-4 left-4">
<span class="bg-primary/90 text-background-dark px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">Active Asset</span>
</div>
</div>
<div class="flex-1 p-8">
<div class="flex justify-between items-start mb-4">
<div>
<h4 class="text-2xl font-bold text-slate-100">Azure Heights Condos</h4>
<p class="text-slate-400 flex items-center gap-1">
<span class="material-symbols-outlined text-sm">location_on</span>
                                        1024 Emerald Way, San Francisco, CA
                                    </p>
</div>
<div class="text-right">
<p class="text-xs text-slate-500 uppercase font-bold tracking-widest mb-1">Portfolio Value</p>
<p class="text-2xl font-black text-primary">$1.2M</p>
</div>
</div>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
<div class="bg-primary/5 rounded-xl p-4 border border-primary/10">
<p class="text-[10px] text-slate-500 uppercase font-bold mb-1">Tenants</p>
<p class="text-lg font-bold text-slate-100">12 / 12</p>
</div>
<div class="bg-primary/5 rounded-xl p-4 border border-primary/10">
<p class="text-[10px] text-slate-500 uppercase font-bold mb-1">Maintenance</p>
<p class="text-lg font-bold text-slate-100">0 Open</p>
</div>
<div class="bg-primary/5 rounded-xl p-4 border border-primary/10">
<p class="text-[10px] text-slate-500 uppercase font-bold mb-1">ROI</p>
<p class="text-lg font-bold text-primary">8.4%</p>
</div>
<div class="bg-primary/5 rounded-xl p-4 border border-primary/10">
<p class="text-[10px] text-slate-500 uppercase font-bold mb-1">Compliance</p>
<p class="text-lg font-bold text-slate-100">100%</p>
</div>
</div>
<div class="flex gap-4">
<button class="px-6 py-2 bg-primary rounded-xl text-background-dark font-bold hover:brightness-110 transition-all">Manage Property</button>
<button class="px-6 py-2 bg-surface-dark rounded-xl text-slate-300 font-bold border border-primary/10 hover:bg-primary/10 transition-all">View Details</button>
</div>
</div>
</div>
</div>
</div>
