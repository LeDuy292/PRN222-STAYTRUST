@page "/profile"
@using Microsoft.AspNetCore.Components.Authorization
@using STAYTRUST.Models
@using STAYTRUST.Services
@inject IUserService UserService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@rendermode InteractiveServer

<nav class="absolute top-0 left-0 right-0 z-50 w-full px-4 lg:px-40 py-5">
    <div class="glass-panel rounded-xl px-6 py-3 flex items-center justify-between shadow-sm bg-white/10 backdrop-blur-md border border-white/20">
        <Logo />
        <div class="flex items-center gap-6">
            <a href="/" class="text-white text-sm font-semibold hover:text-emerald-400 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">arrow_back</span>
                Back to Home
            </a>
        </div>
    </div>
</nav>

<div class="min-h-screen bg-[#0c1117] pt-32 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
        <div class="mb-10 text-center lg:text-left">
            <h1 class="text-4xl font-black text-white mb-3">Update your <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-400">Information</span></h1>
            <p class="text-slate-400 font-medium">Keep your profile up to date for better coordination with landlords.</p>
        </div>

        @if (isLoading)
        {
            <div class="flex flex-col items-center justify-center py-20 gap-4">
                <div class="size-12 border-4 border-emerald-500/20 border-t-emerald-500 rounded-full animate-spin"></div>
                <p class="text-emerald-400 font-bold animate-pulse">Syncing encrypted data...</p>
            </div>
        }
        else if (user != null)
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Sidebar / Summary -->
                <div class="lg:col-span-1 space-y-6">
                    <div class="bg-white/5 border border-white/10 rounded-3xl p-8 text-center backdrop-blur-xl">
                        <div class="size-24 rounded-full bg-gradient-to-tr from-emerald-500 to-teal-400 mx-auto flex items-center justify-center overflow-hidden text-white text-4xl font-black shadow-lg shadow-emerald-500/20 mb-6">
                            @if (!string.IsNullOrEmpty(model?.AvatarUrl))
                            {
                                <img src="@model.AvatarUrl" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                @(model?.FullName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                            }
                        </div>
                        <h2 class="text-xl font-bold text-white mb-1">@model?.FullName</h2>
                        <p class="text-slate-500 text-sm font-medium mb-4">@user.Email</p>
                        <div class="inline-flex px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest">
                            @user.Role
                        </div>
                    </div>

                    <div class="bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-xl">
                        <h3 class="text-white font-bold text-sm uppercase tracking-widest mb-4 opacity-50">Account Integrity</h3>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3 text-slate-300 text-sm">
                                <span class="material-symbols-outlined text-emerald-500 text-lg">verified</span>
                                Verified Identity
                            </li>
                            <li class="flex items-center gap-3 text-slate-300 text-sm">
                                <span class="material-symbols-outlined text-emerald-500 text-lg">security</span>
                                Secure Encrypted Path
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Main Form -->
                <div class="lg:col-span-2">
                    <div class="bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-xl shadow-2xl">
                        @if (!string.IsNullOrEmpty(statusMessage))
                        {
                            <div class="mb-8 p-4 rounded-2xl @(isError ? "bg-red-500/10 border border-red-500/20 text-red-100" : "bg-emerald-500/10 border border-emerald-500/20 text-emerald-100") flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
                                <span class="material-symbols-outlined @(isError ? "text-red-500" : "text-emerald-500")">
                                    @(isError ? "error" : "check_circle")
                                </span>
                                <span class="text-sm font-semibold">@statusMessage</span>
                            </div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleUpdate" class="space-y-8">
                            <DataAnnotationsValidator />
                            <!-- Section: Personal -->
                            <div>
                                <h3 class="text-emerald-400 font-bold text-xs uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
                                    <span class="size-1.5 rounded-full bg-emerald-400"></span>
                                    Thông Tin Cá Nhân
                                </h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Họ và Tên</label>
                                        <InputText @bind-Value="model.FullName" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm outline-none focus:border-emerald-500/50 transition-all" />
                                        <ValidationMessage For="@(() => model.FullName)" class="text-[11px] text-red-500 mt-1" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Số điện thoại</label>
                                        <InputText @bind-Value="model.Phone" type="tel" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm outline-none focus:border-emerald-500/50 transition-all" />
                                        <ValidationMessage For="@(() => model.Phone)" class="text-[11px] text-red-500 mt-1" />
                                    </div>
                                </div>
                            </div>

                            <!-- Section: Profile -->
                            <div>
                                <h3 class="text-emerald-400 font-bold text-xs uppercase tracking-[0.2em] mb-6 flex items-center gap-3 pt-4">
                                    <span class="size-1.5 rounded-full bg-emerald-400"></span>
                                    Dữ liệu Khác (Tùy chọn)
                                </h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Căn Cước Công Dân</label>
                                        <InputText @bind-Value="model.IdentityNumber" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm outline-none focus:border-emerald-500/50 transition-all" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Giới tính</label>
                                        <InputSelect @bind-Value="model.Gender" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm outline-none focus:border-emerald-500/50 transition-all appearance-none cursor-pointer">
                                            <option value="" class="bg-[#0c1117]">Chọn Giới Tính</option>
                                            <option value="Nam" class="bg-[#0c1117]">Nam</option>
                                            <option value="Nữ" class="bg-[#0c1117]">Nữ</option>
                                            <option value="Other" class="bg-[#0c1117]">Khác</option>
                                        </InputSelect>
                                        <ValidationMessage For="@(() => model.Gender)" class="text-[11px] text-red-500 mt-1" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Ngày sinh</label>
                                        <InputDate @bind-Value="model.DateOfBirth" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm outline-none focus:border-emerald-500/50 transition-all" />
                                        <ValidationMessage For="@(() => model.DateOfBirth)" class="text-[11px] text-red-500 mt-1" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Ảnh Đại Diện (JPG/PNG)</label>
                                        <InputFile OnChange="HandleImageUpload" accept=".jpg,.jpeg,.png" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3 text-white text-sm outline-none focus:border-emerald-500/50 transition-all file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-emerald-500/10 file:text-emerald-400 hover:file:bg-emerald-500/20 cursor-pointer" />
                                        @if (!string.IsNullOrEmpty(imageErrorMessage))
                                        {
                                            <p class="text-[11px] text-red-500 mt-1 flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">error</span> @imageErrorMessage</p>
                                        }
                                        @if (!string.IsNullOrEmpty(model.AvatarUrl) && model.AvatarFile != null)
                                        {
                                            <p class="text-[11px] text-emerald-400 mt-1 flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">check_circle</span> Đã định kèm ảnh hợp lệ.</p>
                                        }
                                    </div>
                                </div>
                                <div class="space-y-2 mt-6">
                                    <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">Địa chỉ thường trú</label>
                                    <InputTextArea @bind-Value="model.Address" class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white text-sm outline-none focus:border-emerald-500/50 transition-all min-h-[100px]" placeholder="Nhập địa chỉ của bạn..."></InputTextArea>
                                    <ValidationMessage For="@(() => model.Address)" class="text-[11px] text-red-500 mt-1" />
                                </div>
                            </div>

                            <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-teal-400 hover:from-emerald-400 hover:to-teal-300 text-[#0c1117] font-black py-4.5 rounded-2xl shadow-lg shadow-emerald-500/20 flex items-center justify-center gap-3 transition-all transform hover:scale-[1.01] active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed group uppercase text-xs tracking-[0.2em]" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <div class="size-4 border-2 border-black/20 border-t-black rounded-full animate-spin"></div>
                                    <span>Đang cập nhật Data...</span>
                                }
                                else
                                {
                                    <span>Lưu thay đổi</span>
                                    <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">database</span>
                                }
                            </button>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="bg-red-500/10 border border-red-500/20 text-red-100 p-8 rounded-3xl text-center">
                <span class="material-symbols-outlined text-4xl text-red-500 mb-4">error</span>
                <h2 class="text-xl font-bold mb-2">Access Denied</h2>
                <p class="text-sm opacity-70 mb-6">We could not identify your secure session. Please try logging in again.</p>
                <a href="/login" class="inline-flex px-8 py-3 bg-red-500 text-white rounded-xl font-bold hover:bg-red-600 transition-colors">Sign In</a>
            </div>
        }
    </div>
</div>

<style>
    /* Premium aesthetics for form controls */
    ::-webkit-calendar-picker-indicator {
        filter: invert(1);
        cursor: pointer;
    }
</style>

@code {
    private User? user;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? statusMessage;
    private bool isError = false;

    private STAYTRUST.Models.DTOs.UpdateProfileDto model = new();
    private string? imageErrorMessage;

    // Handlers
    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        imageErrorMessage = null;
        var file = e.File;
        if (file == null) return;

        if (file.ContentType != "image/jpeg" && file.ContentType != "image/png")
        {
            imageErrorMessage = "Chỉ chấp nhận file định dạng JPG hoặc PNG.";
            return;
        }

        if (file.Size > 2 * 1024 * 1024)
        {
            imageErrorMessage = "Dung lượng ảnh quá lớn. Tối đa 2MB.";
            return;
        }

        model.AvatarFile = file;
        model.AvatarUrl = file.Name;
        StateHasChanged();
    }

    private async Task<string?> UploadFileToServerAsync(Microsoft.AspNetCore.Components.Forms.IBrowserFile file)
    {
        if (file == null) return null;

        var folderInfo = System.IO.Path.Combine(Env.WebRootPath, "images", "avatars");
        if (!System.IO.Directory.Exists(folderInfo))
        {
            System.IO.Directory.CreateDirectory(folderInfo);
        }

        var extension = System.IO.Path.GetExtension(file.Name);
        var newFileName = $"{System.Guid.NewGuid()}{extension}";
        var absolutePath = System.IO.Path.Combine(folderInfo, newFileName);

        await using var stream = new System.IO.FileStream(absolutePath, System.IO.FileMode.Create);
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(stream);

        return $"/images/avatars/{newFileName}";
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claimsUser = authState.User;

        if (claimsUser.Identity?.IsAuthenticated == true)
        {
            var userIdStr = claimsUser.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value 
                        ?? claimsUser.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value
                        ?? claimsUser.FindFirst("sub")?.Value;

            if (int.TryParse(userIdStr, out int userId))
            {
                user = await UserService.GetUserWithProfileAsync(userId);
                if (user != null)
                {
                    model.FullName = user.FullName ?? user.UserName ?? "";
                    model.Phone = user.Phone ?? "";
                    if (user.UserProfile != null)
                    {
                        model.DateOfBirth = user.UserProfile.DateOfBirth;
                        model.Gender = user.UserProfile.Gender;
                        model.IdentityNumber = user.UserProfile.IdentityNumber;
                        model.Address = user.UserProfile.Address;
                        model.AvatarUrl = user.UserProfile.AvatarUrl;
                    }
                }
            }
        }

        isLoading = false;
    }

    private async Task HandleUpdate()
    {
        if (user == null || isSubmitting) return;

        isSubmitting = true;
        statusMessage = null;
        isError = false;

        if (model.AvatarFile != null)
        {
            var savedPathUrl = await UploadFileToServerAsync(model.AvatarFile);
            if (savedPathUrl != null) 
            {
               model.AvatarUrl = savedPathUrl; 
            }
        }

        var profileUpdate = new STAYTRUST.Models.UserProfile
        {
            UserId = user.UserId,
            DateOfBirth = model.DateOfBirth,
            Gender = model.Gender,
            IdentityNumber = model.IdentityNumber,
            Address = model.Address,
            AvatarUrl = model.AvatarUrl
        };

        var result = await UserService.UpdateUserProfileAsync(user.UserId, model.FullName ?? "", model.Phone ?? "", profileUpdate);

        if (result)
        {
            statusMessage = "Cập nhật thông tin và cập nhật Profile trên Hệ thống thành công.";
            // Subtle delay to show success
            await Task.Delay(1000);
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }
        else
        {
            statusMessage = "Lưu dữ liệu thất bại. Vui lòng thử lại sau.";
            isError = true;
        }

        isSubmitting = false;
    }
}
