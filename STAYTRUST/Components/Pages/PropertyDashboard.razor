@page "/property"
@layout STAYTRUST.Components.Layout.PropertyLayout
@rendermode InteractiveServer

<HeadContent>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="/css/roommates.css" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13ec92",
                        "background-light": "#f6f8f7",
                        "background-dark": "#182e25",
                        "card-dark": "#213c31",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .filled-icon {
            font-variation-settings: 'FILL' 1;
        }
    </style>
</HeadContent>

<!-- Hero Header -->
<div class="flex flex-wrap justify-between items-end gap-4 mb-8 animate-slide-up">
    <div class="flex flex-col gap-1">
        <div class="flex items-center gap-2 mb-2">
            <span class="bg-primary/20 text-primary text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded">Verified Tenant</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-1">Property Dashboard</h1>
        <p class="text-slate-400 max-w-lg text-sm">Unit 402, Green Valley Apartments. Real-time occupancy and security status for your peace of mind.</p>
    </div>
    <div class="flex gap-3">
        <button @onclick="RequestSupport" class="bg-primary text-background-dark px-5 py-2.5 rounded-full font-bold text-sm shadow-[0_0_20px_rgba(19,236,146,0.2)] flex items-center gap-2 hover:brightness-110 transition-all button-pop">
            <span class="material-symbols-outlined text-sm">support_agent</span>
            @supportButtonText
        </button>
    </div>
</div>

<!-- Main Tabs -->
<div class="flex border-b border-primary/10 mb-8 gap-8 transition-all animate-slide-up" style="animation-delay: 0.1s; opacity: 0; animation-fill-mode: forwards;">
    <button @onclick='() => SetTab("overview")' class="@GetTabClass("overview") pb-4 font-bold text-sm flex items-center gap-2 transition-colors">
        <span class="material-symbols-outlined text-sm @(activeTab == "overview" ? "filled-icon" : "")">grid_view</span> Overview
    </button>
    <button @onclick='() => SetTab("sensors")' class="@GetTabClass("sensors") pb-4 font-bold text-sm flex items-center gap-2 transition-colors">
        <span class="material-symbols-outlined text-sm @(activeTab == "sensors" ? "filled-icon" : "")">sensors</span> Sensors
    </button>
    <button @onclick='() => SetTab("payments")' class="@GetTabClass("payments") pb-4 font-bold text-sm flex items-center gap-2 transition-colors">
        <span class="material-symbols-outlined text-sm @(activeTab == "payments" ? "filled-icon" : "")">payments</span> Payments
    </button>
</div>

@if (activeTab == "overview" || activeTab == "sensors")
{
    <!-- Stats Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 transform transition-all animate-slide-up-delayed">
        <div class="bg-card-dark border border-primary/10 p-6 rounded-2xl relative overflow-hidden group hover:border-primary/20 transition-all hover:-translate-y-1 shadow-md hover:shadow-lg hover:shadow-primary/5">
            <div class="absolute -right-4 -top-4 size-24 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all pulse-primary"></div>
            <p class="text-slate-400 text-sm font-medium mb-1">Property Security</p>
            <div class="flex items-center gap-2">
                <p class="text-2xl font-black text-primary">SECURE</p>
                <span class="material-symbols-outlined text-primary filled-icon text-xl">verified_user</span>
            </div>
            <p class="text-xs text-slate-500 mt-2 font-medium">All doors & windows locked</p>
        </div>
        
        <div class="bg-card-dark border border-primary/10 p-6 rounded-2xl hover:border-primary/20 transition-all hover:-translate-y-1 shadow-md hover:shadow-lg hover:shadow-primary/5">
            <p class="text-slate-400 text-sm font-medium mb-1">Payment Status</p>
            <div class="flex items-center gap-2">
                <p class="text-2xl font-black text-white">UP TO DATE</p>
                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
            </div>
            <p class="text-xs text-slate-500 mt-2 font-medium">Next due: Oct 1st (5 days)</p>
        </div>
        
        <div class="bg-card-dark border border-primary/10 p-6 rounded-2xl cursor-pointer hover:border-primary/20 transition-all hover:-translate-y-1 shadow-md hover:shadow-lg hover:shadow-primary/5 group" @onclick="ToggleSensors">
            <p class="text-slate-400 text-sm font-medium mb-1">Active Sensors</p>
            <div class="flex items-center gap-2">
                <p class="text-2xl font-black @(sensorsOnline ? "text-white" : "text-amber-500")">
                    @(sensorsOnline ? "12/12 ONLINE" : "11/12 WARNING")
                </p>
                <span class="material-symbols-outlined @(sensorsOnline ? "text-primary animate-heartbeat" : "text-amber-500") text-xl">cell_tower</span>
            </div>
            <p class="text-xs text-slate-500 mt-2 font-medium">@(sensorsOnline ? "Last ping: just now" : "Kitchen sensor offline")</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-slide-up" style="animation-delay: 0.2s; opacity: 0; animation-fill-mode: forwards;">
        <!-- Visual Map Section -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-card-dark border border-primary/10 rounded-2xl overflow-hidden shadow-lg flex flex-col items-center">
                
                <div class="p-6 pb-2 w-full flex justify-between items-center border-b border-primary/10">
                    <h3 class="font-bold text-lg flex items-center gap-2 text-white">
                        <span class="material-symbols-outlined text-primary">map</span>
                        Live Room Occupancy
                    </h3>
                    <div class="flex items-center gap-4 text-[10px] font-bold uppercase tracking-widest text-white">
                        <span class="flex items-center gap-1 cursor-pointer"><span class="size-2 rounded-full bg-primary border border-primary shadow-[0_0_8px_rgba(19,236,146,0.6)] animate-pulse"></span> Occupied</span>
                        <span class="flex items-center gap-1 cursor-pointer"><span class="size-2 rounded-full bg-slate-500 border border-slate-500"></span> Vacant</span>
                    </div>
                </div>
                
                <div class="p-8 w-full flex justify-center bg-background-dark/40">
                    <!-- Visual Room Map Diagram -->
                    <div class="relative w-full max-w-lg aspect-[1.3] border border-primary/20 bg-background-dark/80 rounded-xl p-2 grid grid-cols-6 grid-rows-4 gap-2 shadow-[inset_0_0_30px_rgba(19,236,146,0.03)] backdrop-blur-sm">
                        
                        <!-- Kitchen -->
                        <div class="col-span-2 row-span-2 border border-primary/10 rounded flex items-center justify-center flex-col bg-card-dark cursor-pointer hover:border-primary/40 transition-all hover:bg-card-dark/80 hover:shadow-md" @onclick='() => ToggleRoom("kitchen")'>
                            <span class="material-symbols-outlined text-slate-400 text-lg mb-1">restaurant</span>
                            <span class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Kitchen</span>
                        </div>
                        
                        <!-- Living Room -->
                        <div class="@GetRoomClass("living") col-span-4 row-span-2 rounded flex items-center justify-center flex-col cursor-pointer transition-all hover:shadow-md" @onclick='() => ToggleRoom("living")'>
                            <span class="material-symbols-outlined @(occupiedRooms.Contains("living") ? "text-primary animate-float" : "text-slate-400") text-2xl mb-1">
                                @(occupiedRooms.Contains("living") ? "person" : "chair")
                            </span>
                            <span class="text-[9px] uppercase font-bold @(occupiedRooms.Contains("living") ? "text-primary" : "text-slate-400") tracking-wider">Living Room</span>
                        </div>
                        
                        <!-- Bathroom -->
                        <div class="col-span-1 row-span-2 border border-primary/10 rounded flex items-center justify-center flex-col bg-card-dark cursor-pointer hover:border-primary/40 transition-all hover:bg-card-dark/80 hover:shadow-md" @onclick='() => ToggleRoom("bath")'>
                            <span class="material-symbols-outlined text-slate-400 text-sm">shower</span>
                        </div>
                        
                        <!-- Master Bedroom -->
                        <div class="@GetRoomClass("master") col-span-3 row-span-2 rounded flex items-center justify-center flex-col cursor-pointer transition-all hover:shadow-md" @onclick='() => ToggleRoom("master")'>
                            <span class="material-symbols-outlined @(occupiedRooms.Contains("master") ? "text-primary animate-float" : "text-slate-400") text-2xl mb-1">
                                @(occupiedRooms.Contains("master") ? "person_outline" : "bed")
                            </span>
                            <span class="text-[9px] uppercase font-bold @(occupiedRooms.Contains("master") ? "text-primary" : "text-slate-400") tracking-wider">Master BR</span>
                        </div>
                        
                        <!-- Guest Bedroom -->
                        <div class="@GetRoomClass("guest") col-span-2 row-span-2 rounded flex items-center justify-center flex-col cursor-pointer transition-all" @onclick='() => ToggleRoom("guest")'>
                            <span class="material-symbols-outlined @(occupiedRooms.Contains("guest") ? "text-primary animate-float" : "text-slate-400") text-lg mb-1">
                                @(occupiedRooms.Contains("guest") ? "person" : "bed")
                            </span>
                            <span class="text-[9px] uppercase font-bold @(occupiedRooms.Contains("guest") ? "text-primary" : "text-slate-400") tracking-wider">Guest BR</span>
                        </div>
                        
                    </div>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div class="flex items-center gap-3 p-4 bg-card-dark rounded-2xl border border-primary/10 cursor-pointer hover:border-primary/20 transition-all shadow-md hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1">
                    <div class="size-10 bg-primary/10 text-primary flex items-center justify-center rounded-full">
                        <span class="material-symbols-outlined">thermostat</span>
                    </div>
                    <div>
                        <p class="text-xs text-slate-400 font-medium">Temperature</p>
                        <p class="font-bold text-white">22.5°C</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 p-4 bg-card-dark rounded-2xl border border-primary/10 cursor-pointer hover:border-primary/20 transition-all shadow-md hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1">
                    <div class="size-10 bg-primary/10 text-primary flex items-center justify-center rounded-full">
                        <span class="material-symbols-outlined text-lg">water_drop</span>
                    </div>
                    <div>
                        <p class="text-xs text-slate-400 font-medium">Humidity</p>
                        <p class="font-bold text-white">45%</p>
                    </div>
                </div>
            </div>
            
        </div>

        <!-- Right Sidebar Section -->
        <div class="space-y-6">
            
            <!-- Roommate Status -->
            <div class="bg-card-dark border border-primary/10 rounded-2xl p-6 shadow-md hover:shadow-lg hover:shadow-primary/5 hover-glow transition-all duration-300">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-white">
                    <span class="material-symbols-outlined text-primary">group</span>
                    Roommate Status
                </h3>
                <div class="space-y-5">
                    
                    <!-- Roommate 1 -->
                    <div class="flex items-center justify-between group cursor-pointer bg-background-dark/40 p-3 rounded-xl border border-transparent hover:border-primary/20 transition-all hover:translate-x-1">
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <div class="size-10 rounded-full bg-cover border border-primary/20 group-hover:border-primary transition-all" data-alt="Avatar of roommate Marcus" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBHQvJ0c5lqQ3bKWnmMsepAy3rqS9fLXiRA4zQ-JybxAZj_66a1GgBRpEMQmEB8MclI7ZeSIf6Qcw976W_YD3HEaRh9hkJfmHU3usfUdMwDQGO8GkFU12r-2zwuzgr4jjGzb8kOC9rlfOw3sLBuswT1kPkDO0aFr716xIxIoTJVkbsPTjIuq3EFuDrhv-493B1AP7W7Sf-Gkvyo1bfIpHVkZex7fBTeEI_X6vF7RMMc7YgZqyWH5kmlYZDhweTr79wZHJhEJLPCjCBD');"></div>
                                <div class="absolute -bottom-0.5 -right-0.5 size-3.5 @(occupiedRooms.Contains("master") ? "bg-primary shadow-[0_0_8px_rgba(19,236,146,0.6)]" : "bg-slate-500") rounded-full border-2 border-background-dark transition-colors"></div>
                            </div>
                            <div>
                                <p class="font-bold text-sm text-white group-hover:text-primary transition-colors">Marcus Chen</p>
                                <p class="text-[11px] @(occupiedRooms.Contains("master") ? "text-primary" : "text-slate-400") font-bold">@(occupiedRooms.Contains("master") ? "At Home" : "Out")</p>
                            </div>
                        </div>
                        <span class="material-symbols-outlined text-slate-500 hover:text-primary transition-colors">chat_bubble</span>
                    </div>
                    
                    <!-- Roommate 2 -->
                    <div class="flex items-center justify-between group cursor-pointer bg-background-dark/40 p-3 rounded-xl border border-transparent hover:border-primary/20 transition-all hover:translate-x-1">
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <div class="size-10 rounded-full bg-cover border border-primary/20 group-hover:border-primary transition-all" data-alt="Avatar of roommate Sarah" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA-NvF4lj9YETj7rENmtxk29bVPkqle5ECKm-jg9D_0QMhUFCNlRB09F6eufb8rwf3IGKJ_psoDQpvbUlAX7yTSFm576vNicJUYx9DSxyi884UZPvnR6K2MEZmvGo8tHH106EFxpv1fP6NdLNPDXyt7o3Yz0aEYpkCWmGgKoCp61otyKo1ZuQx-uB2eeBQLU_Qze_gps19j4OmMpUc5LeO0g8cTa0MhGagWsYXpKJhnnNIwI3oZ5CGSLj1g8gqqwdITc6wgt26wopFk');"></div>
                                <div class="absolute -bottom-0.5 -right-0.5 size-3.5 @(occupiedRooms.Contains("guest") ? "bg-primary shadow-[0_0_8px_rgba(19,236,146,0.6)]" : "bg-slate-500") rounded-full border-2 border-background-dark transition-colors"></div>
                            </div>
                            <div>
                                <p class="font-bold text-sm text-white group-hover:text-primary transition-colors">Sarah Jenkins</p>
                                <p class="text-[11px] @(occupiedRooms.Contains("guest") ? "text-primary" : "text-slate-400") font-bold">@(occupiedRooms.Contains("guest") ? "At Home" : "Out (Since 9AM)")</p>
                            </div>
                        </div>
                        <span class="material-symbols-outlined text-slate-500 hover:text-primary transition-colors">chat_bubble</span>
                    </div>
                    
                </div>
            </div>

            <!-- Sensor Activity Feed -->
            <div class="bg-card-dark border border-primary/10 rounded-2xl p-6 shadow-md hover:shadow-lg hover:shadow-primary/5 hover-glow transition-all duration-300">
                <h3 class="font-bold text-xs uppercase tracking-widest text-slate-400 mb-6 flex items-center justify-between">
                    Recent Activity
                    <span class="material-symbols-outlined text-sm cursor-pointer hover:text-primary hover:animate-spin transition-colors">history</span>
                </h3>
                
                <div class="space-y-5 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[1px] before:bg-primary/10">
                    
                    @foreach (var log in logs)
                    {
                        <div class="flex gap-4 relative justify-between group cursor-pointer bg-background-dark/20 p-2 -mx-2 rounded-lg hover:bg-background-dark/50 transition-colors">
                            <div class="flex gap-4">
                                <div class="size-6 rounded-full @(log.IsPrimary ? "bg-primary/20 text-primary pulse-primary" : "bg-background-dark text-slate-500 border border-primary/10") flex items-center justify-center z-10 group-hover:scale-110 transition-transform">
                                    <span class="material-symbols-outlined text-[14px]">@log.Icon</span>
                                </div>
                                <div class="-mt-0.5">
                                    <p class="text-[13px] font-bold text-white group-hover:text-primary transition-colors leading-tight">@log.Title</p>
                                    <p class="text-[11px] text-slate-400 mt-0.5">@log.Location • @log.Time</p>
                                </div>
                            </div>
                        </div>
                    }
                    
                </div>
                
                <button @onclick="ToggleLogs" class="w-full mt-6 py-2.5 rounded-lg text-xs font-bold hover:bg-primary/5 transition-all @(logsExpanded ? "text-slate-500" : "text-white") border-t border-primary/10 button-pop">
                    @(logsExpanded ? "Show Less" : "View Full Log")
                </button>
            </div>
            
        </div>
    </div>
}
else if (activeTab == "payments")
{
    <div class="bg-card-dark p-12 rounded-2xl text-center max-w-2xl mx-auto mt-10 shadow-lg hover:shadow-primary/5 border border-primary/10 animate-slide-up hover-glow transition-all duration-300">
        <span class="material-symbols-outlined text-6xl text-primary mb-6 animate-heartbeat">payments</span>
        <h2 class="text-3xl font-black text-white mb-4">Payment Center</h2>
        <div class="bg-background-dark rounded-xl p-6 mb-8 border border-primary/10 shadow-md">
            <h3 class="text-sm font-bold text-slate-400 mb-2 uppercase tracking-wide">Current Balance</h3>
            <p class="text-5xl font-black text-primary mb-2">$850.00</p>
            <p class="text-sm font-medium text-slate-500">Rent for October 2024</p>
        </div>
        
        <div class="flex gap-4 justify-center">
            <button class="bg-primary text-background-dark px-8 py-3 rounded-full font-bold flex items-center gap-2 hover:brightness-110 transition-all shadow-[0_0_15px_rgba(19,236,146,0.2)] button-pop">
                <span class="material-symbols-outlined">credit_card</span>
                Pay Now
            </button>
            <button class="bg-background-dark text-white border border-primary/20 px-8 py-3 rounded-full font-bold flex items-center gap-2 hover:bg-primary/10 transition-colors button-pop">
                <span class="material-symbols-outlined">receipt_long</span>
                History
            </button>
        </div>
    </div>
}

@code {
    private string activeTab = "overview";
    private string supportButtonText = "Get Support";
    private bool sensorsOnline = true;
    private bool logsExpanded = false;
    
    // Manage occupied rooms array 
    private HashSet<string> occupiedRooms = new() { "living", "master" };

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private string GetTabClass(string tab)
    {
        if (activeTab == tab)
        {
            return "border-b-[3px] border-primary text-primary";
        }
        return "border-b-[3px] border-transparent text-slate-500 hover:text-primary";
    }

    private async Task RequestSupport()
    {
        supportButtonText = "Request Sent...";
        await Task.Delay(1500);
        supportButtonText = "Get Support";
    }

    private void ToggleSensors()
    {
        sensorsOnline = !sensorsOnline;
    }

    private void ToggleRoom(string roomId)
    {
        if (occupiedRooms.Contains(roomId))
        {
            occupiedRooms.Remove(roomId);
        }
        else
        {
            occupiedRooms.Add(roomId);
        }
    }

    private string GetRoomClass(string roomId)
    {
        string baseClass = "border ";
        
        if (occupiedRooms.Contains(roomId))
        {
            return baseClass + "border-primary/40 bg-primary/5 animate-none shadow-[inset_0_0_20px_rgba(19,236,146,0.05)] transition-all duration-300 ";
        }
        else
        {
            return baseClass + "border-primary/10 bg-background-dark/80 hover:border-primary/40 transition-all duration-300 hover:bg-card-dark/80 ";
        }
    }

    private class ActivityLog
    {
        public string Icon { get; set; } = "";
        public string Title { get; set; } = "";
        public string Location { get; set; } = "";
        public string Time { get; set; } = "";
        public bool IsPrimary { get; set; }
    }

    private List<ActivityLog> defaultLogs = new()
    {
        new ActivityLog { Icon = "motion_sensor_active", Title = "Motion Detected", Location = "Living Room", Time = "2 mins ago", IsPrimary = true },
        new ActivityLog { Icon = "sensor_door", Title = "Main Door Closed", Location = "Entrance", Time = "45 mins ago", IsPrimary = false },
        new ActivityLog { Icon = "water_drop", Title = "Humidity Warning", Location = "Bathroom", Time = "2 hours ago", IsPrimary = false }
    };

    private List<ActivityLog> expandedLogs = new()
    {
        new ActivityLog { Icon = "motion_sensor_active", Title = "Motion Detected", Location = "Living Room", Time = "2 mins ago", IsPrimary = true },
        new ActivityLog { Icon = "sensor_door", Title = "Main Door Closed", Location = "Entrance", Time = "45 mins ago", IsPrimary = false },
        new ActivityLog { Icon = "water_drop", Title = "Humidity Warning", Location = "Bathroom", Time = "2 hours ago", IsPrimary = false },
        new ActivityLog { Icon = "lock", Title = "Door Locked", Location = "Entrance", Time = "3 hours ago", IsPrimary = false },
        new ActivityLog { Icon = "power", Title = "Smart Plug Off", Location = "Master BR", Time = "4 hours ago", IsPrimary = false },
        new ActivityLog { Icon = "motion_sensor_active", Title = "Motion Detected", Location = "Kitchen", Time = "5 hours ago", IsPrimary = false }
    };

    private List<ActivityLog> logs => logsExpanded ? expandedLogs : defaultLogs;

    private void ToggleLogs()
    {
        logsExpanded = !logsExpanded;
    }
}
