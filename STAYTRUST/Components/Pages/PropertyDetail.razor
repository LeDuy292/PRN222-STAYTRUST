@page "/detail/{RoomId:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using STAYTRUST.Models
@using STAYTRUST.Services
@inject IRoomService RoomService
@inject IRentalService RentalService
@inject IFavoriteService FavoriteService
@inject IMessageService MessageService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Staytrust - @(Room?.Title ?? "Property Detail")</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

    .detail-page-container {
        font-family: 'Space Grotesk', sans-serif;
    }
    .glass-card {
        background: rgba(25, 51, 49, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(19, 236, 218, 0.1);
    }
    .glow-button {
        box-shadow: 0 0 15px rgba(19, 236, 218, 0.3);
    }
    .detail-page-container ::-webkit-scrollbar { width: 8px; }
    .detail-page-container ::-webkit-scrollbar-track { background: #102220; }
    .detail-page-container ::-webkit-scrollbar-thumb { background: #234845; border-radius: 10px; }
    .detail-view-wrapper { background-color: #102220; }

    /* 360 Viewer Modal Animations */
    .viewer360-overlay {
        animation: fadeIn360 0.3s ease-out;
    }
    .viewer360-panel {
        animation: slideUp360 0.35s ease-out;
    }
    @@keyframes fadeIn360 {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    @@keyframes slideUp360 {
        from { opacity: 0; transform: translateY(30px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .viewer360-spinner {
        border: 3px solid rgba(19, 236, 218, 0.2);
        border-top: 3px solid #13ecda;
        border-radius: 50%;
        width: 48px;
        height: 48px;
        animation: spin360 0.8s linear infinite;
    }
    @@keyframes spin360 {
        to { transform: rotate(360deg); }
    }
    .btn-360 {
        background: linear-gradient(135deg, rgba(19, 236, 218, 0.9), rgba(16, 180, 166, 0.9));
        backdrop-filter: blur(8px);
        transition: all 0.3s ease;
    }
    .btn-360:hover {
        transform: scale(1.05);
        box-shadow: 0 0 25px rgba(19, 236, 218, 0.5);
    }
</style>

<div class="detail-page-container detail-view-wrapper text-white relative flex min-h-screen flex-col overflow-x-hidden absolute top-0 left-0 w-screen z-[100]">
    <!-- Top Navigation -->
    <header class="sticky top-0 z-50 w-full border-b border-white/10 bg-[#102220]/80 backdrop-blur-md px-6 lg:px-20 py-4">
        <div class="mx-auto flex max-w-7xl items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="flex items-center gap-3">
                    <div class="text-[#13ecda]">
                        <svg class="h-8 w-8" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z" fill="currentColor"></path>
                        </svg>
                    </div>
                    <h2 class="text-xl font-bold tracking-tight">Staytrust</h2>
                </a>
                <div class="hidden md:flex items-center gap-6">
                    <a class="text-sm font-medium hover:text-[#13ecda] transition-colors" href="/search">Search</a>
                    <a class="text-sm font-medium hover:text-[#13ecda] transition-colors" href="/my-rentals">My Rentals</a>
                </div>
            </div>
            <div class="flex items-center gap-6">
                <AuthorizeView>
                    <Authorized>
                        @{
                            var user = context.User;
                            var fullName = user.FindFirst("FullName")?.Value ?? user.Identity?.Name ?? "User";
                            var avatarUrl = user.FindFirst("AvatarUrl")?.Value ?? string.Empty;
                            var role = user.FindFirst("Role")?.Value ?? "Tenant";
                            var initial = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
                        }
                        <UserMenu FullName="@fullName" Role="@role" Initial="@initial" AvatarUrl="@avatarUrl" IsDarkMode="true" />
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="px-4 py-2 bg-white/5 text-white border border-white/10 rounded-xl text-sm font-bold hover:bg-white/10 transition-all">Login</a>
                        <a href="/register" class="px-4 py-2 bg-[#13ecda] text-[#102220] rounded-xl text-sm font-bold hover:bg-[#10d4c4] transition-all">Sign Up</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>
    <main class="mx-auto flex w-full max-w-7xl flex-1 flex-col px-6 lg:px-20 py-6">
        @if (Room == null)
        {
            <div class="flex items-center justify-center h-64">
                <div class="text-center">
                    <div class="w-8 h-8 border-2 border-[#13ecda]/30 border-t-[#13ecda] rounded-full animate-spin mx-auto mb-4"></div>
                    <p class="text-[#92c9c5] text-sm">Loading property...</p>
                </div>
            </div>
        }
        else
        {
            <!-- Breadcrumbs -->
            <nav class="flex items-center gap-2 pb-6 text-sm">
                <a class="text-[#13ecda]/70 hover:text-[#13ecda] transition-colors" href="/search">Search</a>
                <span class="text-white/30 material-symbols-outlined text-sm">chevron_right</span>
                <span class="text-white font-medium">@Room.Title</span>
            </nav>
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                <!-- Main Content Left (2/3) -->
                <div class="lg:col-span-2 space-y-8">
                    <!-- Hero Image -->
                    <section class="group relative overflow-hidden rounded-3xl bg-black aspect-video shadow-2xl">
                        @{
                            var heroImage = Room.RoomImages?.FirstOrDefault()?.ImageUrl;
                        }
                        @if (!string.IsNullOrEmpty(heroImage))
                        {
                            <div class="absolute inset-0 bg-cover bg-center opacity-80" style="background-image: url('@heroImage');"></div>
                        }
                        else
                        {
                            <div class="absolute inset-0 bg-[#193331] flex items-center justify-center">
                                <span class="material-symbols-outlined text-6xl text-[#92c9c5]">apartment</span>
                            </div>
                        }
                        <div class="absolute inset-0 flex flex-col justify-between p-6">
                            <div class="flex justify-between items-start">
                                <div class="rounded-full bg-black/40 backdrop-blur-md px-4 py-2 border border-white/10 flex items-center gap-2">
                                    <span class="relative flex h-2 w-2">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#13ecda] opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#13ecda]"></span>
                                    </span>
                                    <span class="text-xs font-bold uppercase tracking-widest text-white">@Room.Status</span>
                                </div>
                                <button @onclick="ToggleFavorite" class="p-2 rounded-full bg-black/40 backdrop-blur-md border border-white/10 hover:bg-red-500/20 transition-all">
                                    <span class="material-symbols-outlined @(isFavorite ? "text-red-500" : "text-white")">@(isFavorite ? "favorite" : "favorite_border")</span>
                                </button>
                            </div>
                            <div class="flex justify-between items-end">
                                <div class="flex flex-col gap-1">
                                    <h1 class="text-3xl font-bold">@Room.Title</h1>
                                    <div class="flex items-center gap-2 text-[#13ecda]">
                                        <span class="material-symbols-outlined text-sm">location_on</span>
                                        <span class="text-sm">@Room.Address</span>
                                    </div>
                                </div>
                                @* === 360° VIEW BUTTON === *@
                                @if (!string.IsNullOrEmpty(Room.Image360Url))
                                {
                                    <button @onclick="Open360Viewer" class="btn-360 flex items-center gap-2 px-5 py-3 rounded-2xl text-[#102220] font-bold text-sm shadow-lg">
                                        <span class="material-symbols-outlined text-base">360</span>
                                        Xem 360°
                                    </button>
                                }
                            </div>
                        </div>
                    </section>
                    <!-- Room Images Gallery -->
                    @if (Room.RoomImages?.Count > 1)
                    {
                        <section class="space-y-4">
                            <h3 class="text-lg font-bold px-2">Room Gallery</h3>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                @foreach (var img in Room.RoomImages.Skip(1))
                                {
                                    <div class="group relative aspect-square cursor-pointer overflow-hidden rounded-2xl bg-[#193331] border border-white/5 hover:border-[#13ecda]/50 transition-all">
                                        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110" style="background-image: url('@img.ImageUrl');"></div>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                    <!-- Description -->
                    @if (!string.IsNullOrEmpty(Room.Description))
                    {
                        <section class="rounded-3xl bg-[#193331]/30 p-8 border border-white/5">
                            <h3 class="text-xl font-bold mb-4">About this property</h3>
                            <p class="text-[#92c9c5] leading-relaxed">@Room.Description</p>
                        </section>
                    }
                    <!-- Room Info -->
                    <section class="rounded-3xl bg-[#193331]/30 p-8 border border-white/5">
                        <h3 class="text-xl font-bold mb-6">Room Details</h3>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                            <div class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-white/5 text-center">
                                <span class="material-symbols-outlined text-[#13ecda] text-3xl">square_foot</span>
                                <span class="text-sm font-medium">@(Room.Area?.ToString("F0") ?? "N/A") m²</span>
                            </div>
                            <div class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-white/5 text-center">
                                <span class="material-symbols-outlined text-[#13ecda] text-3xl">payments</span>
                                <span class="text-sm font-medium">@Room.Price.ToString("N0") ₫</span>
                            </div>
                            <div class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-white/5 text-center">
                                <span class="material-symbols-outlined text-[#13ecda] text-3xl">circle</span>
                                <span class="text-sm font-medium">@Room.Status</span>
                            </div>
                            <div class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-white/5 text-center">
                                <span class="material-symbols-outlined text-[#13ecda] text-3xl">calendar_month</span>
                                <span class="text-sm font-medium">@(Room.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                            </div>
                        </div>
                    </section>
                    <!-- Reviews Section -->
                    <section class="space-y-6">
                        <div class="flex items-center justify-between px-2">
                            <h3 class="text-xl font-bold">Reviews (@(Room.Feedbacks?.Count ?? 0))</h3>
                            @if (Room.Feedbacks?.Any() == true)
                            {
                                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#13ecda]/10 border border-[#13ecda]/20">
                                    <span class="material-symbols-outlined text-[#13ecda] text-sm">star</span>
                                    <span class="text-sm font-bold text-[#13ecda]">@Room.Feedbacks.Average(f => f.Rating).ToString("F1")</span>
                                </div>
                            }
                        </div>

                        @if (Room.Feedbacks?.Any() == true)
                        {
                            @foreach (var fb in Room.Feedbacks.OrderByDescending(f => f.CreatedAt))
                            {
                                <div class="glass-card rounded-2xl p-6">
                                    <div class="flex items-center gap-4 mb-3">
                                        <div class="h-10 w-10 rounded-full bg-[#13ecda]/20 flex items-center justify-center text-[#13ecda] font-bold">
                                            @(fb.User?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm">@(fb.User?.FullName ?? "Anonymous")</p>
                                            <p class="text-[10px] text-[#92c9c5]">@(fb.CreatedAt?.ToString("dd/MM/yyyy") ?? "")</p>
                                        </div>
                                        <div class="ml-auto flex gap-0.5">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="material-symbols-outlined text-sm @(i <= fb.Rating ? "text-yellow-400" : "text-white/20")">star</span>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(fb.Comment))
                                    {
                                        <p class="text-sm text-[#92c9c5]">@fb.Comment</p>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-[#92c9c5] text-sm px-2">No reviews yet for this property.</p>
                        }

                        <!-- Add Review Form -->
                        @if (canReview)
                        {
                            <div class="glass-card rounded-2xl p-6 space-y-4">
                                <h4 class="text-sm font-bold uppercase tracking-widest text-[#13ecda]">Leave a Review</h4>
                                <div class="flex gap-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        int rating = i;
                                        <button @onclick="() => newRating = rating" class="w-10 h-10 rounded-xl flex items-center justify-center border transition-all @(newRating >= rating ? "bg-yellow-400/20 border-yellow-400 text-yellow-400" : "bg-white/5 border-white/10 text-white/30 hover:border-yellow-400/50")">
                                            <span class="material-symbols-outlined">star</span>
                                        </button>
                                    }
                                </div>
                                <textarea @bind="newComment" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 min-h-[100px] focus:border-[#13ecda]/50 focus:ring-0 transition-all text-white text-sm" placeholder="Share your experience..."></textarea>
                                <button @onclick="SubmitReview" disabled="@isSubmittingReview" class="px-6 py-3 bg-[#13ecda] text-[#102220] font-bold rounded-xl text-sm hover:bg-[#10d4c4] transition-all disabled:opacity-50">
                                    @(isSubmittingReview ? "Submitting..." : "Submit Review")
                                </button>
                            </div>
                        }
                        else if (currentUserId != null)
                        {
                            <div class="glass-card rounded-2xl p-6 text-center text-[#92c9c5]">
                                <span class="material-symbols-outlined text-4xl mb-3 opacity-40">lock</span>
                                <p class="text-sm">Hệ thống bảo vệ Rating: Bạn phải thuê và trải nghiệm phòng này để được viết nhận xét.</p>
                            </div>
                        }
                    </section>
                </div>
                <!-- Sidebar Right (1/3) -->
                <div class="space-y-8">
                    <!-- Booking Card -->
                    <div class="sticky top-28 glass-card rounded-3xl p-6 shadow-2xl">
                        <div class="mb-6 flex items-end justify-between">
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-[#13ecda]">Monthly Rent</p>
                                <h2 class="text-4xl font-bold">@Room.Price.ToString("N0") <span class="text-lg font-normal text-white/50">₫/mo</span></h2>
                            </div>
                        </div>
                        <div class="space-y-4 pb-6 border-b border-white/10">
                            <div class="flex justify-between text-sm">
                                <span class="text-white/60">Security Deposit</span>
                                <span class="font-bold">@Room.Price.ToString("N0") ₫</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-white/60">Area</span>
                                <span class="font-bold">@(Room.Area?.ToString("F0") ?? "N/A") m²</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-white/60">Status</span>
                                <span class="font-bold text-[#13ecda]">@Room.Status</span>
                            </div>
                        </div>
                        <div class="py-6">
                            @if (Room.Status == "Available")
                            {
                                <button @onclick="OpenContractModal" disabled="@isBooking" class="glow-button w-full rounded-2xl bg-[#13ecda] py-4 text-center text-base font-bold text-[#102220] hover:scale-[1.02] transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                                    @(isBooking ? "Ðang xử lý..." : "Thuê phòng")
                                </button>
                            }
                            else
                            {
                                <button disabled class="w-full rounded-2xl bg-[#193331]/80 py-4 text-center text-base font-bold text-gray-400 opacity-80 cursor-not-allowed flex items-center justify-center gap-2 border border-white/5">
                                    <span class="material-symbols-outlined text-xl">block</span>
                                    Phòng đã được thuê
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(bookingMessage))
                        {
                            <p class="mt-2 text-center text-sm @(bookingSuccess ? "text-emerald-400" : "text-red-400") font-medium">@bookingMessage</p>
                        }
                        <p class="mt-4 text-center text-[10px] text-white/40 font-medium">Free cancellation within 48 hours</p>
                    </div>
                    <!-- Landlord Profile -->
                    <div class="rounded-3xl bg-[#193331]/30 p-6 border border-white/5">
                        <h3 class="text-sm font-bold uppercase tracking-widest text-white/40 mb-4">Property Owner</h3>
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <div class="h-16 w-16 rounded-full bg-[#13ecda]/20 flex items-center justify-center text-[#13ecda] text-2xl font-bold">
                                    @(Room.Landlord?.FullName?.Substring(0, 1).ToUpper() ?? "L")
                                </div>
                                <div class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-[#13ecda] text-[#102220]">
                                    <span class="material-symbols-outlined text-xs font-bold">check</span>
                                </div>
                            </div>
                            <div>
                                <h4 class="text-lg font-bold">@(Room.Landlord?.FullName ?? "Owner")</h4>
                                <p class="text-xs text-[#92c9c5]">@(Room.Landlord?.Email ?? "")</p>
                            </div>
                        </div>
                        <!-- Contact Host Button -->
                        <button @onclick="OpenMessageModal" class="mt-6 w-full rounded-xl border border-white/10 py-3 text-sm font-medium hover:bg-white/5 transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">chat</span>
                            Contact Host
                        </button>
                    </div>
                </div>
            </div>
        }
    </main>
    <footer class="mt-20 border-t border-white/10 py-12 px-6 lg:px-20 text-white/40">
        <div class="mx-auto max-w-7xl flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="flex items-center gap-2">
                <span class="text-[#13ecda] font-bold">Staytrust</span>
                <span>© 2024. All rights reserved.</span>
            </div>
        </div>
    </footer>
</div>

<!-- Message Modal -->
@if (showMessageModal)
{
    <div class="fixed inset-0 z-[200] flex items-center justify-center p-6 bg-black/80 backdrop-blur-sm">
        <div class="glass-card w-full max-w-lg rounded-3xl p-8 border border-white/10 shadow-2xl relative">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold">Message to @(Room?.Landlord?.FullName ?? "Owner")</h3>
                <button @onclick="CloseMessageModal" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-red-500/10 hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <!-- Previous messages -->
            @if (conversationMessages?.Any() == true)
            {
                <div class="max-h-64 overflow-y-auto space-y-3 mb-4 pr-2">
                    @foreach (var msg in conversationMessages)
                    {
                        var isMe = msg.SenderId == currentUserId;
                        <div class="flex @(isMe ? "justify-end" : "justify-start")">
                            <div class="max-w-[80%] px-4 py-2 rounded-2xl text-sm @(isMe ? "bg-[#13ecda] text-[#102220]" : "bg-white/10 text-white")">
                                <p>@msg.Content</p>
                                <p class="text-[10px] mt-1 @(isMe ? "text-[#102220]/60" : "text-white/40")">@(msg.CreatedAt?.ToString("HH:mm dd/MM") ?? "")</p>
                            </div>
                        </div>
                    }
                </div>
            }

            <textarea @bind="messageContent" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 min-h-[100px] focus:border-[#13ecda]/50 focus:ring-0 transition-all text-white text-sm mb-4" placeholder="Write your message..."></textarea>
            <button @onclick="SendMessage" disabled="@isSendingMessage" class="w-full py-3 bg-[#13ecda] text-[#102220] font-bold rounded-xl text-sm hover:bg-[#10d4c4] transition-all disabled:opacity-50 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">send</span>
                @(isSendingMessage ? "Sending..." : "Send Message")
            </button>
        </div>
    </div>
}

@* === 360° VIEWER FULLSCREEN MODAL === *@
@if (show360Modal)
{
    <div class="viewer360-overlay fixed inset-0 z-[300] flex items-center justify-center bg-black/90 backdrop-blur-md p-4 md:p-8">
        <div class="viewer360-panel relative w-full max-w-6xl h-[85vh] rounded-3xl overflow-hidden bg-[#0a1a18] border border-white/10 shadow-2xl flex flex-col">
            @* Header Bar *@
            <div class="flex items-center justify-between px-6 py-4 border-b border-white/10 bg-[#102220]/80 backdrop-blur-sm">
                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#13ecda]/10 border border-[#13ecda]/20">
                        <span class="material-symbols-outlined text-[#13ecda] text-sm">360</span>
                        <span class="text-sm font-bold text-[#13ecda]">Chế độ xem 360°</span>
                    </div>
                    <span class="text-sm text-white/50">@Room?.Title</span>
                </div>
                <button @onclick="Close360Viewer" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-red-500/20 hover:border-red-500/30 hover:text-red-400 transition-all text-white">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            @* Viewer Container *@
            <div class="flex-1 relative">
                @* Loading Spinner – shown until viewer fires 'ready' *@
                @if (is360Loading)
                {
                    <div class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-4 bg-[#0a1a18]">
                        <div class="viewer360-spinner"></div>
                        <p class="text-[#92c9c5] text-sm animate-pulse">Đang tải ảnh 360°...</p>
                    </div>
                }

                @* Error Message *@
                @if (has360Error)
                {
                    <div class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-4 bg-[#0a1a18]">
                        <span class="material-symbols-outlined text-5xl text-red-400">error</span>
                        <p class="text-red-400 font-bold">Không thể tải ảnh 360°</p>
                        <p class="text-white/50 text-sm">Vui lòng kiểm tra kết nối mạng hoặc thử lại sau.</p>
                        <button @onclick="Close360Viewer" class="mt-2 px-6 py-2 rounded-xl border border-white/20 text-white/70 text-sm hover:bg-white/5 transition-all">Đóng</button>
                    </div>
                }

                @* This div is the target for Photo Sphere Viewer *@
                <div id="viewer360Container" style="width:100%; height:100%;"></div>
            </div>

            @* Footer hint *@
            <div class="px-6 py-3 border-t border-white/10 bg-[#102220]/80 backdrop-blur-sm">
                <p class="text-[10px] text-white/40 text-center tracking-wider uppercase">Kéo chuột để xoay • Cuộn để phóng to/thu nhỏ • Nhấn nút fullscreen ở thanh điều khiển</p>
            </div>
        </div>
    </div>
}

<!-- Contract Modal -->
@if (showContractModal)
{
    <div class="fixed inset-0 z-[400] flex items-center justify-center p-6 bg-black/80 backdrop-blur-sm">
        <div class="glass-card w-full max-w-2xl rounded-3xl p-8 border border-white/10 shadow-2xl relative flex flex-col max-h-[90vh]">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold">Hợp đồng thuê phòng</h3>
                <button @onclick="CloseContractModal" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-red-500/10 hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div class="flex-1 overflow-y-auto pr-4 mb-6 text-sm text-[#92c9c5] space-y-4">
                <h4 class="font-bold text-white text-base">CÁC ĐIỀU KHOẢN VÀ ĐIỀU KIỆN</h4>
                <p>1. **Thời hạn thuê**: Hợp đồng thuê này có hiệu lực kể từ ngày xác nhận. Bạn phải tuân thủ điều khoản chấm dứt nếu muốn kết thúc hợp đồng sớm.</p>
                <p>2. **Trả phòng**: Nếu bạn muốn trả phòng, bạn **phải thông báo trước 15 ngày** và **phải thanh toán toàn bộ các khoản nợ** (tiền thuê, điện, nước, internet, v.v.) thì mới được phép trả phòng. Hệ thống sẽ không cho phép trả phòng nếu còn hóa đơn chưa thanh toán.</p>
                <p>3. **Tiền thuê và tiện ích**: Bạn đồng ý thanh toán tiền thuê phòng và các dịch vụ tiện ích đầy đủ và đúng hạn hàng tháng theo hóa đơn đã được gửi.</p>
                <p>4. **Quy định tòa nhà**: Tuân thủ các quy định chung của tòa nhà (không được nuôi thú cưng tùy tiện, không gây tiếng ồn lớn sau 22h, v.v.).</p>
                <p class="text-white font-medium mt-4">Bằng việc đánh dấu vào ô bên dưới, bạn xác nhận đã đọc, hiểu rõ và đồng ý với tất cả các điều khoản nêu trên.</p>
            </div>
            
            <div class="mt-auto">
                <label class="flex items-center gap-3 cursor-pointer mb-6">
                    <input type="checkbox" @bind="agreedToTerms" class="w-5 h-5 rounded border-gray-300 text-[#13ecda] focus:ring-[#13ecda] bg-black/50" />
                    <span class="text-sm font-medium select-none text-white">Tôi đã đọc kỹ và đồng ý với thỏa thuận hợp đồng</span>
                </label>
                
                <button @onclick="HandleBooking" disabled="@(!agreedToTerms || isBooking)" class="w-full py-4 bg-[#13ecda] text-[#102220] font-bold rounded-xl text-base hover:bg-[#10d4c4] transition-all disabled:opacity-50 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">assignment_turned_in</span>
                    @(isBooking ? "Đang xử lý..." : "Xác nhận thuê")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int RoomId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private Room? Room { get; set; }
    private string? bookingMessage;
    private bool bookingSuccess;
    private bool isBooking;
    private bool isFavorite;
    private int? currentUserId;
    private bool showContractModal;
    private bool agreedToTerms;

    // Review
    private bool canReview;
    private int newRating = 5;
    private string newComment = "";
    private bool isSubmittingReview;

    // Messaging
    private bool showMessageModal;
    private string messageContent = "";
    private bool isSendingMessage;
    private List<Message>? conversationMessages;

    protected override async Task OnInitializedAsync()
    {
        Room = await RoomService.GetRoomDetailWithFeedbacksAsync(RoomId);

        // DEMO OVERRIDE: Provide reliable, instantly-loading interior apartment panoramas natively supported by WebGL
        if (Room != null)
        {
            // All rooms temporarily get the verified working Living Room image
            Room.Image360Url = "https://raw.githubusercontent.com/ArcherFMY/SD-T2I-360PanoImage/main/data/a-living-room.png"; 
        }

        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                              ?? user.FindFirst("sub")?.Value;
                if (int.TryParse(userIdStr, out var uid))
                {
                    currentUserId = uid;
                    isFavorite = await FavoriteService.IsFavoriteAsync(uid, RoomId);
                    canReview = await RentalService.CanFeedbackAsync(uid, RoomId);
                }
            }
        }
    }

    private async Task OpenContractModal()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            NavigationManager.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
            return;
        }

        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        ?? user.FindFirst("sub")?.Value;

        if (string.IsNullOrEmpty(userIdStr) || !int.TryParse(userIdStr, out int userId))
        {
            bookingMessage = "Không thể xác định thông tin người dùng.";
            return;
        }

        if (await RentalService.HasActiveRentalAsync(userId))
        {
            bookingMessage = "Bạn hiện đang thuê một phòng khác. Vui lòng trả phòng trước khi thuê phòng mới.";
            bookingSuccess = false;
            return;
        }

        showContractModal = true;
        agreedToTerms = false;
        bookingMessage = null;
    }

    private void CloseContractModal()
    {
        showContractModal = false;
    }

    private async Task HandleBooking()
    {
        if (!agreedToTerms) return;
        
        isBooking = true;
        bookingMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        ?? user.FindFirst("sub")?.Value;

        if (int.TryParse(userIdStr, out int userId))
        {
            var contract = await RentalService.CreateRentalContractAsync(userId, RoomId);
            if (contract != null)
            {
                bookingMessage = "Đặt phòng thành công! Bạn có thể xem hợp đồng và thanh toán trong phần 'My Rentals'.";
                bookingSuccess = true;
                showContractModal = false;
            }
            else
            {
                bookingMessage = "Đặt phòng thất bại. Có thể phòng này đã được thuê hoặc có lỗi xảy ra.";
                bookingSuccess = false;
            }
        }
        else
        {
            bookingMessage = "Không thể xác định thông tin người dùng.";
            bookingSuccess = false;
        }

        isBooking = false;
    }

    private async Task ToggleFavorite()
    {
        if (currentUserId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        var added = await FavoriteService.ToggleFavoriteAsync(currentUserId.Value, RoomId);
        isFavorite = added;
    }

    private async Task SubmitReview()
    {
        if (currentUserId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        isSubmittingReview = true;
        var feedback = new Feedback
        {
            RoomId = RoomId,
            UserId = currentUserId.Value,
            Rating = newRating,
            Comment = newComment,
            CreatedAt = DateTime.Now
        };

        var success = await RentalService.SubmitFeedbackAsync(feedback);
        if (success)
        {
            // Reload room to show new review
            Room = await RoomService.GetRoomDetailWithFeedbacksAsync(RoomId);
            newComment = "";
            newRating = 5;
            await JSRuntime.InvokeVoidAsync("alert", "Cảm ơn bạn đã gửi đánh giá!");
        }
        isSubmittingReview = false;
    }

    private async Task OpenMessageModal()
    {
        if (currentUserId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        if (Room?.LandlordId > 0)
        {
            conversationMessages = await MessageService.GetConversationAsync(currentUserId.Value, Room.LandlordId, RoomId);
        }
        showMessageModal = true;
    }

    private void CloseMessageModal()
    {
        showMessageModal = false;
        messageContent = "";
    }

    private async Task SendMessage()
    {
        if (currentUserId == null || Room == null || string.IsNullOrWhiteSpace(messageContent)) return;

        isSendingMessage = true;
        await MessageService.SendMessageAsync(currentUserId.Value, Room.LandlordId, RoomId, messageContent);
        conversationMessages = await MessageService.GetConversationAsync(currentUserId.Value, Room.LandlordId, RoomId);
        messageContent = "";
        isSendingMessage = false;
    }

    // =============================================
    // 360° Viewer Logic
    // =============================================
    private bool show360Modal;
    private bool is360Loading;
    private bool has360Error;

    private async Task Open360Viewer()
    {
        if (string.IsNullOrEmpty(Room?.Image360Url)) return;

        show360Modal = true;
        is360Loading = true;
        has360Error = false;
        StateHasChanged();

        // Small delay to let the DOM render the container
        await Task.Delay(150);

        try
        {
            var result = await JSRuntime.InvokeAsync<bool>("Room360.initViewer", "viewer360Container", Room.Image360Url);
            if (!result)
            {
                has360Error = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[360 Viewer Error] {ex.Message}");
            has360Error = true;
        }

        // Hide spinner after a brief moment (viewer will have loaded or errored)
        await Task.Delay(2000);
        is360Loading = false;
        StateHasChanged();
    }

    private async Task Close360Viewer()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("Room360.destroyViewer");
        }
        catch { /* ignore if JS context is gone */ }

        show360Modal = false;
        is360Loading = false;
        has360Error = false;
        StateHasChanged();
    }
}
