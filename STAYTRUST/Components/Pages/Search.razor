@page "/search"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Staytrust - Find Your Home Da Nang</PageTitle>

<style>
    /* Scoped font for search page */
    @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

    .search-page-container {
        font-family: 'Space Grotesk', sans-serif;
    }
    .glass-panel {
        background: rgba(16, 34, 32, 0.8);
        backdrop-filter: blur(12px);
        border-right: 1px solid rgba(19, 236, 218, 0.1);
    }
    .glass-card {
        background: rgba(25, 51, 49, 0.7);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(19, 236, 218, 0.1);
    }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .map-pin-glow {
        box-shadow: 0 0 15px rgba(19, 236, 218, 0.6);
    }
    #map {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 100%;
        height: 100%;
    }
</style>

<div class="search-page-container bg-[#102220] text-white overflow-hidden h-screen w-screen flex flex-col absolute top-0 left-0 z-[100]">
    <!-- Top Navigation Bar -->
    <header class="z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-b-[#234845] px-6 py-3 bg-[#102220]/95 backdrop-blur-md">
        <div class="flex items-center gap-8">
            <Logo />
            <!-- Search Bar Overlay Component -->
            <div class="hidden lg:flex items-center gap-2">
