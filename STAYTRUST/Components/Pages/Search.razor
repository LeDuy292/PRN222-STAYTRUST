@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@code {
    private List<PropertyMarker> propertyMarkers = new()
    {
        new PropertyMarker { Lat = 16.0678, Lng = 108.2415, Price = 650 }, // Sơn Trà
        new PropertyMarker { Lat = 16.0333, Lng = 108.2667, Price = 820 }, // Ngũ Hành Sơn
        new PropertyMarker { Lat = 16.0544, Lng = 108.2022, Price = 480 }  // Hải Châu
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("goongMap.initSearchMap", "map", 16.0544, 108.2022, 13);
            await JSRuntime.InvokeVoidAsync("goongMap.addMarkers", "map", propertyMarkers);
            
            // Check for search query
            var uri = new Uri(NavigationManager.Uri);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("q", out var locationStr) && !string.IsNullOrEmpty(locationStr))
            {
                var coords = await JSRuntime.InvokeAsync<Coordinates>("goongMap.geocode", locationStr.ToString());
                if (coords != null)
                {
                    await JSRuntime.InvokeVoidAsync("goongMap.flyTo", "map", coords.Lat, coords.Lng, 15);
                }
            }
        }
    }

    private async Task Logout()
    {
        await Http.PostAsync("api/auth/logout", null);
        NavigationManager.NavigateTo("/search", forceLoad: true);
    }

    public class Coordinates
    {
        public double Lat { get; set; }
        public double Lng { get; set; }
    }

    public class PropertyMarker
    {
        public double Lat { get; set; }
        public double Lng { get; set; }
        public int Price { get; set; }
    }
}
