@page "/search"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using STAYTRUST.Models
@using STAYTRUST.Services
@inject IRoomService RoomService
@inject IFavoriteService FavoriteService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Staytrust - Find Your Home Da Nang</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

    .search-page-container {
        font-family: 'Space Grotesk', sans-serif;
    }
    .glass-panel {
        background: rgba(16, 34, 32, 0.8);
        backdrop-filter: blur(12px);
        border-right: 1px solid rgba(19, 236, 218, 0.1);
    }
    .glass-card {
        background: rgba(25, 51, 49, 0.7);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(19, 236, 218, 0.1);
    }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .map-pin-glow {
        box-shadow: 0 0 15px rgba(19, 236, 218, 0.6);
    }
    #map {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 100%;
        height: 100%;
    }
</style>

<div class="search-page-container bg-[#102220] text-white overflow-hidden h-screen w-screen flex flex-col absolute top-0 left-0 z-[100]">
    <!-- Top Navigation Bar -->
    <header class="z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-b-[#234845] px-6 py-3 bg-[#102220]/95 backdrop-blur-md">
        <div class="flex items-center gap-8">
            <Logo />
            <div class="hidden lg:flex items-center gap-2">
                <div class="relative w-[400px]">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                        <span class="material-symbols-outlined text-[#13ecda] text-xl">search</span>
                    </div>
                    <input @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKeyUp"
                           class="block w-full pl-11 pr-4 py-2 bg-[#193331] border-none rounded-xl text-sm focus:ring-1 focus:ring-[#13ecda] placeholder-[#92c9c5]"
                           placeholder="Search by location or name..." type="text" />
                    
                    @if (suggestions != null && suggestions.Any() && isDropdownOpen)
                    {
                        <ul class="absolute top-full left-0 w-full bg-[#193331] border border-[#234845] rounded-xl mt-1 max-h-60 overflow-y-auto z-[60] shadow-lg hide-scrollbar">
                            @foreach (var suggestion in suggestions)
                            {
                                <li class="px-4 py-3 text-sm text-white hover:bg-[#13ecda]/20 cursor-pointer border-b border-[#234845] last:border-b-0"
                                    @onclick="() => SelectSuggestion(suggestion.description)">
                                    @suggestion.description
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="flex items-center gap-6">
            <nav class="hidden md:flex items-center gap-6">
                <a class="text-white hover:text-[#13ecda] transition-colors text-sm font-medium" href="/">Home</a>
                <a class="text-[#13ecda] text-sm font-medium border-b-2 border-[#13ecda] pb-1" href="/search">Search</a>
            </nav>
            <div class="flex items-center gap-4">
                <AuthorizeView>
                    <Authorized>
                        @{
                            var user = context.User;
                            var fullName = user.FindFirst("FullName")?.Value ?? user.Identity?.Name ?? "User";
                            var avatarUrl = user.FindFirst("AvatarUrl")?.Value ?? string.Empty;
                            var role = user.FindFirst("Role")?.Value ?? "Tenant";
                            var initial = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
                        }
                        <UserMenu FullName="@fullName" Role="@role" Initial="@initial" AvatarUrl="@avatarUrl" IsDarkMode="true" />
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="px-4 py-2 bg-[#13ecda]/10 text-[#13ecda] border border-[#13ecda]/30 rounded-xl text-sm font-bold hover:bg-[#13ecda]/20 transition-all">Login</a>
                        <a href="/register" class="px-4 py-2 bg-[#13ecda] text-[#102220] rounded-xl text-sm font-bold shadow-[0_0_15px_rgba(19,236,218,0.2)] hover:bg-[#10d4c4] transition-all">Sign Up</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>
    <main class="flex-1 flex overflow-hidden relative text-white">
        <!-- Left Side Bar Filters -->
        <aside class="w-80 glass-panel h-full flex flex-col z-40 bg-[#102220]/80">
            <div class="p-6 flex flex-col gap-8 overflow-y-auto hide-scrollbar">
                <div>
                    <h2 class="text-lg font-bold mb-1">Advanced Filters</h2>
                    <p class="text-[#92c9c5] text-xs">Filter rooms from database</p>
                </div>
                <!-- Price Range -->
                <div class="flex flex-col gap-4">
                    <label class="text-sm font-medium">Price Range (VND)</label>
                    <div class="flex gap-2">
                        <input @bind="minPrice" type="number" placeholder="Min" class="w-1/2 bg-[#193331] border border-[#234845] rounded-xl px-3 py-2 text-sm text-white placeholder-[#92c9c5] focus:border-[#13ecda]" />
                        <input @bind="maxPrice" type="number" placeholder="Max" class="w-1/2 bg-[#193331] border border-[#234845] rounded-xl px-3 py-2 text-sm text-white placeholder-[#92c9c5] focus:border-[#13ecda]" />
                    </div>
                </div>
                <!-- Min Area -->
                <div class="flex flex-col gap-3">
                    <label class="text-sm font-medium">Minimum Area (m²)</label>
                    <input @bind="minArea" type="number" placeholder="e.g. 20" class="w-full bg-[#193331] border border-[#234845] rounded-xl px-3 py-2 text-sm text-white placeholder-[#92c9c5] focus:border-[#13ecda]" />
                </div>
                <!-- Location -->
                <div class="flex flex-col gap-3">
                    <label class="text-sm font-medium">Location / Keyword</label>
                    <input @bind="filterAddress" type="text" placeholder="e.g. Sơn Trà, Đà Nẵng" class="w-full bg-[#193331] border border-[#234845] rounded-xl px-3 py-2 text-sm text-white placeholder-[#92c9c5] focus:border-[#13ecda]" />
                </div>
            </div>
            <div class="p-6 border-t border-[rgba(19,236,218,0.2)] space-y-3">
                <button @onclick="ApplyFilters" class="w-full py-3 bg-[#13ecda] text-[#102220] font-bold rounded-xl text-sm flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">search</span>
                    Search Rooms
                </button>
                <button @onclick="ResetFilters" class="w-full py-3 bg-white/5 border border-white/10 text-white font-bold rounded-xl text-sm flex items-center justify-center gap-2 hover:bg-white/10">
                    <span class="material-symbols-outlined text-sm">filter_alt_off</span>
                    Reset Filters
                </button>
            </div>
        </aside>
        <!-- Main Content Area -->
        <div class="flex-1 relative">
            <div id="map" class="absolute inset-0 bg-[#0d1a19]"></div>
            <!-- Scrollable Property Cards -->
            <div class="absolute inset-y-0 right-0 w-[420px] z-20 pointer-events-none p-6">
                <div class="h-full overflow-y-auto hide-scrollbar pointer-events-auto space-y-4 pr-2">
                    @if (isLoading)
                    {
                        <div class="flex items-center justify-center h-full">
                            <div class="text-center">
                                <div class="w-8 h-8 border-2 border-[#13ecda]/30 border-t-[#13ecda] rounded-full animate-spin mx-auto mb-4"></div>
                                <p class="text-[#92c9c5] text-sm">Loading rooms...</p>
                            </div>
                        </div>
                    }
                    else if (rooms == null || !rooms.Any())
                    {
                        <div class="flex items-center justify-center h-full">
                            <div class="text-center">
                                <span class="material-symbols-outlined text-4xl text-[#92c9c5] mb-4">search_off</span>
                                <p class="text-[#92c9c5] text-sm">No rooms found matching your criteria.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var room in rooms)
                        {
                            var firstImage = room.RoomImages?.FirstOrDefault()?.ImageUrl;
                            var avgRating = room.Feedbacks?.Any() == true
                                ? room.Feedbacks.Average(f => f.Rating).ToString("F1")
                                : "N/A";
                            var isFav = favoriteRoomIds.Contains(room.RoomId);

                            <div class="glass-card rounded-xl overflow-hidden group hover:shadow-[0_0_20px_rgba(19,236,218,0.2)] transition-all duration-300">
                                <div class="relative h-48">
                                    @if (!string.IsNullOrEmpty(firstImage))
                                    {
                                        <div class="w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
                                             style="background-image: url('@firstImage');"></div>
                                    }
                                    else
                                    {
                                        <div class="w-full h-full bg-[#193331] flex items-center justify-center">
                                            <span class="material-symbols-outlined text-4xl text-[#92c9c5]">apartment</span>
                                        </div>
                                    }
                                    <div class="absolute top-3 left-3 px-2 py-1 bg-[#13ecda]/20 backdrop-blur border border-[#13ecda]/40 rounded-lg flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[14px] text-[#13ecda] fill-[1]">star</span>
                                        <span class="text-[10px] font-bold text-[#13ecda] uppercase tracking-wider">@avgRating</span>
                                    </div>
                                    <button @onclick="() => ToggleFavorite(room.RoomId)" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-[#102220]/40 backdrop-blur flex items-center justify-center hover:bg-red-500/30 transition-all">
                                        <span class="material-symbols-outlined text-lg @(isFav ? "text-red-500" : "text-white")">@(isFav ? "favorite" : "favorite_border")</span>
                                    </button>
                                </div>
                                <div class="p-4">
                                    <div class="flex justify-between items-start mb-2">
                                        <div>
                                            <h3 class="font-bold text-base leading-tight">@room.Title</h3>
                                            <p class="text-xs text-[#92c9c5] flex items-center gap-1 mt-0.5">
                                                <span class="material-symbols-outlined text-xs">location_on</span> @room.Address
                                            </p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-[#13ecda] font-bold text-lg leading-none">@room.Price.ToString("N0")<span class="text-[10px] text-white/60 font-normal">₫/mo</span></p>
                                        </div>
                                    </div>
                                    <div class="flex gap-4 mb-4 py-2 border-y border-[rgba(19,236,218,0.2)]">
                                        <div class="flex items-center gap-1.5">
                                            <span class="material-symbols-outlined text-sm text-[#13ecda]">square_foot</span>
                                            <span class="text-[11px] text-[#92c9c5]">@(room.Area?.ToString("F0") ?? "N/A")m²</span>
                                        </div>
                                        <div class="flex items-center gap-1.5">
                                            <span class="material-symbols-outlined text-sm text-[#13ecda]">person</span>
                                            <span class="text-[11px] text-[#92c9c5]">@(room.Landlord?.FullName ?? "Owner")</span>
                                        </div>
                                        <div class="flex items-center gap-1.5">
                                            <span class="material-symbols-outlined text-sm text-[#13ecda]">circle</span>
                                            <span class="text-[11px] text-[#92c9c5]">@room.Status</span>
                                        </div>
                                    </div>
                                    <a href="/detail/@room.RoomId" class="w-full inline-block text-center py-2.5 bg-[#13ecda] text-[#102220] font-bold rounded-lg text-sm transition-colors hover:bg-[#10d4c4]">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </main>
    <!-- Footer -->
    <footer class="z-50 bg-[#102220]/95 border-t border-[rgba(19,236,218,0.2)] px-6 py-2 flex justify-between items-center text-[10px] tracking-widest text-[#92c9c5] uppercase">
        <div class="flex gap-6">
            <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 bg-[#13ecda] rounded-full animate-pulse"></span> @(rooms?.Count ?? 0) Rooms found</span>
        </div>
        <div class="flex gap-4">
            <a class="hover:text-[#13ecda] transition-colors" href="#">Privacy & Terms</a>
        </div>
    </footer>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private List<Room>? rooms;
    private List<int> favoriteRoomIds = new();
    private bool isLoading = true;

    private string? searchQuery;
    private string? filterAddress;
    private decimal? minPrice;
    private decimal? maxPrice;
    private double? minArea;
    private int? currentUserId;

    public class GoongSuggestion
    {
        public string description { get; set; } = string.Empty;
        public string place_id { get; set; } = string.Empty;
    }

    private List<GoongSuggestion> suggestions = new();
    private bool isDropdownOpen = false;

    protected override async Task OnInitializedAsync()
    {
        // Get current user ID
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                              ?? user.FindFirst("sub")?.Value;
                if (int.TryParse(userIdStr, out var uid))
                {
                    currentUserId = uid;
                    favoriteRoomIds = await FavoriteService.GetUserFavoriteRoomIdsAsync(uid);
                }
            }
        }

        // Load all available rooms
        rooms = await RoomService.SearchRoomsAsync(null, null, null, null);
        isLoading = false;
    }

    private async Task ApplyFilters()
    {
        isLoading = true;
        var addr = !string.IsNullOrWhiteSpace(filterAddress) ? filterAddress : searchQuery;
        rooms = await RoomService.SearchRoomsAsync(addr, minPrice, maxPrice, minArea);
        isLoading = false;
        await UpdateMapMarkersAsync();
    }

    private async Task ResetFilters()
    {
        searchQuery = null;
        filterAddress = null;
        minPrice = null;
        maxPrice = null;
        minArea = null;
        rooms = await RoomService.SearchRoomsAsync(null, null, null, null);
        await UpdateMapMarkersAsync();
        await JSRuntime.InvokeVoidAsync("goongMap.flyTo", "map", 16.0544, 108.2022, 12);
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            isDropdownOpen = false;
            filterAddress = searchQuery;
            await ApplyFilters();
            return;
        }

        if (string.IsNullOrWhiteSpace(searchQuery) || searchQuery.Length < 2)
        {
            suggestions.Clear();
            isDropdownOpen = false;
            return;
        }

        try
        {
            suggestions = await JSRuntime.InvokeAsync<List<GoongSuggestion>>("goongMap.getSuggestions", searchQuery);
            isDropdownOpen = suggestions != null && suggestions.Any();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error getting suggestions: " + ex.Message);
            suggestions.Clear();
            isDropdownOpen = false;
        }
    }

    private async Task SelectSuggestion(string description)
    {
        searchQuery = description;
        filterAddress = description;
        suggestions.Clear();
        isDropdownOpen = false;
        await ApplyFilters();

        try
        {
            var coord = await JSRuntime.InvokeAsync<System.Text.Json.JsonElement?>("goongMap.geocode", description);
            if (coord != null && coord.Value.ValueKind != System.Text.Json.JsonValueKind.Null)
            {
                if (coord.Value.TryGetProperty("lat", out var latEl) && coord.Value.TryGetProperty("lng", out var lngEl))
                {
                    double lat = latEl.GetDouble();
                    double lng = lngEl.GetDouble();
                    await JSRuntime.InvokeVoidAsync("goongMap.flyTo", "map", lat, lng, 13);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error geocoding location: " + ex.Message);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500); // Wait for scripts to load and layout to settle
            await JSRuntime.InvokeVoidAsync("goongMap.initSearchMap", "map", 16.0544, 108.2022, 12);
            await UpdateMapMarkersAsync();
        }
    }

    private async Task UpdateMapMarkersAsync()
    {
        if (rooms == null) return;
        
        // Pass room addresses so the JS side can use Goong geocoding API to find the real locations
        var mapData = rooms.Where(r => !string.IsNullOrEmpty(r.Address)).Select(r => new
        {
            address = r.Address,
            price = r.Price >= 1000000 ? (r.Price / 1000000).ToString("0.#") + "tr" : (r.Price / 1000).ToString("0") + "k"
        }).ToList();
        
        try
        {
            await JSRuntime.InvokeVoidAsync("goongMap.addMarkers", "map", mapData);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to update map markers: " + ex.Message);
        }
    }

    private async Task ToggleFavorite(int roomId)
    {
        if (currentUserId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        var added = await FavoriteService.ToggleFavoriteAsync(currentUserId.Value, roomId);
        if (added)
            favoriteRoomIds.Add(roomId);
        else
            favoriteRoomIds.Remove(roomId);
    }
}
