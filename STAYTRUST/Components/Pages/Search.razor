                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                        <span class="material-symbols-outlined text-[#13ecda] text-xl">search</span>
                    </div>
                    <input class="block w-full pl-11 pr-4 py-2 bg-[#193331] border-none rounded-xl text-sm focus:ring-1 focus:ring-[#13ecda] placeholder-[#92c9c5]" placeholder="Location: Sơn Trà, Đà Nẵng | 'Modern Studio'" type="text" />
                </div>
            </div>
        </div>
        <div class="flex items-center gap-6">
            <nav class="hidden md:flex items-center gap-6">
                <a class="text-white hover:text-[#13ecda] transition-colors text-sm font-medium" href="#">Discover</a>
                <a class="text-white hover:text-[#13ecda] transition-colors text-sm font-medium" href="#">Listings</a>
