@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public bool IsActive { get; set; }

    [Parameter]
    public string Icon { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public List<string> Options { get; set; } = new();

    [Parameter]
    public string SelectedOption { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnOptionSelected { get; set; }

    private async Task SelectOption(string option)
    {
        await OnOptionSelected.InvokeAsync(option);
    }
}

<div class="relative">
    @if (IsActive && Options.Any())
    {
        <button class="flex h-10 items-center gap-2 px-4 rounded-xl bg-primary text-background-dark font-bold text-sm shadow-lg shadow-primary/20 z-10 relative" @onclick="OnClick">
            @Label 
            @if (!string.IsNullOrEmpty(SelectedOption))
            {
                <span class="text-xs bg-background-dark/20 px-2 py-0.5 rounded-md ml-1">@SelectedOption</span>
            }
            @if (!string.IsNullOrEmpty(Icon))
            {
                <span class="material-symbols-outlined text-lg transition-transform duration-200 rotate-180">@Icon</span>
            }
        </button>
        
        <!-- Dropdown Menu -->
        <div class="absolute top-12 left-0 w-48 bg-background-dark border border-white/10 rounded-xl shadow-xl shadow-black/50 overflow-hidden z-50 flex flex-col py-2 animate-in fade-in slide-in-from-top-2 duration-200">
            @foreach (var option in Options)
            {
                <button class="text-left px-4 py-2 text-sm text-slate-300 hover:bg-white/5 hover:text-primary transition-colors @(SelectedOption == option ? "text-primary font-bold bg-white/5" : "")"
                        @onclick="() => SelectOption(option)">
                    @option
                </button>
            }
        </div>
    }
    else
    {
        <button class="flex h-10 items-center gap-2 px-4 rounded-xl glass-card hover:bg-primary/10 transition-colors text-sm font-medium z-10 relative" @onclick="OnClick">
            @Label 
            @if (!string.IsNullOrEmpty(SelectedOption))
            {
                <span class="text-xs bg-primary/20 text-primary px-2 py-0.5 rounded-md ml-1">@SelectedOption</span>
            }
            @if (!string.IsNullOrEmpty(Icon))
            {
                <span class="material-symbols-outlined text-sm">@Icon</span>
            }
        </button>
    }
</div>
